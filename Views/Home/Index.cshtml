@{
    ViewData["Title"] = "Transforme prática em evolução musical";
    Layout = "_LandingLayout";
}

<!-- ===================== NAV ===================== -->
<header class="nav" id="nav">
    <div class="wrap nav-inner">
        <a class="brand" href="/">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" width="38" height="38" />
            <span class="brand-text">YourRhythm<span>.</span>
                <span class="brand-sub">Studio</span>
            </span>
        </a>
        <nav class="nav-links" aria-label="Navegação principal">
            <a asp-controller="Home" asp-action="Piano">Piano Virtual</a>
        </nav>
        <div class="nav-cta">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-login" asp-controller="Dashboard" asp-action="Index">Meu painel</a>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="nav-logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary" style="padding:11px 20px">Sair</button>
                </form>
            }
            else
            {
                <a class="nav-login" asp-controller="Auth" asp-action="Login">Entrar</a>
                <a class="btn btn-primary" style="padding:11px 20px" asp-controller="Auth" asp-action="Register">Solicitar acesso</a>
            }
        </div>
        <button class="nav-hamburger" id="navHamburger" type="button"
                aria-label="Abrir menu" aria-expanded="false" aria-controls="navMobile">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

<div class="nav-mobile-backdrop" id="navMobileBackdrop" aria-hidden="true"></div>
<nav class="nav-mobile" id="navMobile" aria-label="Menu de navegação" aria-hidden="true">
    <div class="nav-mobile-top">
        <button class="nav-mobile-close" id="navMobileClose" type="button" aria-label="Fechar menu">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor"
                 stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                <path d="M2 2l14 14M16 2L2 16"/>
            </svg>
        </button>
    </div>
    <div class="nav-mobile-auth">
        <a class="nav-mobile-link" asp-controller="Home" asp-action="Piano">Piano Virtual</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="nav-mobile-link" asp-controller="Dashboard" asp-action="Index">Meu painel</a>
            <form asp-controller="Auth" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary nav-mobile-cta">Sair</button>
            </form>
        }
        else
        {
            <a class="nav-mobile-link" asp-controller="Auth" asp-action="Login">Entrar</a>
            <a class="btn btn-primary nav-mobile-cta" asp-controller="Auth" asp-action="Register">Solicitar acesso →</a>
        }
        <a asp-controller="Home" asp-action="Privacy" class="nav-mobile-link nav-mobile-link--secondary">Privacidade</a>
    </div>
</nav>

<!-- ===================== HERO ===================== -->
<section class="hero">
    <div class="wrap hero-grid">
        <div class="hero-copy">
            <span class="eyebrow" data-aos="fade-down">
                <span class="dot"></span> Para professores e escolas de música
            </span>
            <h1 data-aos="fade-up">Seus alunos<br>praticam <span class="grad">mais.</span></h1>
            <p class="lead" data-aos="fade-up" data-aos-delay="80">
                Organize alunos, aulas, repertório e missões em um só lugar.
                Progresso visível que mantém o aluno tocando — toda semana, não só no dia da aula.
            </p>
            <div class="hero-actions" data-aos="fade-up" data-aos-delay="160">
                <a asp-controller="Auth" asp-action="Register" class="btn btn-primary">
                    Solicitar acesso <span class="arrow">&rarr;</span>
                </a>
                <a asp-controller="Auth" asp-action="Login" class="btn btn-ghost">Entrar</a>
            </div>
            <div class="hero-trust" data-aos="fade-up" data-aos-delay="220">
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                    Acesso revisado
                </span>
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                    Liberação pelo Root
                </span>
            </div>
        </div>

        <!-- Hero visual — purely decorative, no JS required -->
        <div class="hero-visual" data-aos="fade-left" data-aos-delay="100" aria-hidden="true">
            <div class="hv-main">
                <div class="hv-header">
                    <div class="hv-avatar">🎹</div>
                    <div class="hv-info">
                        <div class="hv-name">Ana Silva</div>
                        <div class="hv-sub">Piano · Nível Aprendiz</div>
                    </div>
                    <div class="hv-xp">+50 XP</div>
                </div>
                <div class="hv-mission">
                    <div class="hv-mission-label">Missão de hoje</div>
                    <div class="hv-mission-title">
                        Praticar Clair de Lune
                        <span class="hv-tag">Em andamento</span>
                    </div>
                    <div class="hv-prog">
                        <div class="bar"><i style="width:68%"></i></div>
                        <span class="hv-pct">68%</span>
                    </div>
                </div>
                <div class="hv-stats">
                    <div class="hv-stat"><b>12</b><span>dias seguidos</span></div>
                    <div class="hv-stat"><b>840</b><span>XP acumulado</span></div>
                    <div class="hv-stat"><b>5</b><span>músicas</span></div>
                </div>
            </div>
            <div class="hv-mini">
                <span class="hv-mini-icon">💬</span>
                <div class="hv-mini-body">
                    <div class="hv-mini-title">Feedback enviado</div>
                    <div class="hv-mini-sub">Presta atenção na dinâmica do compasso 8</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===================== FEATURES ===================== -->
<section class="sec" id="recursos">
    <div class="wrap">
        <div class="sec-head" data-aos="fade-up">
            <h2>Tudo que a música pede,<br><span class="grad">nada que ela não precisa.</span></h2>
            <p>Ferramentas pensadas para inspirar — não para virar mais um sistema.</p>
        </div>
        <div class="feat-grid">
            <div class="feat" data-aos="fade-up" data-aos-delay="0">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3>Alunos</h3>
                <p>Perfis individuais com histórico de aulas, repertório e evolução ao longo do tempo.</p>
            </div>
            <div class="feat" data-aos="fade-up" data-aos-delay="60">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1 2.7 3 6 3s6-2 6-3v-5"/></svg>
                </div>
                <h3>Aulas</h3>
                <p>Planeje encontros, registre conteúdos e acompanhe cada lição sem papelada.</p>
            </div>
            <div class="feat" data-aos="fade-up" data-aos-delay="120">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                </div>
                <h3>Repertório</h3>
                <p>Partituras, cifras e músicas favoritas organizadas por aluno e por nível.</p>
            </div>
            <div class="feat" data-aos="fade-up" data-aos-delay="0">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>
                </div>
                <h3>Missões</h3>
                <p>Desafios diários que transformam praticar em hábito — e hábito em evolução.</p>
            </div>
            <div class="feat" data-aos="fade-up" data-aos-delay="60">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3>Feedback</h3>
                <p>Comentários e orientações do professor registrados no contexto certo.</p>
            </div>
            <div class="feat" data-aos="fade-up" data-aos-delay="120">
                <div class="feat-ic">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>
                </div>
                <h3>Evolução</h3>
                <p>XP, níveis e progresso que motivam a prática constante e mostram resultados reais.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===================== HOW IT WORKS ===================== -->
<section class="sec sec-steps">
    <div class="wrap">
        <div class="sec-head" data-aos="fade-up">
            <h2>Simples de começar,<br><span class="grad">poderoso na prática.</span></h2>
        </div>
        <div class="steps">
            <div class="step" data-aos="fade-up" data-aos-delay="0">
                <div class="step-num">01</div>
                <h3>Crie perfis</h3>
                <p>Cadastre seus alunos, adicione o repertório e defina o nível de cada um.</p>
            </div>
            <div class="step-arrow" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div class="step" data-aos="fade-up" data-aos-delay="80">
                <div class="step-num">02</div>
                <h3>Atribua missões</h3>
                <p>O aluno recebe tarefas diárias, pratica no instrumento e registra o progresso.</p>
            </div>
            <div class="step-arrow" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div class="step" data-aos="fade-up" data-aos-delay="160">
                <div class="step-num">03</div>
                <h3>Acompanhe a evolução</h3>
                <p>XP, níveis e gráficos mostram o avanço para o aluno, o professor e a família.</p>
            </div>
        </div>
    </div>
</section>

<!-- ===================== FINAL CTA ===================== -->
<section class="cta">
    <div class="wrap">
        <div data-aos="fade-up">
            <h2>Seu ritmo. Suas aulas.<br><span class="grad">Seus alunos evoluindo.</span></h2>
            <p>Comece hoje e veja a prática acontecer — todos os dias, não só na aula.</p>
            <a asp-controller="Auth" asp-action="Register" class="btn btn-primary" style="padding:17px 34px;font-size:16px">
                Solicitar acesso <span class="arrow">&rarr;</span>
            </a>
            <div class="hero-trust cta-trust">
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
                    Acesso revisado
                </span>
                <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                    Liberação pelo Root
                </span>
            </div>
        </div>
    </div>
</section>

<!-- ===================== FOOTER ===================== -->
<footer class="foot">
    <div class="wrap foot-inner">
        <a class="brand" href="/">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" width="32" height="32" />
            <span class="brand-text">YourRhythm<span>.</span></span>
        </a>
        <div class="foot-links">
            <a asp-controller="Home" asp-action="Privacy">Privacidade</a>
        </div>
        <p>&copy; 2026 YourRhythm Studio</p>
    </div>
</footer>
