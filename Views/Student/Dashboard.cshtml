@model YourRhythmStudio.ViewModels.Learning.StudentDashboardViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meu painel";
    ViewData["Role"] = "student";
    var first = (User.Identity?.Name ?? "Aluno").Split(' ')[0];

    var xp        = Model.Summary.Progress.CurrentXp;
    var level     = Model.Summary.Progress.CurrentLevel;
    var pending   = Model.Summary.Progress.PendingAssignments;
    var completed = Model.Summary.Progress.CompletedAssignments;
    var repCount  = Model.Summary.RepertoireInProgress.Count;
    var xpIn      = Model.Summary.Progress.XpInCurrentLevel;
    var xpNeed    = Model.Summary.Progress.XpRequiredForCurrentLevel;
    var xpPct     = Model.Summary.Progress.CurrentLevelProgressPercent;
    var nextAssignment = Model.Summary.PendingAssignments.FirstOrDefault();
    var nextRepertoire = Model.Summary.RepertoireInProgress.FirstOrDefault();
    var hasContent = nextAssignment is not null || nextRepertoire is not null
                     || Model.Summary.RecentFeedback.Any()
                     || Model.Summary.RepertoireInProgress.Any();

    var rankLabel = Model.Summary.Progress.CurrentLevelName;
}

@* ── Hero Card ──────────────────────────────────────────────────── *@
<a href="@Url.Action("Levels","Student")" class="s-hero lvl-@level" data-yr-reveal style="--d:0s">
    <div class="s-hero-glow"></div>

    @* Particles — lvl 3-5, high perf only *@
    @if (level >= 3) {
    <div class="s-hero-particles">
        <span style="left:15%;top:60%;--dur:3.2s;--delay2:0s"></span>
        <span style="left:30%;top:70%;--dur:4.1s;--delay2:.7s"></span>
        <span style="left:55%;top:55%;--dur:3.6s;--delay2:1.2s"></span>
        <span style="left:70%;top:65%;--dur:4.8s;--delay2:.3s"></span>
        <span style="left:82%;top:50%;--dur:3.0s;--delay2:1.8s"></span>
    </div>
    }

    <div class="s-hero-top">
        <div class="s-badge-wrap">
            <div class="s-badge-ring"></div>
            <div class="s-badge s-badge-svg">
                <partial name="_LevelBadge" model="@level" />
            </div>
        </div>

        <div class="s-hero-meta">
            <div class="s-hero-greeting">Sua jornada</div>
            <div class="s-hero-name">@first</div>
            <div class="s-hero-rank">@rankLabel · Nível @level</div>
        </div>

    </div>

    <div class="s-bar-area">
        @if (level >= 5) {
            <div class="s-bar-labels"><span>Nível <b>MAX</b></span><b>@rankLabel</b></div>
        } else {
            <div class="s-bar-labels">
                <span><b id="heroXpIn">@xpIn</b> / @xpNeed XP para @Model.Summary.Progress.NextLevelName</span>
                <b>@xpPct%</b>
            </div>
        }
        <div class="s-xp-track">
            <div class="s-xp-fill" id="heroXpFill" style="width:0"></div>
        </div>
    </div>
</a>

@* ── Stat chips ─────────────────────────────────────────────────── *@
<div class="s-chips">
    <a class="s-chip s-chip-warn" asp-controller="Student" asp-action="Assignments"
       data-yr-reveal style="--d:.08s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg></div>
        <div class="s-chip-val" data-count="@pending">@pending</div>
        <div class="s-chip-lbl">Missões abertas</div>
    </a>
    <a class="s-chip s-chip-ok" asp-controller="Student" asp-action="Assignments"
       data-yr-reveal style="--d:.14s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg></div>
        <div class="s-chip-val" data-count="@completed">@completed</div>
        <div class="s-chip-lbl">Concluídas</div>
    </a>
    <a class="s-chip s-chip-blue" asp-controller="Student" asp-action="Repertoire"
       data-yr-reveal style="--d:.20s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <div class="s-chip-val" data-count="@repCount">@repCount</div>
        <div class="s-chip-lbl">Em repertório</div>
    </a>
</div>

@* ── Next move card ──────────────────────────────────────────────── *@
<div class="s-next lvl-@level" data-yr-reveal style="--d:.26s">
    <div class="s-next-body">
        <div class="s-next-kicker">Próxima jogada</div>
        @if (nextAssignment is not null) {
            <div class="s-next-title">@nextAssignment.Title</div>
            <div class="s-next-desc">Missão pronta para avançar · +@nextAssignment.XpReward XP</div>
        } else if (nextRepertoire is not null) {
            <div class="s-next-title">@nextRepertoire.Title</div>
            <div class="s-next-desc">Registre seu estudo para acumular XP</div>
        } else {
            <div class="s-next-title">Tudo em dia!</div>
            <div class="s-next-desc">Novas missões aparecem assim que seu professor enviar.</div>
        }
    </div>
    @if (nextAssignment is not null) {
        <a class="s-next-btn" asp-controller="Student" asp-action="Assignments">Abrir missões</a>
    } else if (nextRepertoire is not null) {
        <a class="s-next-btn" asp-controller="Student" asp-action="RepertoireDetail" asp-route-id="@nextRepertoire.Id">Abrir repertório</a>
    } else {
        <a class="s-next-btn ghost" asp-controller="Student" asp-action="Progress">Ver progresso</a>
    }
</div>

@* ── Panels row ──────────────────────────────────────────────────── *@
<div class="s-panels">
    @* Feedback *@
    <div class="s-panel" data-yr-reveal style="--d:.33s">
        <div class="s-panel-head">
            <div>
                <div class="s-panel-kicker">Do Professor</div>
                <h3>Feedback</h3>
            </div>
            <a class="s-panel-link" asp-controller="Student" asp-action="Feedback">Ver tudo →</a>
        </div>

        @if (Model.Summary.RecentFeedback.Any()) {
            @foreach (var fb in Model.Summary.RecentFeedback.Take(2)) {
            <div class="s-fb-item">
                <div class="s-fb-row">
                    <span class="s-fb-who">Professor</span>
                    <span class="s-fb-date">@fb.CreatedAtUtc.ToLocalTime().ToString("dd/MM")</span>
                </div>
                <div class="s-fb-msg">@fb.Message</div>
            </div>
            }
        } else {
            <div class="s-empty">
                <div class="s-empty-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
                <div class="s-empty-msg">Nenhum feedback visível ainda.</div>
            </div>
        }
    </div>

    @* Repertoire *@
    <div class="s-panel" data-yr-reveal style="--d:.40s">
        <div class="s-panel-head">
            <div>
                <div class="s-panel-kicker">Em estudo</div>
                <h3>Repertório</h3>
            </div>
            <a class="s-panel-link" asp-controller="Student" asp-action="Repertoire">Ver tudo →</a>
        </div>

        @if (Model.Summary.RepertoireInProgress.Any()) {
            @foreach (var rep in Model.Summary.RepertoireInProgress.Take(3)) {
            <a class="s-rep-item" asp-controller="Student" asp-action="RepertoireDetail" asp-route-id="@rep.Id">
                <div class="s-rep-ico">YR</div>
                <div class="s-rep-body">
                    <div class="s-rep-title">@rep.Title</div>
                    <div class="s-rep-artist">@(rep.HasAudio ? "Audio disponivel" : "Material por link")</div>
                    <div class="s-rep-bar-wrap">
                        <div class="s-rep-bar"><i style="width:@rep.ProgressPercent%"></i></div>
                        <div class="s-rep-pct">@rep.ProgressPercent% acessado</div>
                    </div>
                </div>
            </a>
            }
        } else {
            <div class="s-empty">
                <div class="s-empty-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
                <div class="s-empty-msg">Nenhum repertório em andamento.</div>
            </div>
        }
    </div>
</div>

@if (!hasContent) {
<div class="s-empty" style="margin-top:32px">
    <div class="s-empty-icon">YR</div>
    <div class="s-empty-msg">Nenhuma atividade ainda.<br>Seu professor em breve criará missões para você.</div>
</div>
}

@section Scripts {
<script>
(function(){
    // Count-up for hero XP and chips
    function runCountUps() {
        document.querySelectorAll('.s-chip-val[data-count]').forEach(function(el){
            window.yrCountUp(el, parseInt(el.dataset.count || '0'), 700);
        });
    }

    // XP bar fill
    function runBar() {
        var fill = document.getElementById('heroXpFill');
        window.yrBarAnimate(fill, @xpPct);
    }

    // Wait for hero to be revealed, then run
    var hero = document.querySelector('.s-hero');
    if (!hero) { runCountUps(); runBar(); return; }

    if (window.yrTier === 'low') {
        runCountUps(); runBar(); return;
    }

    var started = false;
    var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
            if (e.isIntersecting && !started) {
                started = true;
                setTimeout(runCountUps, 120);
                runBar();
                io.disconnect();
            }
        });
    }, { threshold: 0.1 });
    io.observe(hero);
}());
</script>
}
