@using YourRhythmStudio.Domain.Learning.Enums
@using YourRhythmStudio.Application.Learning
@model YourRhythmStudio.ViewModels.Learning.StudentLevelsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Progressão";
    ViewData["Role"] = "student";

    var xp    = Model.Progress.CurrentXp;
    var level = Model.Progress.CurrentLevel;

    var xpIn = Model.Progress.XpInCurrentLevel;
    var xpNeed = Model.Progress.XpRequiredForCurrentLevel;
    var xpPct = Model.Progress.CurrentLevelProgressPercent;
    var waitingPromotion = Model.Progress.AwaitingPromotion;

    var masteredCount = Model.Skills.Count(s => s.Mastered);
    var totalSkills   = Model.Skills.Count;
    var promotionSkill = level < 5
        ? Model.Skills.FirstOrDefault(s => s.SkillType == SkillType.PromotionRequired && s.RequiredLevel == level)
        : null;

    var tiers = LearningLevelCalculator.Levels;
}

@* ── Progress Hero ──────────────────────────────────────────────────── *@
<div class="s-prog-hero lvl-@level" data-yr-reveal style="--d:0s">
    <div class="s-ph-eyebrow">Classificação atual</div>
    <div class="s-ph-hex">@level</div>
    <div class="s-ph-xp-big" id="lvlXpBig" data-count="@xp">@xp</div>
    <div class="s-ph-xp-lbl">XP total</div>

    <div style="margin:16px 0 0;padding:0 4px;position:relative;z-index:1">
        <div class="s-bar-labels" style="margin-bottom:5px">
            @if (level >= 5) {
                <span style="color:var(--xp)">Nível máximo atingido</span><b style="color:var(--xp)">MAX</b>
            } else if (waitingPromotion) {
                <span style="color:var(--lvl-a,var(--xp))">XP suficiente — aguardando promoção do professor</span>
                <b style="color:var(--lvl-a,var(--xp))">100%</b>
            } else {
                <span style="color:var(--muted)"><b style="color:var(--lvl-a,var(--xp))">@xpIn</b> / @xpNeed XP para @Model.Progress.NextLevelName</span>
                <span style="color:var(--muted)">@xpPct%</span>
            }
        </div>
        <div class="s-xp-track">
            <div class="s-xp-fill @(waitingPromotion ? "s-xp-fill-full" : "")" id="lvlXpFill" style="width:0"></div>
        </div>
    </div>

    @* Promotion skill callout *@
    @if (promotionSkill is not null) {
        <div class="promo-callout @(promotionSkill.Mastered ? "promo-callout-done" : "")" style="margin-top:14px">
            @if (promotionSkill.Mastered) {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg>
                <span>Promoção desbloqueada: <b>@promotionSkill.Name</b></span>
            } else {
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
                <span>Habilidade de promoção: <b>@promotionSkill.Name</b></span>
            }
        </div>
    }

    <div class="s-ph-stats">
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@level</span>
            <span class="s-ph-stat-lbl">Nível</span>
        </div>
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@masteredCount</span>
            <span class="s-ph-stat-lbl">Habilidades</span>
        </div>
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@Model.Progress.CompletedAssignments</span>
            <span class="s-ph-stat-lbl">Missões</span>
        </div>
    </div>
</div>

@* ── Stat chips ─────────────────────────────────────────────────────── *@
<div class="s-chips" style="margin-bottom:20px">
    <div class="s-chip s-chip-ok" data-yr-reveal style="--d:.08s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg></div>
        <div class="s-chip-val" data-count="@masteredCount">@masteredCount</div>
        <div class="s-chip-lbl">Dominadas</div>
    </div>
    <div class="s-chip s-chip-blue" data-yr-reveal style="--d:.14s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <div class="s-chip-val" data-count="@totalSkills">@totalSkills</div>
        <div class="s-chip-lbl">Total</div>
    </div>
    <div class="s-chip s-chip-warn" data-yr-reveal style="--d:.20s">
        <div class="s-chip-ico"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10"/></svg></div>
        <div class="s-chip-val">@xp</div>
        <div class="s-chip-lbl">XP Total</div>
    </div>
</div>

@* ── Journey ─────────────────────────────────────────────────────────── *@
<div class="s-sec" data-yr-reveal style="--d:.26s">
    <span class="s-sec-title">Habilidades por nível</span>
    <span class="s-sec-badge">definido pelo professor</span>
</div>

@if (!Model.Skills.Any()) {
    <div class="s-empty" data-yr-reveal style="--d:.32s">
        <div class="s-empty-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <div class="s-empty-msg">Seu professor ainda não definiu as habilidades por nível.</div>
    </div>
} else {
    <div class="lvl-journey">
        @{ int tierIdx = 0; }
        @foreach (var tier in tiers) {
            tierIdx++;
            var tierSkills   = Model.Skills.Where(s => s.RequiredLevel == tier.Level).ToList();
            var tierMastered = tierSkills.Count(s => s.Mastered);
            var isCurrent    = level == tier.Level;
            var isUnlocked   = level >= tier.Level;
            var tierPct      = tierSkills.Count == 0 ? (isUnlocked ? 100 : 0) : tierMastered * 100 / tierSkills.Count;
            var delay        = (0.30 + tierIdx * 0.07).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
            <div class="lvl-tier lvl-@tier.Level @(isUnlocked ? "lvl-tier-unlocked" : "lvl-tier-locked")"
                 data-yr-reveal style="--d:@(delay)s" data-tier-pct="@tierPct">
                <div class="lvl-tier-left">
                    <div class="lvl-tier-badge">
                        @if (isUnlocked) { <span>@tier.Level</span> }
                        else { <span style="opacity:.4;display:flex;align-items:center;justify-content:center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></span> }
                    </div>
                    @if (tier.Level < 5) {
                        <div class="lvl-tier-line @(isUnlocked ? "lvl-tier-line-on" : "")"></div>
                    }
                </div>

                <div class="lvl-tier-body">
                    <div class="lvl-tier-head">
                        <div>
                            <div class="lvl-tier-name">Nível @tier.Level — @tier.Name</div>
                            <div class="lvl-tier-range">
                                @tierMastered/@tierSkills.Count habilidades
                                @if (tier.Level < 5) {
                                    <span>· @tier.MinXp.ToString("N0") – @tier.MaxXp.ToString("N0") XP</span>
                                } else {
                                    <span>· @tier.MinXp.ToString("N0") – @tier.MaxXp.ToString("N0") XP</span>
                                }
                            </div>
                        </div>
                        @if (isCurrent)      { <span class="lvl-tier-tag">Atual</span> }
                        else if (isUnlocked) { <span class="lvl-tier-tag lvl-tier-done">Possui</span> }
                    </div>

                    <div class="lvl-tier-bar-wrap">
                        <div class="lvl-tier-bar">
                            <i class="lvl-tier-bar-fill" style="width:0"></i>
                        </div>
                    </div>

                    @if (tierSkills.Any()) {
                        <div class="lvl-skills">
                            @foreach (var skill in tierSkills) {
                                var src = skill.InferredFromCurrentLevel
                                    ? "pelo nível"
                                    : skill.MasteredAtUtc.HasValue
                                        ? skill.MasteredAtUtc.Value.ToLocalTime().ToString("dd/MM/yy")
                                        : "pendente";
                                var isPromotion = skill.SkillType == SkillType.PromotionRequired;
                                var isLegendary = skill.SkillType == SkillType.MissionReward;
                                <div class="lvl-skill @(skill.Mastered ? "lvl-skill-mastered" : "lvl-skill-pending") @(isPromotion ? "lvl-skill-promo" : "")">
                                    <span class="lvl-skill-dot">@if(skill.Mastered){<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg>}else{<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="6" y1="12" x2="18" y2="12"/></svg>}</span>
                                    <span class="lvl-skill-name">@skill.Name</span>
                                    @if (isPromotion) {
                                        <span class="skill-type-badge skill-type-promo">Promoção</span>
                                    } else if (isLegendary) {
                                        <span class="skill-type-badge skill-type-legend">Lendária</span>
                                    } else {
                                        <span class="skill-type-badge skill-type-special">Especial</span>
                                    }
                                    <span style="font-size:11px;color:var(--muted);margin-left:4px">@src</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(skill.Description)) {
                                    <div style="font-size:12px;color:var(--muted);padding:2px 0 8px 34px;line-height:1.5">@skill.Description</div>
                                }
                            }
                        </div>
                    } else {
                        <p class="s-muted" style="margin:8px 0 0;font-size:13px">Nenhuma habilidade definida para este nível.</p>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
.promo-callout {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px; border-radius: 10px; margin-top: 14px;
    background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.12);
    font-size: 13px; color: rgba(255,255,255,.75); position: relative; z-index: 1;
}
.promo-callout svg { flex-shrink: 0; opacity: .7; }
.promo-callout-done { background: rgba(95,208,160,.08); border-color: rgba(95,208,160,.25); color: #5fd0a0; }
.promo-callout-done svg { color: #5fd0a0; opacity: 1; }

.skill-type-badge {
    display: inline-flex; align-items: center;
    font-size: 10px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase;
    padding: 2px 7px; border-radius: 6px; flex-shrink: 0; margin-left: auto;
}
.skill-type-promo  { background: rgba(255,176,32,.12);  color: #ffb020; border: 1px solid rgba(255,176,32,.2);  }
.skill-type-legend { background: rgba(168,85,247,.12);  color: #c084fc; border: 1px solid rgba(168,85,247,.2);  }
.skill-type-special{ background: rgba(59,130,246,.10);  color: #60a5fa; border: 1px solid rgba(59,130,246,.18); }

.lvl-skill-promo { border-left: 2px solid rgba(255,176,32,.4); padding-left: 8px; }
.lvl-skill-promo.lvl-skill-mastered { border-left-color: #ffb020; }

.s-xp-fill-full { background: linear-gradient(90deg, var(--lvl-a, var(--xp)), var(--lvl-b, var(--xp))); animation: yr-xp-pulse 2s ease-in-out infinite; }
@@keyframes yr-xp-pulse { 0%,100%{opacity:1} 50%{opacity:.75} }
</style>

@section Scripts {
<script>
(function(){
    var bigEl = document.getElementById('lvlXpBig');
    if (bigEl) window.yrCountUp(bigEl, parseInt(bigEl.dataset.count || '0', 10), 900);
    window.yrBarAnimate(document.getElementById('lvlXpFill'), @xpPct);

    document.querySelectorAll('.s-chip-val[data-count]').forEach(function(el){
        window.yrCountUp(el, parseInt(el.dataset.count || '0', 10), 700);
    });

    if (!window.IntersectionObserver || window.yrTier === 'low') {
        document.querySelectorAll('.lvl-tier[data-tier-pct]').forEach(function(tier){
            var fill = tier.querySelector('.lvl-tier-bar-fill');
            if (fill) fill.style.width = tier.dataset.tierPct + '%';
        });
        return;
    }

    var barObserver = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
            if (!e.isIntersecting) return;
            var tier = e.target;
            var fill = tier.querySelector('.lvl-tier-bar-fill');
            if (fill) setTimeout(function(){ fill.style.width = tier.dataset.tierPct + '%'; }, 200);
            barObserver.unobserve(tier);
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.lvl-tier[data-tier-pct]').forEach(function(tier){
        barObserver.observe(tier);
    });
}());
</script>
}
