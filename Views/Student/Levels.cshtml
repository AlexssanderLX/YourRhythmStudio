@model YourRhythmStudio.ViewModels.Learning.StudentLevelsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Níveis";
    ViewData["Role"] = "student";

    var xp            = Model.Progress.CurrentXp;
    var level         = Model.Progress.CurrentLevel;
    var masteredCount = Model.Skills.Count(s => s.Mastered);
    var totalSkills   = Model.Skills.Count;
    var nextLevel     = level < 5 ? level + 1 : 5;
    var nextPending   = Model.Skills.Count(s => s.RequiredLevel == nextLevel && !s.Mastered);
    var (xpIn, xpNeed, xpPct) = XpProgress(xp, level);

    var tiers = new[] {
        (Num:1, Name:"Iniciante",     XpStart:0,    XpEnd:100),
        (Num:2, Name:"Aprendiz",      XpStart:100,  XpEnd:250),
        (Num:3, Name:"Intermediário", XpStart:250,  XpEnd:500),
        (Num:4, Name:"Avançado",      XpStart:500,  XpEnd:1000),
        (Num:5, Name:"Mestre",        XpStart:1000, XpEnd:9999),
    };
}

@* ── Progress Hero ────────────────────────────────────────────────── *@
<div class="s-prog-hero lvl-@level" data-yr-reveal style="--d:0s">
    <div class="s-ph-eyebrow">Classificação atual</div>
    <div class="s-ph-hex">@level</div>
    <div class="s-ph-xp-big" id="lvlXpBig" data-count="@xp">@xp</div>
    <div class="s-ph-xp-lbl">XP total</div>

    <div style="margin:16px 0 0;padding:0 4px;position:relative;z-index:1">
        <div class="s-bar-labels" style="margin-bottom:5px">
            @if (level >= 5) {
                <span style="color:var(--xp)">Nível máximo atingido</span><b style="color:var(--xp)">MAX</b>
            } else {
                <span style="color:var(--muted)"><b style="color:var(--lvl-a,var(--xp))">@xpIn</b> / @xpNeed XP para nível @(level+1)</span>
                <span style="color:var(--muted)">@xpPct%</span>
            }
        </div>
        <div class="s-xp-track">
            <div class="s-xp-fill" id="lvlXpFill" style="width:0"></div>
        </div>
    </div>
</div>

@* ── Stat chips ─────────────────────────────────────────────────────── *@
<div class="s-chips" style="margin-bottom:20px">
    <div class="s-chip s-chip-ok" data-yr-reveal style="--d:.08s">
        <div class="s-chip-ico">⭐</div>
        <div class="s-chip-val" data-count="@masteredCount">@masteredCount</div>
        <div class="s-chip-lbl">Habilidades</div>
    </div>
    <div class="s-chip s-chip-blue" data-yr-reveal style="--d:.14s">
        <div class="s-chip-ico">📋</div>
        <div class="s-chip-val" data-count="@totalSkills">@totalSkills</div>
        <div class="s-chip-lbl">Total definidas</div>
    </div>
    <div class="s-chip s-chip-warn" data-yr-reveal style="--d:.20s">
        <div class="s-chip-ico">🔒</div>
        <div class="s-chip-val" data-count="@nextPending">@nextPending</div>
        <div class="s-chip-lbl">Próx. nível</div>
    </div>
</div>

@* ── Journey ─────────────────────────────────────────────────────────── *@
<div class="s-sec" data-yr-reveal style="--d:.26s">
    <span class="s-sec-title">Habilidades por nível</span>
    <span class="s-sec-badge">definido pelo professor</span>
</div>

@if (!Model.Skills.Any()) {
    <div class="s-empty" data-yr-reveal style="--d:.32s">
        <div class="s-empty-icon">📜</div>
        <div class="s-empty-msg">Seu professor ainda não definiu as habilidades por nível.</div>
    </div>
} else {
    <div class="lvl-journey">
        @{ int tierIdx = 0; }
        @foreach (var tier in tiers) {
            tierIdx++;
            var tierSkills    = Model.Skills.Where(s => s.RequiredLevel == tier.Num).ToList();
            var tierMastered  = tierSkills.Count(s => s.Mastered);
            var isCurrent     = level == tier.Num;
            var isUnlocked    = level >= tier.Num;
            var tierPct       = tierSkills.Count == 0 ? (isUnlocked ? 100 : 0) : tierMastered * 100 / tierSkills.Count;
            var revealDelay   = (0.30 + tierIdx * 0.07).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
            <div class="lvl-tier lvl-@tier.Num @(isUnlocked ? "lvl-tier-unlocked" : "lvl-tier-locked")"
                 data-yr-reveal style="--d:@(revealDelay)s" data-tier-pct="@tierPct">
                <div class="lvl-tier-left">
                    <div class="lvl-tier-badge">
                        @if (isUnlocked) { <span>@tier.Num</span> }
                        else { <span style="font-size:14px;opacity:.5">🔒</span> }
                    </div>
                    @if (tier.Num < 5) {
                        <div class="lvl-tier-line @(isUnlocked ? "lvl-tier-line-on" : "")"></div>
                    }
                </div>

                <div class="lvl-tier-body">
                    <div class="lvl-tier-head">
                        <div>
                            <div class="lvl-tier-name">Nível @tier.Num — @tier.Name</div>
                            <div class="lvl-tier-range">
                                @tierMastered/@tierSkills.Count habilidades
                                @if (tier.Num < 5) {
                                    <span>· @tier.XpStart–@(tier.XpEnd-1) XP</span>
                                } else {
                                    <span>· @tier.XpStart+ XP</span>
                                }
                            </div>
                        </div>
                        @if (isCurrent)     { <span class="lvl-tier-tag">Atual</span> }
                        else if (isUnlocked){ <span class="lvl-tier-tag lvl-tier-done">Possui</span> }
                    </div>

                    <div class="lvl-tier-bar-wrap">
                        <div class="lvl-tier-bar">
                            <i class="lvl-tier-bar-fill" style="width:0"></i>
                        </div>
                    </div>

                    @if (tierSkills.Any()) {
                        <div class="lvl-skills">
                            @foreach (var skill in tierSkills) {
                                var src = skill.InferredFromCurrentLevel
                                    ? "pelo nível atual"
                                    : skill.MasteredAtUtc.HasValue
                                        ? skill.MasteredAtUtc.Value.ToLocalTime().ToString("dd/MM/yy")
                                        : "pendente";
                                <div class="lvl-skill @(skill.Mastered ? "lvl-skill-mastered" : "lvl-skill-pending")">
                                    <span class="lvl-skill-dot">@(skill.Mastered ? "✓" : "–")</span>
                                    <span class="lvl-skill-name">@skill.Name</span>
                                    <span style="margin-left:auto;font-size:11px;color:var(--muted)">@src</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(skill.Description)) {
                                    <div style="font-size:12px;color:var(--muted);padding:2px 0 8px 34px;line-height:1.5">@skill.Description</div>
                                }
                            }
                        </div>
                    } else {
                        <p class="s-muted" style="margin:8px 0 0;font-size:13px">Nenhuma habilidade definida para este nível.</p>
                    }
                </div>
            </div>
        }
    </div>
}

@functions {
    static (int xpIn, int xpNeed, int pct) XpProgress(int xp, int level) {
        if (level >= 5) return (xp - 1000, 0, 100);
        int[] starts = { 0, 100, 250, 500 };
        int[] ends   = { 100, 250, 500, 1000 };
        var i       = Math.Max(0, Math.Min(level - 1, 3));
        var current = Math.Max(0, xp - starts[i]);
        var need    = ends[i] - starts[i];
        return (current, need, Math.Min(100, need > 0 ? current * 100 / need : 100));
    }
}

@section Scripts {
<script>
(function(){
    // Hero XP count-up + bar
    var bigEl = document.getElementById('lvlXpBig');
    if (bigEl) window.yrCountUp(bigEl, parseInt(bigEl.dataset.count || '0', 10), 900);
    window.yrBarAnimate(document.getElementById('lvlXpFill'), @xpPct);

    // Chip count-ups
    document.querySelectorAll('.s-chip-val[data-count]').forEach(function(el){
        window.yrCountUp(el, parseInt(el.dataset.count || '0', 10), 700);
    });

    // Per-tier bar animation: fire when tier enters viewport
    if (!window.IntersectionObserver || window.yrTier === 'low') {
        document.querySelectorAll('.lvl-tier[data-tier-pct]').forEach(function(tier){
            var fill = tier.querySelector('.lvl-tier-bar-fill');
            if (fill) fill.style.width = tier.dataset.tierPct + '%';
        });
        return;
    }

    var barObserver = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
            if (!e.isIntersecting) return;
            var tier = e.target;
            var fill = tier.querySelector('.lvl-tier-bar-fill');
            if (fill) {
                setTimeout(function(){ fill.style.width = tier.dataset.tierPct + '%'; }, 200);
            }
            barObserver.unobserve(tier);
        });
    }, { threshold: 0.15 });

    document.querySelectorAll('.lvl-tier[data-tier-pct]').forEach(function(tier){
        barObserver.observe(tier);
    });
}());
</script>
}