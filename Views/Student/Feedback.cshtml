@model YourRhythmStudio.ViewModels.Learning.StudentFeedbackViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Feedback";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Feedback";
}

@if (Model.Feedback.Any()) {
    <div class="s-sec">
        <span class="s-sec-title">Feedbacks do professor</span>
        <span class="s-sec-badge">@Model.Feedback.Count mensagens</span>
    </div>
    <div class="fb-list">
        @foreach (var item in Model.Feedback.OrderByDescending(f => f.CreatedAtUtc)) {
            <div class="fb-bubble">
                <div class="fb-head">
                    <div class="fb-avatar">P</div>
                    <div class="fb-meta">
                        <span class="fb-from">Professor</span>
                        <span class="fb-date">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM · HH:mm")</span>
                    </div>
                </div>
                <div class="fb-msg">@item.Message</div>
            </div>
        }
    </div>
} else {
    <div class="s-empty">
        <div class="s-empty-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div>
        <div class="s-empty-msg">Nenhum feedback recebido ainda.<br>Quando seu professor deixar uma mensagem, ela aparecerá aqui.</div>
    </div>
}
