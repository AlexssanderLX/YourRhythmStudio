@model YourRhythmStudio.ViewModels.Learning.StudentRepertoireDetailViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Item.Title;
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Repertório";

    var item = Model.Item;
    var isAccessed = item.ProgressPercent >= 50;
    var isCompleted = item.ProgressPercent >= 100 || item.Status.ToString() == "Learned";
    var statusLabel = item.Status.ToString() switch
    {
        "NotStarted" => "Referência não acessada",
        "Practicing" => "Referência acessada",
        "Learned" => "Estudo concluído",
        "Archived" => "Arquivada",
        _ => item.Status.ToString()
    };
}

<a href="@Url.Action("Repertoire", "Student")" class="s-back-link">← Voltar ao repertório</a>

<section class="rep-quest lvl-@Math.Clamp(item.ProgressPercent / 25 + 1, 1, 5)">
    <div class="rep-quest-top">
        <div class="rep-orb">♪</div>
        <div class="rep-quest-copy">
            <div class="rep-kicker">Material de estudo</div>
            <h1>@item.Title</h1>
            <p>@(item.HasAudio ? "Áudio enviado pelo professor" : "Referência por link")</p>
        </div>
        <div class="rep-score">
            <strong>@item.ProgressPercent%</strong>
            <span>@statusLabel</span>
        </div>
    </div>

    <div class="rep-quest-bar"><i style="width:@item.ProgressPercent%"></i></div>

    <div class="rep-steps">
        <div class="rep-step @(isAccessed ? "done" : "active")">
            <span>1</span>
            <div><strong>Abrir referência</strong><small>Registra acesso e libera 50%</small></div>
        </div>
        <div class="rep-step @(isCompleted ? "done" : isAccessed ? "active" : "")">
            <span>2</span>
            <div><strong>Concluir estudo</strong><small>Aluno confirma que estudou o material</small></div>
        </div>
    </div>
</section>

<section class="rep-actions-grid">
    @if (!string.IsNullOrWhiteSpace(item.ReferenceUrl))
    {
        <a class="rep-action-card primary" href="@Url.Action("OpenRepertoireReference", "Student", new { id = item.Id })" target="_blank" rel="noopener">
            <span class="rep-action-icon">↗</span>
            <strong>Abrir referência</strong>
            <small>@(isAccessed ? "Referência acessada · 50% registrado" : "Clique para acessar o material")</small>
        </a>
    }
    @if (item.HasAudio)
    {
        <a class="rep-action-card primary" href="@Url.Action("RepertoireAudio", "Student", new { id = item.Id })">
            <span class="rep-action-icon">♪</span>
            <strong>Ouvir áudio</strong>
            <small>@item.AudioOriginalFileName</small>
        </a>
    }
    @if (string.IsNullOrWhiteSpace(item.ReferenceUrl) && !item.HasAudio)
    {
        <div class="rep-action-card disabled">
            <span class="rep-action-icon">–</span>
            <strong>Sem material</strong>
            <small>O professor ainda não adicionou link ou áudio.</small>
        </div>
    }

    <form asp-controller="Student" asp-action="CompleteRepertoire" asp-route-id="@item.Id" method="post" class="rep-action-form">
        @Html.AntiForgeryToken()
        <button class="rep-action-card complete" type="submit" @(isCompleted ? "disabled" : "")>
            <span class="rep-action-icon">✓</span>
            <strong>@(isCompleted ? "Estudo concluído" : "Marcar como concluído")</strong>
            <small>@(isCompleted ? "O aluno confirmou este material" : "Use depois de estudar")</small>
        </button>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(item.Notes))
{
    <section class="s-card rep-professor-note">
        <div class="s-sec-title">Dica do professor</div>
        <p>@item.Notes</p>
    </section>
}
