@model YourRhythmStudio.ViewModels.Learning.StudentRepertoireViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meu repertório";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Repertório";
}

<div class="stat-strip">
    <div class="stat-chip"><span class="sc-val">@Model.Repertoire.Count</span><span class="sc-lbl">Músicas</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">@Model.Repertoire.Count(r => r.Status.ToString() == "Completed")</span><span class="sc-lbl">Concluídas</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">@(Model.Repertoire.Any() ? (int)Model.Repertoire.Average(r => r.ProgressPercent) : 0)<small>%</small></span><span class="sc-lbl">Progresso médio</span></div>
</div>

<div class="card">
    <h3>Meu repertório</h3>
    <div class="card-sub" style="margin-bottom:16px">Músicas atribuídas pelo professor</div>

    @if (Model.Repertoire.Any())
    {
        <div class="row-list">
            @foreach (var item in Model.Repertoire)
            {
                <div class="prow">
                    <div class="pmeta">
                        <div class="pn">@item.Title</div>
                        <div class="ps">@item.ComposerOrArtist · @item.Status</div>
                        <div class="pbar" style="margin-top:6px"><i style="width:@item.ProgressPercent%"></i></div>
                    </div>
                    <div class="ppct">@item.ProgressPercent%</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>Nenhuma música adicionada ao repertório ainda.</p>
        </div>
    }
</div>
