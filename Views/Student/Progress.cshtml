@model YourRhythmStudio.ViewModels.Learning.StudentProgressViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Progresso";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Progresso";

    var xp    = Model.Progress.CurrentXp;
    var level = Model.Progress.CurrentLevel;
    var (xpIn, xpNeed, xpPct) = XpProgress(xp, level);
}

<div class="s-prog-hero lvl-@level">
    <div class="s-ph-eyebrow">Nível atual</div>
    <div class="s-ph-hex">@level</div>
    <div class="s-ph-xp-big">@xp</div>
    <div class="s-ph-xp-lbl">XP Total</div>

    <div style="margin:16px 0 0;padding:0 4px;position:relative;z-index:1">
        <div class="s-bar-labels" style="margin-bottom:5px">
            @if (level >= 5) {
                <span style="color:var(--xp)">Nível máximo atingido!</span>
                <b style="color:var(--xp)">MAX</b>
            } else {
                <span style="color:var(--muted)"><b style="color:var(--xp)">@xpIn</b> / @xpNeed XP para nível @(level+1)</span>
                <span style="color:var(--muted)">@xpPct%</span>
            }
        </div>
        <div class="s-xp-track">
            <div class="s-xp-fill" style="width:@xpPct%"></div>
        </div>
    </div>

    <div class="s-ph-stats">
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@level</span>
            <span class="s-ph-stat-lbl">Nível</span>
        </div>
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@Model.Progress.CompletedAssignments</span>
            <span class="s-ph-stat-lbl">Missões concluídas</span>
        </div>
        <div class="s-ph-stat">
            <span class="s-ph-stat-val">@Model.Progress.RecentXpEvents.Count</span>
            <span class="s-ph-stat-lbl">Eventos XP</span>
        </div>
    </div>
</div>

@if (Model.Progress.RecentXpEvents.Any()) {
    <div class="s-sec" style="margin-top:4px">
        <span class="s-sec-title">Histórico de XP</span>
    </div>
    <div class="s-card">
        <div class="xp-feed">
            @foreach (var item in Model.Progress.RecentXpEvents) {
                <div class="xp-ev">
                    <div class="xp-ev-badge">+@item.Points</div>
                    <div class="xp-ev-body">
                        <div class="xp-ev-title">@item.Description</div>
                        <div class="xp-ev-date">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM · HH:mm")</div>
                    </div>
                </div>
            }
        </div>
    </div>
} else {
    <div class="s-empty">
        <div class="s-empty-icon"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg></div>
        <div class="s-empty-msg">Nenhum XP ganho ainda.<br>Complete missões para ver seu progresso aqui!</div>
    </div>
}

@functions {
    static (int xpIn, int xpNeed, int pct) XpProgress(int xp, int level) {
        if (level >= 5) return (xp, 0, 100);
        int[] promotionXp = { 0, 500, 2_000, 8_000, 25_000 };
        var need = promotionXp[Math.Min(level, 4)];
        var pct  = need > 0 ? Math.Min(100, xp * 100 / need) : 100;
        return (xp, need, pct);
    }
}
