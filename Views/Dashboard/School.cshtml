@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Painel da escola";
    ViewData["Role"] = "school";
    var name = User.Identity?.Name ?? "Escola";
    ViewData["DashTitle"] = $"Visão geral · {name}";
}

<div class="dash-grid cols-4">
    <div class="card stat">
        <div class="stat-top">
            <div class="stat-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1 2.7 3 6 3s6-2 6-3v-5"/></svg></div>
            <span class="stat-trend">+12</span>
        </div>
        <div class="stat-val">128</div>
        <div class="stat-label">Alunos ativos</div>
    </div>
    <div class="card stat">
        <div class="stat-top">
            <div class="stat-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="8" r="3.5"/><path d="M3 20a6 6 0 0 1 12 0"/></svg></div>
            <span class="stat-trend">+1</span>
        </div>
        <div class="stat-val">9</div>
        <div class="stat-label">Professores</div>
    </div>
    <div class="card stat">
        <div class="stat-top">
            <div class="stat-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4.5" width="18" height="16" rx="2"/><path d="M3 9h18"/></svg></div>
        </div>
        <div class="stat-val">54</div>
        <div class="stat-label">Aulas hoje</div>
    </div>
    <div class="card stat">
        <div class="stat-top">
            <div class="stat-ic"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 6.5 7 .6-5.3 4.6L18.4 21 12 17.3 5.6 21l1.7-7.3L2 9.1l7-.6z"/></svg></div>
            <span class="stat-trend">+8%</span>
        </div>
        <div class="stat-val">12.8k</div>
        <div class="stat-label">XP total da escola</div>
    </div>
</div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Professores</h3>
        <div class="card-sub">Desempenho e turmas</div>
        <div class="row-list">
            <div class="prow">
                <div class="pavatar">HR</div>
                <div class="pmeta"><div class="pn">Helena Reis</div><div class="ps">Piano · 24 alunos</div><div class="pbar"><i style="width:91%"></i></div></div>
                <div class="ppct">91%</div>
            </div>
            <div class="prow">
                <div class="pavatar">MT</div>
                <div class="pmeta"><div class="pn">Marcos Teixeira</div><div class="ps">Violão · 19 alunos</div><div class="pbar"><i style="width:84%"></i></div></div>
                <div class="ppct">84%</div>
            </div>
            <div class="prow">
                <div class="pavatar">CD</div>
                <div class="pmeta"><div class="pn">Carla Dias</div><div class="ps">Canto · 16 alunos</div><div class="pbar"><i style="width:77%"></i></div></div>
                <div class="ppct">77%</div>
            </div>
            <div class="prow">
                <div class="pavatar">RP</div>
                <div class="pmeta"><div class="pn">Rafael Pinto</div><div class="ps">Bateria · 14 alunos</div><div class="pbar"><i style="width:69%"></i></div></div>
                <div class="ppct">69%</div>
            </div>
        </div>
    </div>

    <div class="card glow">
        <h3>Plano da escola</h3>
        <div class="card-sub">Studio Pro</div>
        <div class="plan-row"><span class="plan-price">R$ 249<small>/mês</small></span></div>
        <ul class="plan-feats">
            <li><span class="ck">✓</span> Até 150 alunos</li>
            <li><span class="ck">✓</span> Professores ilimitados</li>
            <li><span class="ck">✓</span> Gamificação e XP</li>
            <li><span class="ck">✓</span> Relatórios de evolução</li>
        </ul>
    </div>
</div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Engajamento</h3>
        <div class="card-sub">Alunos praticando · últimas 8 semanas</div>
        <div class="wchart">
            <div class="wcol"><i style="height:40%"></i><span>S1</span></div>
            <div class="wcol"><i style="height:52%"></i><span>S2</span></div>
            <div class="wcol"><i style="height:48%"></i><span>S3</span></div>
            <div class="wcol"><i style="height:64%"></i><span>S4</span></div>
            <div class="wcol"><i style="height:72%"></i><span>S5</span></div>
            <div class="wcol"><i style="height:81%"></i><span>S6</span></div>
            <div class="wcol"><i style="height:88%"></i><span>S7</span></div>
            <div class="wcol"><i style="height:96%"></i><span>S8</span></div>
        </div>
    </div>

    <div class="card">
        <h3>Atividade recente</h3>
        <div class="card-sub">Hoje</div>
        <div class="sched">
            <div class="sitem"><span class="stime">🏅</span><div class="sinfo"><b>Sofia subiu para o Nível 12</b><span>há 20 min</span></div></div>
            <div class="sitem"><span class="stime">🎼</span><div class="sinfo"><b>Lucas concluiu "The Scientist"</b><span>há 1 h</span></div></div>
            <div class="sitem"><span class="stime">👤</span><div class="sinfo"><b>Novo aluno: Beatriz Rocha</b><span>há 3 h</span></div></div>
        </div>
    </div>
</div>
