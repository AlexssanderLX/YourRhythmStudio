@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meu repertório";
    ViewData["Role"] = "student";
    var first = (User.Identity?.Name ?? "Aluno").Split(' ')[0];
    ViewData["DashTitle"] = "Meu repertório";

    var songs = new[] {
        new { Icon="🎹", Title="Clair de Lune",        Author="C. Debussy",   Inst="Piano",  Pct=80, Status="ativo",     Difficulty="Intermediário", AddedOn="Mar 2024" },
        new { Icon="🎶", Title="River Flows In You",   Author="Yiruma",       Inst="Piano",  Pct=45, Status="ativo",     Difficulty="Iniciante",     AddedOn="Abr 2024" },
        new { Icon="🎼", Title="The Scientist",         Author="Coldplay",     Inst="Violão", Pct=60, Status="ativo",     Difficulty="Intermediário", AddedOn="Mai 2024" },
        new { Icon="🎵", Title="Für Elise",             Author="Beethoven",    Inst="Piano",  Pct=100,Status="concluído", Difficulty="Iniciante",     AddedOn="Fev 2024" },
        new { Icon="🎸", Title="Wonderwall",            Author="Oasis",        Inst="Violão", Pct=100,Status="concluído", Difficulty="Iniciante",     AddedOn="Jan 2024" },
        new { Icon="🎹", Title="Canon in D",            Author="Pachelbel",    Inst="Piano",  Pct=20, Status="pausado",   Difficulty="Avançado",      AddedOn="Jun 2024" },
    };
}

<div class="cols-4-scroll"><div class="dash-grid cols-4">
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic">🎵</div></div>
        <div class="stat-val">@songs.Length</div>
        <div class="stat-label">Total de músicas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic" style="font-size:16px">▶</div><span class="stat-trend">ativos</span></div>
        <div class="stat-val">@songs.Count(s => s.Status == "ativo")</div>
        <div class="stat-label">Em andamento</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span class="stat-trend" style="color:#5fd0a0">✓</span></div>
        <div class="stat-val">@songs.Count(s => s.Status == "concluído")</div>
        <div class="stat-label">Concluídas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></div></div>
        <div class="stat-val">@(songs.Where(s => s.Status == "ativo").Average(s => s.Pct).ToString("F0"))%</div>
        <div class="stat-label">Progresso médio</div>
    </div>
</div></div>

<div class="card">
    <div class="rep-header">
        <div>
            <h3>Minhas músicas</h3>
            <div class="card-sub">Repertório completo</div>
        </div>
        <div class="rep-filters">
            <button class="rep-filter active" data-filter="todos">Todos</button>
            <button class="rep-filter" data-filter="ativo">Em andamento</button>
            <button class="rep-filter" data-filter="concluído">Concluídas</button>
            <button class="rep-filter" data-filter="pausado">Pausadas</button>
        </div>
    </div>

    <div class="rep-list" id="repList">
        @foreach (var s in songs)
        {
            <div class="rep-row" data-status="@s.Status">
                <div class="rep-icon">@s.Icon</div>
                <div class="rep-info">
                    <span class="rep-title">@s.Title</span>
                    <span class="rep-author">@s.Author · @s.Inst</span>
                </div>
                <div class="rep-diff">
                    <span class="pill">@s.Difficulty</span>
                </div>
                <div class="rep-prog">
                    @if (s.Status == "concluído")
                    {
                        <span class="rep-done">✓ Concluída</span>
                    }
                    else if (s.Status == "pausado")
                    {
                        <span class="rep-paused">— Pausada</span>
                    }
                    else
                    {
                        <div class="pbar" style="width:140px"><i style="width:@(s.Pct)%"></i></div>
                        <span class="rep-pct">@(s.Pct)%</span>
                    }
                </div>
                <span class="rep-date">@s.AddedOn</span>
            </div>
        }
    </div>
</div>

<style>
.rep-header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; margin-bottom: 12px;
}
.rep-filters { display: flex; gap: 6px; flex-wrap: wrap; }
.rep-filter {
    padding: 6px 14px; border-radius: 100px; font-size: 12.5px; font-weight: 500;
    background: var(--surface); border: 1px solid var(--border-soft);
    color: var(--muted); cursor: pointer; transition: all .15s;
}
.rep-filter.active,
.rep-filter:hover { color: var(--ink); border-color: var(--blue-bright); background: rgba(46,155,255,0.1); }

.rep-list { display: flex; flex-direction: column; }
.rep-row {
    display: grid;
    grid-template-columns: 42px 1fr 130px 180px 70px;
    align-items: center; gap: 16px;
    padding: 14px 10px; border-radius: 12px; transition: background .15s;
}
.rep-row + .rep-row { border-top: 1px solid var(--border-soft); }
.rep-row:hover { background: var(--surface); }

.rep-icon { font-size: 22px; text-align: center; }
.rep-info { min-width: 0; }
.rep-title  { display: block; font-size: 14px; font-weight: 600; }
.rep-author { display: block; font-size: 12.5px; color: var(--muted); margin-top: 2px; }
.rep-diff   { display: flex; }
.rep-prog   { display: flex; flex-direction: column; gap: 4px; }
.rep-pct    { font-size: 11.5px; color: var(--muted); }
.rep-done   { font-size: 12.5px; font-weight: 600; color: #5fd0a0; }
.rep-paused { font-size: 12.5px; color: var(--muted); }
.rep-date   { font-size: 12px; color: var(--muted); text-align: right; }

@@media (max-width: 680px) {
    .rep-row { grid-template-columns: 36px 1fr auto; }
    .rep-diff, .rep-date { display: none; }
    .rep-prog { align-items: flex-end; }
}
</style>

<script>
document.querySelectorAll('.rep-filter').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.querySelectorAll('.rep-filter').forEach(function (b) { b.classList.remove('active'); });
        this.classList.add('active');
        var f = this.dataset.filter;
        document.querySelectorAll('.rep-row').forEach(function (row) {
            row.style.display = (f === 'todos' || row.dataset.status === f) ? '' : 'none';
        });
    });
});
</script>
