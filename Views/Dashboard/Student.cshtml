@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meu painel";
    ViewData["Role"] = "student";
    var first = (User.Identity?.Name ?? "Aluno").Split(' ')[0];
    ViewData["DashTitle"] = $"Olá, {first} 👋";
}

<div class="dash-grid cols-3">
    <div class="card glow span-2">
        <div class="level-hero">
            <div class="level-ring">
                <svg width="120" height="120">
                    <circle cx="60" cy="60" r="50" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="9"/>
                    <circle cx="60" cy="60" r="50" fill="none" stroke="url(#dg)" stroke-width="9" stroke-linecap="round"
                            stroke-dasharray="314" stroke-dashoffset="69" transform="rotate(-90 60 60)"/>
                    <defs><linearGradient id="dg" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#6BC0FF"/><stop offset="1" stop-color="#1E5BFF"/></linearGradient></defs>
                </svg>
                <div class="pct"><b>78%</b><span>do nível</span></div>
            </div>
            <div class="level-info">
                <div class="lvl-num"><small>Nível atual</small>12</div>
                <div class="xp-track"><i style="width:82%"></i></div>
                <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--muted)">
                    <span>2.450 XP</span><span>Faltam 50 XP para Intermediário</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Sequência</h3>
        <div class="card-sub">Não quebre a corrente!</div>
        <div class="streak-row"><span style="display:inline-flex;align-items:center"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10"/></svg></span> 7 dias</div>
        <div class="eq" style="margin-top:16px"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
    </div>
</div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Repertório em andamento</h3>
        <div class="card-sub">Continue de onde parou</div>
        <div class="row-list">
            <div class="prow">
                <div class="pavatar" style="display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
                <div class="pmeta"><div class="pn">Clair de Lune</div><div class="ps">C. Debussy</div><div class="pbar"><i style="width:80%"></i></div></div>
                <div class="ppct">80%</div>
            </div>
            <div class="prow">
                <div class="pavatar" style="display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
                <div class="pmeta"><div class="pn">River Flows In You</div><div class="ps">Yiruma</div><div class="pbar"><i style="width:45%"></i></div></div>
                <div class="ppct">45%</div>
            </div>
            <div class="prow">
                <div class="pavatar" style="display:flex;align-items:center;justify-content:center"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
                <div class="pmeta"><div class="pn">The Scientist</div><div class="ps">Coldplay</div><div class="pbar"><i style="width:60%"></i></div></div>
                <div class="ppct">60%</div>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Próxima missão</h3>
        <div class="card-sub">Hoje</div>
        <div class="mission" style="flex-direction:column;align-items:stretch;gap:12px">
            <div>
                <div class="m-label">Praticar escalas maiores</div>
                <div class="m-title">18 / 30 min</div>
                <div class="pbar" style="margin-top:10px"><i style="width:60%"></i></div>
            </div>
            <div class="m-xp">+90 XP</div>
        </div>
    </div>
</div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Sua evolução</h3>
        <div class="card-sub">Minutos de prática · últimas 8 semanas</div>
        <div class="wchart">
            <div class="wcol"><i style="height:22%"></i><span>S1</span></div>
            <div class="wcol"><i style="height:34%"></i><span>S2</span></div>
            <div class="wcol"><i style="height:30%"></i><span>S3</span></div>
            <div class="wcol"><i style="height:48%"></i><span>S4</span></div>
            <div class="wcol"><i style="height:58%"></i><span>S5</span></div>
            <div class="wcol"><i style="height:70%"></i><span>S6</span></div>
            <div class="wcol"><i style="height:84%"></i><span>S7</span></div>
            <div class="wcol"><i style="height:100%"></i><span>S8</span></div>
        </div>
    </div>

    <div class="card">
        <h3>Conquistas</h3>
        <div class="card-sub">5 de 8 desbloqueadas</div>
        <div class="achv-grid2">
            <div class="achv2"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
            <div class="achv2"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg></div>
            <div class="achv2"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 6H4v2a3 3 0 0 0 3 3"/><path d="M17 6h3v2a3 3 0 0 1-3 3"/><path d="M9 17h6"/><path d="M12 13v4"/></svg></div>
            <div class="achv2"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg></div>
            <div class="achv2"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20,6 9,17 4,12"/></svg></div>
            <div class="achv2 locked" style="opacity:.35"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></div>
            <div class="achv2 locked" style="opacity:.35"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></div>
            <div class="achv2 locked" style="opacity:.35"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></div>
        </div>
    </div>
</div>
