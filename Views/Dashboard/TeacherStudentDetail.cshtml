@{
    Layout = "_DashboardLayout";
    ViewData["Role"] = "teacher";

    var id = (int)(ViewData["StudentId"] ?? 1);

    // Dados mockados por ID — futuramente virá do banco
    var allStudents = new[] {
        new { Id=1, Init="SA", Name="Sofia Almeida",  Inst="Piano",   Song="Clair de Lune",     Pct=80, Lvl=12, Streak=14, Xp=3420, XpNext=4000, Last="Hoje 14:00",   Status="online",  Since="Mar 2024", LessonsTotal=38 },
        new { Id=2, Init="GN", Name="Gabriel Nunes",  Inst="Teclado", Song="Canon in D",         Pct=67, Lvl=9,  Streak=7,  Xp=1980, XpNext=2500, Last="Ontem 18:00",  Status="offline", Since="Jun 2024", LessonsTotal=24 },
        new { Id=3, Init="LM", Name="Lucas Martins",  Inst="Violão",  Song="The Scientist",      Pct=55, Lvl=7,  Streak=5,  Xp=1340, XpNext=1800, Last="Hoje 15:00",   Status="online",  Since="Ago 2024", LessonsTotal=18 },
        new { Id=4, Init="CR", Name="Clara Ribeiro",  Inst="Piano",   Song="Für Elise",          Pct=45, Lvl=5,  Streak=3,  Xp=820,  XpNext=1200, Last="Seg 10:00",    Status="offline", Since="Out 2024", LessonsTotal=14 },
        new { Id=5, Init="BR", Name="Beatriz Rocha",  Inst="Piano",   Song="River Flows In You", Pct=38, Lvl=4,  Streak=2,  Xp=580,  XpNext=900,  Last="Hoje 16:30",   Status="online",  Since="Nov 2024", LessonsTotal=11 },
        new { Id=6, Init="PT", Name="Pedro Torres",   Inst="Violão",  Song="Wonderwall",         Pct=30, Lvl=3,  Streak=0,  Xp=310,  XpNext=600,  Last="Sex 11:00",    Status="offline", Since="Dez 2024", LessonsTotal=8  },
    };

    var s = allStudents.FirstOrDefault(x => x.Id == id) ?? allStudents[0];
    ViewData["Title"] = s.Name;
    ViewData["DashTitle"] = s.Name;

    var missions = new[] {
        new { Title="Praticar 20min por dia",              Xp="+10 XP", Status="concluida",    Deadline="Ontem"   },
        new { Title="Memorizar compassos 1–16",            Xp="+30 XP", Status="em-andamento", Deadline="Hoje"    },
        new { Title="Assistir vídeo de técnica",           Xp="+15 XP", Status="em-andamento", Deadline="Amanhã"  },
        new { Title="Leitura à primeira vista – Etude 3",  Xp="+20 XP", Status="pendente",     Deadline="Sex"     },
    };

    var recentLessons = new[] {
        new { Date="06/07", Topic="Escalas maiores · mão direita",   Duration="45min" },
        new { Date="01/07", Topic="Clair de Lune · compasso 1–8",    Duration="50min" },
        new { Date="24/06", Topic="Postura e dedilhado",             Duration="45min" },
        new { Date="17/06", Topic="Leitura de partitura básica",     Duration="40min" },
    };

    int xpPct = (int)((double)s.Xp / s.XpNext * 100);
}

<div class="sd-back">
    <a href="@Url.Action("Students","Dashboard")" class="dash-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Voltar aos alunos
    </a>
</div>


<div class="sd-hero card">
    <div class="sd-hero-left">
        <div class="sd-big-avatar">@s.Init</div>
        <div class="sd-hero-info">
            <div class="sd-hero-name">
                @s.Name
                @if (s.Status == "online")
                {
                    <span class="sd-online-badge">Praticando agora</span>
                }
            </div>
            <div class="sd-hero-meta">
                <span>@s.Inst</span>
                <span class="sd-sep">·</span>
                <span>Aluno desde @s.Since</span>
                <span class="sd-sep">·</span>
                <span>@s.LessonsTotal aulas realizadas</span>
            </div>
            <div class="sd-xp-wrap">
                <div class="sd-xp-labels">
                    <span class="sd-xp-num">@s.Xp XP</span>
                    <span class="sd-xp-next">/ @s.XpNext XP para Nível @(s.Lvl + 1)</span>
                </div>
                <div class="xp-track"><i style="width:@(xpPct)%"></i></div>
            </div>
        </div>
    </div>
    <div class="sd-hero-right">
        <div class="sd-stat-mini">
            <span class="sd-stat-val">@s.Lvl</span>
            <span class="sd-stat-lbl">Nível</span>
        </div>
        <div class="sd-stat-mini">
            <span class="sd-stat-val">@(s.Streak > 0 ? $"🔥{s.Streak}" : "—")</span>
            <span class="sd-stat-lbl">Dias seguidos</span>
        </div>
        <div class="sd-stat-mini">
            <span class="sd-stat-val">@(s.Pct)%</span>
            <span class="sd-stat-lbl">Progresso semana</span>
        </div>
    </div>
</div>

<div class="dash-grid cols-2">
    
    <div class="card">
        <h3>Repertório atual</h3>
        <div class="card-sub">Música em andamento</div>
        <div class="sd-song-block">
            <div class="sd-song-ic">🎵</div>
            <div class="sd-song-info">
                <span class="sd-song-title">@s.Song</span>
                <span class="sd-song-inst">@s.Inst</span>
            </div>
            <div style="flex:1;min-width:0;">
                <div class="pbar"><i style="width:@(s.Pct)%"></i></div>
                <span style="font-size:11.5px;color:var(--muted);margin-top:4px;display:block">@(s.Pct)% concluído</span>
            </div>
        </div>
    </div>

    
    <div class="card">
        <h3>Prática esta semana</h3>
        <div class="card-sub">Minutos por dia</div>
        <div class="wchart">
            @foreach (var (d, h) in new[] { ("S",60),("T",80),("Q",20),("Q",90),("S",45),("S",0),("D",30) })
            {
                <div class="wcol">
                    <i style="height:@(h)px"></i>
                    <span>@d</span>
                </div>
            }
        </div>
    </div>

    
    <div class="card">
        <h3>Missões</h3>
        <div class="card-sub">Atribuídas pelo professor</div>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:4px;">
            @foreach (var m in missions)
            {
                var statusLabel = m.Status switch {
                    "concluida"    => "Concluída",
                    "em-andamento" => "Em andamento",
                    _              => "Pendente"
                };
                <div class="mission">
                    <div>
                        <div class="m-label">@m.Deadline</div>
                        <div class="m-title">@m.Title</div>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">
                        <span class="m-xp">@m.Xp</span>
                        <span class="mission-status @m.Status">@statusLabel</span>
                    </div>
                </div>
            }
        </div>
    </div>

    
    <div class="card">
        <h3>Aulas recentes</h3>
        <div class="card-sub">Histórico de encontros</div>
        <div class="sched" style="margin-top:4px;">
            @foreach (var l in recentLessons)
            {
                <div class="sitem">
                    <span class="stime" style="width:44px;font-size:12px;">@l.Date</span>
                    <div class="sinfo" style="flex:1;">
                        <b>@l.Topic</b>
                        <span>@l.Duration</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
.sd-back { margin-bottom: 6px; }

.sd-hero {
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 20px;
}
.sd-hero-left { display: flex; align-items: center; gap: 20px; flex: 1; min-width: 0; }
.sd-big-avatar {
    width: 64px; height: 64px; border-radius: 18px; flex-shrink: 0;
    display: grid; place-items: center;
    font-family: var(--font-display); font-weight: 700; font-size: 22px; color: #fff;
    background: linear-gradient(135deg, var(--blue-bright), var(--blue-deep));
}
.sd-hero-info { flex: 1; min-width: 0; }
.sd-hero-name {
    display: flex; align-items: center; flex-wrap: wrap; gap: 10px;
    font-family: var(--font-display); font-weight: 700; font-size: 22px; margin-bottom: 6px;
}
.sd-online-badge {
    font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 100px;
    background: rgba(95,208,160,0.15); color: #5fd0a0; border: 1px solid rgba(95,208,160,0.25);
}
.sd-hero-meta { font-size: 13px; color: var(--muted); margin-bottom: 12px; }
.sd-sep { margin: 0 4px; opacity: 0.4; }
.sd-xp-wrap { max-width: 380px; }
.sd-xp-labels { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
.sd-xp-num { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--blue-bright); }
.sd-xp-next { font-size: 12px; color: var(--muted); }

.sd-hero-right {
    display: flex; gap: 20px; flex-shrink: 0;
    padding: 14px 20px; border-radius: 14px;
    background: var(--surface); border: 1px solid var(--border-soft);
}
.sd-stat-mini { text-align: center; }
.sd-stat-val { display: block; font-family: var(--font-display); font-weight: 700; font-size: 22px; }
.sd-stat-lbl { display: block; font-size: 11.5px; color: var(--muted); margin-top: 3px; }

.sd-song-block { display: flex; align-items: center; gap: 14px; padding: 14px; border-radius: 12px; background: var(--surface); border: 1px solid var(--border-soft); margin-top: 4px; }
.sd-song-ic { font-size: 26px; flex-shrink: 0; }
.sd-song-info { flex-shrink: 0; }
.sd-song-title { display: block; font-size: 14px; font-weight: 600; }
.sd-song-inst  { display: block; font-size: 12px; color: var(--muted); margin-top: 2px; }

.mission-status { font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 100px; }
.mission-status.concluida    { background: rgba(95,208,160,0.15); color: #5fd0a0; }
.mission-status.em-andamento { background: rgba(46,155,255,0.12); color: var(--blue-bright); }
.mission-status.pendente     { background: rgba(255,255,255,0.06); color: var(--muted); }

@@media (max-width: 680px) {
    .sd-hero { flex-direction: column; align-items: flex-start; }
    .sd-hero-right { width: 100%; justify-content: space-around; }
    .sd-xp-wrap { max-width: 100%; }
}
</style>
