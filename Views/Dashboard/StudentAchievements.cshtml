@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Conquistas";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Conquistas";

    const string _icoNote   = "<svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9 18V5l12-2v13'/><circle cx='6' cy='18' r='3'/><circle cx='18' cy='16' r='3'/></svg>";
    const string _icoStar   = "<svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26'/></svg>";
    const string _icoTrophy = "<svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M7 4h10v4a5 5 0 0 1-10 0z'/><path d='M7 6H4v2a3 3 0 0 0 3 3'/><path d='M17 6h3v2a3 3 0 0 1-3 3'/><path d='M9 17h6'/><path d='M12 13v4'/></svg>";
    const string _icoZap    = "<svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='13,2 3,14 12,14 11,22 21,10 12,10'/></svg>";
    const string _icoCheck  = "<svg width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='20,6 9,17 4,12'/></svg>";

    var achievements = new[] {
        new { Icon=_icoNote,   Name="Primeira nota",        Desc="Complete sua primeira missão",               Xp=50,  Unlocked=true,  Date="Jan 2024", Category="Início"    },
        new { Icon=_icoNote,   Name="Leitor de partitura",  Desc="Leia uma música completa à primeira vista",  Xp=80,  Unlocked=true,  Date="Fev 2024", Category="Leitura"   },
        new { Icon=_icoZap,    Name="Semana de fogo",        Desc="7 dias seguidos de prática",                 Xp=120, Unlocked=true,  Date="Mar 2024", Category="Streak"    },
        new { Icon=_icoStar,   Name="Nível 10",              Desc="Alcance o nível 10",                         Xp=200, Unlocked=true,  Date="Abr 2024", Category="Nível"     },
        new { Icon=_icoCheck,  Name="Repertório rico",       Desc="Adicione 5 músicas ao repertório",           Xp=100, Unlocked=true,  Date="Mai 2024", Category="Repertório"},
        new { Icon=_icoNote,   Name="Músico dedicado",       Desc="100h totais de prática registradas",         Xp=300, Unlocked=false, Date="",         Category="Prática"   },
        new { Icon=_icoTrophy, Name="Mestre das escalas",    Desc="Conclua todas as missões de escalas",        Xp=250, Unlocked=false, Date="",         Category="Técnica"   },
        new { Icon=_icoStar,   Name="Lenda do estúdio",      Desc="Alcance o nível 20",                         Xp=500, Unlocked=false, Date="",         Category="Nível"     },
    };

    int unlockedCount = achievements.Count(a => a.Unlocked);
    int totalXpEarned = achievements.Where(a => a.Unlocked).Sum(a => a.Xp);
}

<div class="cols-4-scroll"><div class="dash-grid cols-4">
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 6H4v2a3 3 0 0 0 3 3"/><path d="M17 6h3v2a3 3 0 0 1-3 3"/><path d="M9 17h6"/><path d="M12 13v4"/></svg></div><span class="stat-trend" style="color:#5fd0a0">@unlockedCount/@achievements.Length</span></div>
        <div class="stat-val">@unlockedCount</div>
        <div class="stat-label">Desbloqueadas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div></div>
        <div class="stat-val">@totalXpEarned</div>
        <div class="stat-label">XP de conquistas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg></div></div>
        <div class="stat-val">@(achievements.Length - unlockedCount)</div>
        <div class="stat-label">A desbloquear</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg></div></div>
        <div class="stat-val">@(unlockedCount * 100 / achievements.Length)%</div>
        <div class="stat-label">Completado</div>
    </div>
</div></div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Todas as conquistas</h3>
        <div class="card-sub">@unlockedCount de @achievements.Length desbloqueadas</div>

        <div class="ach-progress-bar" style="margin:12px 0 20px;">
            <div class="pbar" style="height:8px;"><i style="width:@(unlockedCount * 100 / achievements.Length)%"></i></div>
        </div>

        <div class="ach-grid">
            @foreach (var a in achievements)
            {
                <div class="ach-card @(a.Unlocked ? "unlocked" : "locked")">
                    <div class="ach-icon">@Html.Raw(a.Icon)</div>
                    <div class="ach-info">
                        <span class="ach-name">@a.Name</span>
                        <span class="ach-desc">@a.Desc</span>
                        @if (a.Unlocked)
                        {
                            <span class="ach-date">@a.Date · +@(a.Xp) XP</span>
                        }
                        else
                        {
                            <span class="ach-xp-locked">+@(a.Xp) XP ao desbloquear</span>
                        }
                    </div>
                    <div class="ach-badge">
                        @if (a.Unlocked)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5fd0a0" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                        else
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--muted)"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:18px;">
        <div class="card">
            <h3>Próximas conquistas</h3>
            <div class="card-sub">Mais perto de desbloquear</div>
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px;">
                @foreach (var a in achievements.Where(x => !x.Unlocked).Take(3))
                {
                    <div class="next-ach">
                        <span class="next-ach-icon">@a.Icon</span>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13.5px;font-weight:600">@a.Name</div>
                            <div style="font-size:12px;color:var(--muted);margin-top:2px;">@a.Desc</div>
                        </div>
                        <span class="ms-xp">+@(a.Xp)</span>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <h3>Por categoria</h3>
            <div class="card-sub">Distribuição</div>
            @{
                var cats = achievements.GroupBy(a => a.Category).Select(g => (
                    Cat: g.Key,
                    Total: g.Count(),
                    Done: g.Count(a => a.Unlocked)
                )).ToArray();
            }
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:10px;">
                @foreach (var c in cats)
                {
                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                            <span>@c.Cat</span>
                            <span style="color:var(--muted)">@c.Done/@c.Total</span>
                        </div>
                        <div class="pbar"><i style="width:@(c.Done * 100 / c.Total)%"></i></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
.ach-grid { display: flex; flex-direction: column; gap: 6px; }

.ach-card {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 12px; border-radius: 14px;
    border: 1px solid var(--border-soft); transition: border-color .15s;
}
.ach-card.unlocked { background: var(--surface); }
.ach-card.locked   { opacity: 0.45; background: transparent; }
.ach-card:hover    { border-color: var(--border); }

.ach-icon { font-size: 24px; width: 44px; height: 44px; border-radius: 13px; display: grid; place-items: center; flex-shrink: 0; background: rgba(255,255,255,0.04); border: 1px solid var(--border-soft); }
.ach-card.unlocked .ach-icon { background: rgba(46,155,255,0.1); border-color: rgba(46,155,255,0.2); }

.ach-info { flex: 1; min-width: 0; }
.ach-name { display: block; font-size: 14px; font-weight: 600; }
.ach-desc { display: block; font-size: 12.5px; color: var(--muted); margin-top: 2px; }
.ach-date { display: block; font-size: 11.5px; color: #5fd0a0; margin-top: 4px; }
.ach-xp-locked { display: block; font-size: 11.5px; color: var(--muted); margin-top: 4px; }

.ach-badge { flex-shrink: 0; }

.next-ach {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: 12px;
    background: var(--surface); border: 1px solid var(--border-soft);
}
.next-ach-icon { font-size: 20px; flex-shrink: 0; }

.ms-xp { font-family: var(--font-display); font-weight: 700; font-size: 13px; color: var(--blue-bright); flex-shrink: 0; }

@@media (max-width: 680px) {
    .ach-desc { display: none; }
}
</style>
