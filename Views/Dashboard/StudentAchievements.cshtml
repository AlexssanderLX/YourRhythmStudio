@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Conquistas";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Conquistas";

    var achievements = new[] {
        new { Icon="🎵", Name="Primeira nota",        Desc="Complete sua primeira missão",               Xp=50,  Unlocked=true,  Date="Jan 2024", Category="Início"    },
        new { Icon="🎼", Name="Leitor de partitura",  Desc="Leia uma música completa à primeira vista",  Xp=80,  Unlocked=true,  Date="Fev 2024", Category="Leitura"   },
        new { Icon="🔥", Name="Semana de fogo",        Desc="7 dias seguidos de prática",                 Xp=120, Unlocked=true,  Date="Mar 2024", Category="Streak"    },
        new { Icon="⭐", Name="Nível 10",              Desc="Alcance o nível 10",                         Xp=200, Unlocked=true,  Date="Abr 2024", Category="Nível"     },
        new { Icon="🏅", Name="Repertório rico",       Desc="Adicione 5 músicas ao repertório",           Xp=100, Unlocked=true,  Date="Mai 2024", Category="Repertório"},
        new { Icon="🎹", Name="Pianista dedicado",     Desc="100h totais de prática registradas",         Xp=300, Unlocked=false, Date="",         Category="Prática"   },
        new { Icon="🏆", Name="Mestre das escalas",    Desc="Conclua todas as missões de escalas",        Xp=250, Unlocked=false, Date="",         Category="Técnica"   },
        new { Icon="🌟", Name="Lenda do estúdio",      Desc="Alcance o nível 20",                         Xp=500, Unlocked=false, Date="",         Category="Nível"     },
    };

    int unlockedCount = achievements.Count(a => a.Unlocked);
    int totalXpEarned = achievements.Where(a => a.Unlocked).Sum(a => a.Xp);
}

<div class="cols-4-scroll"><div class="dash-grid cols-4">
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic">🏅</div><span class="stat-trend" style="color:#5fd0a0">@unlockedCount/@achievements.Length</span></div>
        <div class="stat-val">@unlockedCount</div>
        <div class="stat-label">Desbloqueadas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div></div>
        <div class="stat-val">@totalXpEarned</div>
        <div class="stat-label">XP de conquistas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic">🔒</div></div>
        <div class="stat-val">@(achievements.Length - unlockedCount)</div>
        <div class="stat-label">A desbloquear</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic">📊</div></div>
        <div class="stat-val">@(unlockedCount * 100 / achievements.Length)%</div>
        <div class="stat-label">Completado</div>
    </div>
</div></div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Todas as conquistas</h3>
        <div class="card-sub">@unlockedCount de @achievements.Length desbloqueadas</div>

        <div class="ach-progress-bar" style="margin:12px 0 20px;">
            <div class="pbar" style="height:8px;"><i style="width:@(unlockedCount * 100 / achievements.Length)%"></i></div>
        </div>

        <div class="ach-grid">
            @foreach (var a in achievements)
            {
                <div class="ach-card @(a.Unlocked ? "unlocked" : "locked")">
                    <div class="ach-icon">@a.Icon</div>
                    <div class="ach-info">
                        <span class="ach-name">@a.Name</span>
                        <span class="ach-desc">@a.Desc</span>
                        @if (a.Unlocked)
                        {
                            <span class="ach-date">@a.Date · +@(a.Xp) XP</span>
                        }
                        else
                        {
                            <span class="ach-xp-locked">+@(a.Xp) XP ao desbloquear</span>
                        }
                    </div>
                    <div class="ach-badge">
                        @if (a.Unlocked)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5fd0a0" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                        else
                        {
                            <span style="font-size:14px;color:var(--muted)">🔒</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:18px;">
        <div class="card">
            <h3>Próximas conquistas</h3>
            <div class="card-sub">Mais perto de desbloquear</div>
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px;">
                @foreach (var a in achievements.Where(x => !x.Unlocked).Take(3))
                {
                    <div class="next-ach">
                        <span class="next-ach-icon">@a.Icon</span>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13.5px;font-weight:600">@a.Name</div>
                            <div style="font-size:12px;color:var(--muted);margin-top:2px;">@a.Desc</div>
                        </div>
                        <span class="ms-xp">+@(a.Xp)</span>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <h3>Por categoria</h3>
            <div class="card-sub">Distribuição</div>
            @{
                var cats = achievements.GroupBy(a => a.Category).Select(g => (
                    Cat: g.Key,
                    Total: g.Count(),
                    Done: g.Count(a => a.Unlocked)
                )).ToArray();
            }
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:10px;">
                @foreach (var c in cats)
                {
                    <div>
                        <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                            <span>@c.Cat</span>
                            <span style="color:var(--muted)">@c.Done/@c.Total</span>
                        </div>
                        <div class="pbar"><i style="width:@(c.Done * 100 / c.Total)%"></i></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
.ach-grid { display: flex; flex-direction: column; gap: 6px; }

.ach-card {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 12px; border-radius: 14px;
    border: 1px solid var(--border-soft); transition: border-color .15s;
}
.ach-card.unlocked { background: var(--surface); }
.ach-card.locked   { opacity: 0.45; background: transparent; }
.ach-card:hover    { border-color: var(--border); }

.ach-icon { font-size: 24px; width: 44px; height: 44px; border-radius: 13px; display: grid; place-items: center; flex-shrink: 0; background: rgba(255,255,255,0.04); border: 1px solid var(--border-soft); }
.ach-card.unlocked .ach-icon { background: rgba(46,155,255,0.1); border-color: rgba(46,155,255,0.2); }

.ach-info { flex: 1; min-width: 0; }
.ach-name { display: block; font-size: 14px; font-weight: 600; }
.ach-desc { display: block; font-size: 12.5px; color: var(--muted); margin-top: 2px; }
.ach-date { display: block; font-size: 11.5px; color: #5fd0a0; margin-top: 4px; }
.ach-xp-locked { display: block; font-size: 11.5px; color: var(--muted); margin-top: 4px; }

.ach-badge { flex-shrink: 0; }

.next-ach {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: 12px;
    background: var(--surface); border: 1px solid var(--border-soft);
}
.next-ach-icon { font-size: 20px; flex-shrink: 0; }

.ms-xp { font-family: var(--font-display); font-weight: 700; font-size: 13px; color: var(--blue-bright); flex-shrink: 0; }

@@media (max-width: 680px) {
    .ach-desc { display: none; }
}
</style>
