@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meus alunos";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Meus alunos";

    var students = new[] {
        new { Id=1, Init="SA", Name="Sofia Almeida",  Inst="Piano",   Song="Clair de Lune",     Pct=80, Lvl=12, Streak=14, Last="Hoje 14:00",   Status="online"   },
        new { Id=2, Init="GN", Name="Gabriel Nunes",  Inst="Teclado", Song="Canon in D",         Pct=67, Lvl=9,  Streak=7,  Last="Ontem 18:00",  Status="offline"  },
        new { Id=3, Init="LM", Name="Lucas Martins",  Inst="Violão",  Song="The Scientist",      Pct=55, Lvl=7,  Streak=5,  Last="Hoje 15:00",   Status="online"   },
        new { Id=4, Init="CR", Name="Clara Ribeiro",  Inst="Piano",   Song="Für Elise",          Pct=45, Lvl=5,  Streak=3,  Last="Seg 10:00",    Status="offline"  },
        new { Id=5, Init="BR", Name="Beatriz Rocha",  Inst="Piano",   Song="River Flows In You", Pct=38, Lvl=4,  Streak=2,  Last="Hoje 16:30",   Status="online"   },
        new { Id=6, Init="PT", Name="Pedro Torres",   Inst="Violão",  Song="Wonderwall",         Pct=30, Lvl=3,  Streak=0,  Last="Sex 11:00",    Status="offline"  },
    };
}

<div class="stat-strip">
    <div class="stat-chip"><span class="sc-val">@students.Length</span><span class="sc-lbl">Alunos ativos</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">@students.Count(s => s.Status == "online")</span><span class="sc-lbl">Praticando hoje</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">@(students.Average(s => s.Lvl).ToString("F1"))</span><span class="sc-lbl">Nível médio</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">91<small>%</small></span><span class="sc-lbl">Engajamento semana</span></div>
</div>

<div class="card">
    <div class="sl-header">
        <div>
            <h3>Meus alunos</h3>
            <div class="card-sub">@students.Length alunos · clique para ver detalhes</div>
        </div>
        <div class="sl-search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
            <input type="text" id="sSearch" placeholder="Buscar…" />
        </div>
    </div>

    <div class="sl-list" id="slList">
        @foreach (var s in students)
        {
            <a href="@Url.Action("StudentDetail","Dashboard",new{id=s.Id})" class="sl-row" data-q="@((s.Name + " " + s.Inst + " " + s.Song).ToLower())">
                <div class="sl-avatar-wrap">
                    <div class="pavatar">@s.Init</div>
                    @if (s.Status == "online")
                    {
                        <span class="sl-dot"></span>
                    }
                </div>
                <div class="sl-info">
                    <span class="sl-name">@s.Name</span>
                    <span class="sl-sub">@s.Inst · @s.Song</span>
                </div>
                <div class="sl-progress">
                    <div class="pbar"><i style="width:@(s.Pct)%"></i></div>
                    <span class="sl-pct">@(s.Pct)%</span>
                </div>
                <div class="sl-right">
                    <span class="pill lvl">Nível @s.Lvl</span>
                    @if (s.Streak > 0)
                    {
                        <span class="sl-streak">🔥 @s.Streak</span>
                    }
                </div>
                <svg class="sl-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        }
    </div>
</div>

<style>
.sl-header {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; margin-bottom: 8px;
}
.sl-search {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 16px; border-radius: 100px;
    background: var(--surface); border: 1px solid var(--border-soft); color: var(--muted);
}
.sl-search input {
    background: none; border: none; outline: none;
    color: var(--ink); font-size: 13.5px; width: 140px;
}
.sl-search input::placeholder { color: var(--muted); }

.sl-list { display: flex; flex-direction: column; }

.sl-row {
    display: grid;
    grid-template-columns: 44px 1fr 180px auto 20px;
    align-items: center; gap: 16px;
    padding: 14px 10px; border-radius: 12px;
    text-decoration: none; color: inherit;
    transition: background .15s;
    cursor: pointer;
}
.sl-row + .sl-row { border-top: 1px solid var(--border-soft); }
.sl-row:hover { background: var(--surface); }
.sl-row:hover .sl-arrow { color: var(--ink); }

.sl-avatar-wrap { position: relative; width: 38px; }
.sl-dot {
    position: absolute; bottom: 0; right: 0;
    width: 10px; height: 10px; border-radius: 50%;
    background: #5fd0a0; border: 2px solid var(--bg);
}
.sl-info { min-width: 0; }
.sl-name { display: block; font-size: 14px; font-weight: 600; }
.sl-sub  { display: block; font-size: 12.5px; color: var(--muted); margin-top: 2px; }

.sl-progress { display: flex; flex-direction: column; gap: 4px; }
.sl-pct { font-size: 11.5px; color: var(--muted); }

.sl-right { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; }
.sl-streak { font-size: 12px; color: var(--muted); font-family: var(--font-display); }

.sl-arrow { color: var(--muted); flex-shrink: 0; transition: color .15s; }

@@media (max-width: 680px) {
    .sl-row { grid-template-columns: 44px 1fr auto 20px; }
    .sl-progress { display: none; }
    .sl-search input { width: 110px; }
}
@@media (max-width: 400px) {
    .sl-header { flex-direction: column; align-items: stretch; }
    .sl-search { width: 100%; }
    .sl-search input { flex: 1; width: 100%; }
}
</style>

<script>
document.getElementById('sSearch').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    document.querySelectorAll('#slList .sl-row').forEach(function (row) {
        row.style.display = (row.dataset.q || '').includes(q) ? '' : 'none';
    });
});
</script>
