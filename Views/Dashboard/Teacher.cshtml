@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Painel do professor";
    ViewData["Role"] = "teacher";
    var first = (User.Identity?.Name ?? "Professor").Split(' ')[0];
    ViewData["DashTitle"] = $"Bom dia, {first}";
}

<div class="stat-strip">
    <div class="stat-chip"><span class="sc-val">24</span><span class="sc-lbl">Alunos ativos</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">6</span><span class="sc-lbl">Aulas hoje</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">18</span><span class="sc-lbl">Missões concluídas</span></div>
    <div class="sc-sep"></div>
    <div class="stat-chip"><span class="sc-val">91<small>%</small></span><span class="sc-lbl">Praticaram esta semana</span></div>
</div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <h3>Meus alunos</h3>
        <div class="card-sub">Progresso da semana</div>
        <div class="row-list">
            <div class="prow">
                <div class="pavatar">SA</div>
                <div class="pmeta"><div class="pn">Sofia Almeida</div><div class="ps">Piano · Clair de Lune</div><div class="pbar"><i style="width:80%"></i></div></div>
                <span class="pill lvl">Aprendiz</span>
            </div>
            <div class="prow">
                <div class="pavatar">LM</div>
                <div class="pmeta"><div class="pn">Lucas Martins</div><div class="ps">Violão · The Scientist</div><div class="pbar"><i style="width:55%"></i></div></div>
                <span class="pill lvl">Nível 7</span>
            </div>
            <div class="prow">
                <div class="pavatar">BR</div>
                <div class="pmeta"><div class="pn">Beatriz Rocha</div><div class="ps">Piano · River Flows In You</div><div class="pbar"><i style="width:38%"></i></div></div>
                <span class="pill lvl">Nível 4</span>
            </div>
            <div class="prow">
                <div class="pavatar">GN</div>
                <div class="pmeta"><div class="pn">Gabriel Nunes</div><div class="ps">Teclado · Canon in D</div><div class="pbar"><i style="width:67%"></i></div></div>
                <span class="pill lvl">Nível 9</span>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Agenda de hoje</h3>
        <div class="card-sub">Terça-feira</div>
        <div class="sched">
            <div class="sitem"><span class="stime">14:00</span><div class="sinfo"><b>Sofia Almeida</b><span>Piano · escalas maiores</span></div></div>
            <div class="sitem"><span class="stime">15:00</span><div class="sinfo"><b>Lucas Martins</b><span>Violão · ritmo</span></div></div>
            <div class="sitem"><span class="stime">16:30</span><div class="sinfo"><b>Beatriz Rocha</b><span>Piano · leitura</span></div></div>
            <div class="sitem"><span class="stime">18:00</span><div class="sinfo"><b>Gabriel Nunes</b><span>Teclado · repertório</span></div></div>
        </div>
    </div>
</div>
