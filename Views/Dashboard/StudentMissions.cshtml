@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Missões";
    ViewData["Role"] = "student";
    ViewData["DashTitle"] = "Missões";

    const string _icoNote   = "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9 18V5l12-2v13'/><circle cx='6' cy='18' r='3'/><circle cx='18' cy='16' r='3'/></svg>";
    const string _icoTarget = "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='9'/><circle cx='12' cy='12' r='4'/></svg>";
    const string _icoCheck  = "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='20,6 9,17 4,12'/></svg>";
    const string _icoZap    = "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polygon points='13,2 3,14 12,14 11,22 21,10 12,10'/></svg>";

    var missions = new[] {
        new { Icon=_icoNote,   Title="Praticar escalas maiores",          Desc="30 min de prática contínua",       Xp=90,  Status="em-andamento", Progress=60, Deadline="Hoje",     Category="Técnica"    },
        new { Icon=_icoNote,   Title="Memorizar Clair de Lune (1–16)",    Desc="Compassos 1 a 16 sem partitura",    Xp=120, Status="em-andamento", Progress=30, Deadline="Amanhã",   Category="Repertório" },
        new { Icon=_icoTarget, Title="Treino de ouvido — intervalos",     Desc="10 exercícios de intervalo",        Xp=50,  Status="pendente",     Progress=0,  Deadline="Qui",      Category="Percepção"  },
        new { Icon=_icoNote,   Title="Leitura à primeira vista",          Desc="Etude nº 3 — leitura completa",     Xp=80,  Status="pendente",     Progress=0,  Deadline="Sex",      Category="Leitura"    },
        new { Icon=_icoZap,    Title="7 dias seguidos de prática",        Desc="Pratique todos os dias da semana",  Xp=200, Status="em-andamento", Progress=71, Deadline="Dom",      Category="Streak"     },
        new { Icon=_icoCheck,  Title="Aprender River Flows — parte A",    Desc="Mão direita completa",              Xp=100, Status="concluida",    Progress=100,Deadline="Ontem",    Category="Repertório" },
        new { Icon=_icoCheck,  Title="Praticar 20 min por dia",           Desc="Missão diária concluída",           Xp=30,  Status="concluida",    Progress=100,Deadline="Ontem",    Category="Técnica"    },
    };

    int totalXp    = missions.Where(m => m.Status == "concluida").Sum(m => m.Xp);
    int activeCount = missions.Count(m => m.Status == "em-andamento");
    int doneCount   = missions.Count(m => m.Status == "concluida");
}

<div class="cols-4-scroll"><div class="dash-grid cols-4">
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg></div><span class="stat-trend">semana</span></div>
        <div class="stat-val">@missions.Length</div>
        <div class="stat-label">Total de missões</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg></div></div>
        <div class="stat-val">@activeCount</div>
        <div class="stat-label">Em andamento</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div><span class="stat-trend" style="color:#5fd0a0">✓</span></div>
        <div class="stat-val">@doneCount</div>
        <div class="stat-label">Concluídas</div>
    </div>
    <div class="card stat">
        <div class="stat-top"><div class="stat-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div></div>
        <div class="stat-val">@totalXp</div>
        <div class="stat-label">XP ganho</div>
    </div>
</div></div>

<div class="dash-grid cols-3">
    <div class="card span-2">
        <div class="ms-header">
            <div>
                <h3>Minhas missões</h3>
                <div class="card-sub">Definidas pelo professor</div>
            </div>
            <div class="rep-filters">
                <button class="rep-filter active" data-filter="todas">Todas</button>
                <button class="rep-filter" data-filter="em-andamento">Em andamento</button>
                <button class="rep-filter" data-filter="pendente">Pendentes</button>
                <button class="rep-filter" data-filter="concluida">Concluídas</button>
            </div>
        </div>

        <div class="ms-list" id="msList">
            @foreach (var m in missions)
            {
                var statusLabel = m.Status switch {
                    "concluida"    => "Concluída",
                    "em-andamento" => "Em andamento",
                    _              => "Pendente"
                };
                <div class="ms-row" data-status="@m.Status">
                    <div class="ms-icon @m.Status">@Html.Raw(m.Icon)</div>
                    <div class="ms-info">
                        <div class="ms-title-row">
                            <span class="ms-title">@m.Title</span>
                            <span class="ms-cat">@m.Category</span>
                        </div>
                        <span class="ms-desc">@m.Desc</span>
                        @if (m.Status == "em-andamento")
                        {
                            <div class="pbar" style="max-width:260px;margin-top:8px"><i style="width:@(m.Progress)%"></i></div>
                        }
                    </div>
                    <div class="ms-right">
                        <span class="ms-xp">+@(m.Xp) XP</span>
                        <span class="ms-deadline">@m.Deadline</span>
                        <span class="mission-status @m.Status">@statusLabel</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <h3>Progresso XP</h3>
        <div class="card-sub">Acumulado esta semana</div>
        <div class="xp-week">
            @foreach (var (day, xp, active) in new[] {
                ("Seg",  30, false),
                ("Ter", 120, false),
                ("Qua",  50, false),
                ("Qui",  80, false),
                ("Sex",   0, true),
                ("Sáb",   0, true),
                ("Dom",   0, true),
            })
            {
                <div class="xp-day @(active ? "future" : "")">
                    <div class="xp-bar-wrap">
                        <div class="xp-bar" style="height:@(xp > 0 ? (xp * 80 / 120) : 0)px"></div>
                    </div>
                    <span class="xp-day-label">@day</span>
                    @if (xp > 0)
                    {
                        <span class="xp-day-val">@xp</span>
                    }
                </div>
            }
        </div>

        <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border-soft);">
            <div class="card-sub" style="margin-bottom:10px">Próxima recompensa</div>
            <div class="next-reward">
                <span class="next-reward-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 6H4v2a3 3 0 0 0 3 3"/><path d="M17 6h3v2a3 3 0 0 1-3 3"/><path d="M9 17h6"/><path d="M12 13v4"/></svg></span>
                <div>
                    <div style="font-size:13.5px;font-weight:600">500 XP acumulados</div>
                    <div style="font-size:12px;color:var(--muted);margin-top:2px">Faltam @(500 - totalXp) XP</div>
                    <div class="pbar" style="margin-top:8px"><i style="width:@(Math.Min(totalXp * 100 / 500, 100))%"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.ms-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; margin-bottom: 8px;
}
.rep-filters { display: flex; gap: 6px; flex-wrap: wrap; }
.rep-filter {
    padding: 6px 14px; border-radius: 100px; font-size: 12.5px; font-weight: 500;
    background: var(--surface); border: 1px solid var(--border-soft);
    color: var(--muted); cursor: pointer; transition: all .15s;
}
.rep-filter.active, .rep-filter:hover { color: var(--ink); border-color: var(--blue-bright); background: rgba(46,155,255,0.1); }

.ms-list { display: flex; flex-direction: column; gap: 6px; }
.ms-row {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 12px; border-radius: 14px;
    background: var(--surface); border: 1px solid var(--border-soft);
    transition: border-color .15s;
}
.ms-row:hover { border-color: var(--border); }
.ms-row[data-status="concluida"] { opacity: 0.55; }

.ms-icon { font-size: 22px; flex-shrink: 0; width: 40px; height: 40px; border-radius: 12px; display: grid; place-items: center; background: rgba(255,255,255,0.04); border: 1px solid var(--border-soft); }
.ms-icon.concluida { background: rgba(95,208,160,0.1); border-color: rgba(95,208,160,0.2); }
.ms-icon.em-andamento { background: rgba(46,155,255,0.1); border-color: rgba(46,155,255,0.2); }

.ms-info { flex: 1; min-width: 0; }
.ms-title-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 3px; }
.ms-title { font-size: 14px; font-weight: 600; }
.ms-cat { font-size: 11px; padding: 2px 8px; border-radius: 100px; background: rgba(255,255,255,0.06); color: var(--muted); border: 1px solid var(--border-soft); }
.ms-desc { font-size: 12.5px; color: var(--muted); }

.ms-right { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; flex-shrink: 0; }
.ms-xp { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--blue-bright); }
.ms-deadline { font-size: 11.5px; color: var(--muted); }

.mission-status { font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 100px; }
.mission-status.concluida    { background: rgba(95,208,160,0.15); color: #5fd0a0; }
.mission-status.em-andamento { background: rgba(46,155,255,0.12); color: var(--blue-bright); }
.mission-status.pendente     { background: rgba(255,255,255,0.06); color: var(--muted); }

/* XP chart */
.xp-week { display: flex; align-items: flex-end; gap: 6px; height: 100px; padding-top: 10px; }
.xp-day { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; }
.xp-day.future .xp-bar { background: rgba(255,255,255,0.07); }
.xp-bar-wrap { flex: 1; display: flex; align-items: flex-end; width: 100%; }
.xp-bar { width: 100%; border-radius: 5px 5px 0 0; background: linear-gradient(180deg, var(--blue-bright), rgba(30,91,255,0.4)); min-height: 4px; transition: height .3s ease; }
.xp-day-label { font-size: 10.5px; color: var(--muted); }
.xp-day-val { font-size: 10px; color: var(--blue-bright); font-family: var(--font-display); font-weight: 600; }

.next-reward { display: flex; align-items: center; gap: 12px; }
.next-reward-icon { font-size: 28px; flex-shrink: 0; }

@@media (max-width: 680px) {
    .ms-right { display: none; }
    .ms-row { gap: 10px; }
}
</style>

<script>
document.querySelectorAll('.rep-filter').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.querySelectorAll('.rep-filter').forEach(function (b) { b.classList.remove('active'); });
        this.classList.add('active');
        var f = this.dataset.filter;
        document.querySelectorAll('.ms-row').forEach(function (row) {
            row.style.display = (f === 'todas' || row.dataset.status === f) ? '' : 'none';
        });
    });
});
</script>
