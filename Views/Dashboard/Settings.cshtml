@model YourRhythmStudio.ViewModels.Settings.AccountSettingsPageViewModel
@{
    Layout = "_DashboardLayout";
    var isStudent = Model.Role == "student";
    var isTeacher = Model.Role == "teacher";
    var student = Model.Student?.Profile;
    var teacher = Model.Teacher;
    var displayName = student?.DisplayName ?? teacher?.Profile.DisplayName ?? User.Identity?.Name ?? "YourRhythm";
    var photoUrl = student?.ProfilePhotoUrl ?? teacher?.Profile.ProfilePhotoUrl;
    var initials = Initials(displayName);
    var successMsg = TempData["SettingsSuccess"] as string;
    var errorMsg = TempData["SettingsError"] as string;
}

@if (!string.IsNullOrWhiteSpace(successMsg))
{
    <div class="account-feedback success" role="status">@successMsg</div>
}
@if (!string.IsNullOrWhiteSpace(errorMsg))
{
    <div class="account-feedback error" role="alert">@errorMsg</div>
}

<section class="account-page">
    <header class="account-hero">
        <div class="account-photo-preview" data-photo-preview>
            @if (!string.IsNullOrWhiteSpace(photoUrl))
            {
                <img src="@photoUrl" alt="Foto de perfil de @displayName" />
            }
            else
            {
                <span>@initials</span>
            }
        </div>
        <div>
            <span class="account-kicker">Conta YourRhythm</span>
            <h1>@displayName</h1>
            <p>@(isStudent ? "Perfil do aluno" : isTeacher ? "Perfil do professor" : "Configuracoes da conta")</p>
        </div>
    </header>

    @if (isStudent && student is not null)
    {
        <form asp-action="SaveStudentProfile" asp-controller="Dashboard" method="post" enctype="multipart/form-data" class="account-card account-form" data-safe-submit>
            @Html.AntiForgeryToken()
            <div class="account-section-head">
                <div>
                    <span>Aluno</span>
                    <h2>Meu perfil</h2>
                </div>
                <strong class="level-badge">Nivel @student.CurrentLevel - @student.CurrentLevelBadge</strong>
            </div>

            <div class="account-photo-row">
                <div class="account-photo-preview compact" data-photo-preview>
                    @if (!string.IsNullOrWhiteSpace(student.ProfilePhotoUrl))
                    {
                        <img src="@student.ProfilePhotoUrl" alt="Foto de perfil de @student.DisplayName" />
                    }
                    else
                    {
                        <span>@Initials(student.DisplayName)</span>
                    }
                </div>
                <div class="account-photo-actions">
                    <label class="account-file-btn">
                        <input name="Photo" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" data-photo-input />
                        Enviar foto
                    </label>
                    <label class="account-check">
                        <input name="RemovePhoto" type="checkbox" value="true" />
                        Remover foto atual
                    </label>
                    <small>JPG, PNG ou WebP. Maximo 5 MB.</small>
                </div>
            </div>

            <div class="account-grid">
                <label class="account-field span-2">
                    <span>Nome</span>
                    <input name="DisplayName" value="@student.DisplayName" autocomplete="name" />
                </label>
                <label class="account-field span-2">
                    <span>Contato externo opcional</span>
                    <input name="ExternalContact" value="@student.ExternalContact" autocomplete="email tel" placeholder="Telefone ou e-mail dos pais/responsavel" />
                    <small>Usado fora do app. Nao altera seu acesso.</small>
                </label>
                <label class="account-field">
                    <span>Instrumento</span>
                    <input value="@student.Instrument" disabled />
                </label>
                <label class="account-field">
                    <span>Nivel atual</span>
                    <input value="Nivel @student.CurrentLevel - @student.CurrentLevelBadge" disabled />
                </label>
            </div>

            <div class="account-actions">
                <button type="submit" class="account-primary" data-loading-text="Salvando...">Salvar perfil</button>
            </div>
        </form>
    }

    @if (isTeacher && teacher is not null)
    {
        <div class="account-layout">
            <section class="account-card account-form" id="profile">
                <div class="account-section-head">
                    <div>
                        <span>Perfil</span>
                        <h2>Foto e acesso</h2>
                    </div>
                </div>
                <form asp-action="SaveTeacherPhoto" asp-controller="Dashboard" method="post" enctype="multipart/form-data" data-safe-submit>
                    @Html.AntiForgeryToken()
                    <div class="account-photo-row">
                        <div class="account-photo-preview compact" data-photo-preview>
                            @if (!string.IsNullOrWhiteSpace(teacher.Profile.ProfilePhotoUrl))
                            {
                                <img src="@teacher.Profile.ProfilePhotoUrl" alt="Foto de perfil de @teacher.Profile.DisplayName" />
                            }
                            else
                            {
                                <span>@Initials(teacher.Profile.DisplayName)</span>
                            }
                        </div>
                        <div class="account-photo-actions">
                            <label class="account-file-btn">
                                <input name="Photo" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" data-photo-input />
                                Enviar foto
                            </label>
                            <label class="account-check">
                                <input name="RemovePhoto" type="checkbox" value="true" />
                                Remover foto atual
                            </label>
                            <small>JPG, PNG ou WebP. Maximo 5 MB.</small>
                        </div>
                    </div>
                    <div class="account-grid">
                        <label class="account-field span-2">
                            <span>E-mail de acesso atual</span>
                            <input value="@teacher.Profile.Email" autocomplete="email" disabled />
                        </label>
                    </div>
                    <div class="account-actions">
                        <button type="submit" class="account-primary" data-loading-text="Salvando...">Salvar foto</button>
                    </div>
                </form>
            </section>

            <section class="account-card account-form" id="email">
                <div class="account-section-head">
                    <div>
                        <span>Seguranca</span>
                        <h2>Alterar e-mail</h2>
                    </div>
                </div>
                <form asp-action="ChangeTeacherEmail" asp-controller="Dashboard" method="post" data-safe-submit>
                    @Html.AntiForgeryToken()
                    <input name="CurrentEmail" value="@teacher.Email.CurrentEmail" type="hidden" />
                    <div class="account-grid">
                        <label class="account-field span-2">
                            <span>Novo e-mail de acesso</span>
                            <input name="NewEmail" value="@teacher.Email.NewEmail" autocomplete="email" />
                        </label>
                        <label class="account-field span-2">
                            <span>Senha atual</span>
                            <input name="CurrentPassword" type="password" autocomplete="current-password" value="" />
                        </label>
                    </div>
                    <div class="account-actions">
                        <button type="submit" class="account-primary" data-loading-text="Alterando...">Alterar e-mail</button>
                    </div>
                </form>
            </section>

            <section class="account-card account-form" id="security">
                <div class="account-section-head">
                    <div>
                        <span>Seguranca</span>
                        <h2>Trocar senha</h2>
                    </div>
                </div>
                <form asp-action="ChangeTeacherPassword" asp-controller="Dashboard" method="post" data-safe-submit>
                    @Html.AntiForgeryToken()
                    <div class="account-grid">
                        <label class="account-field span-2">
                            <span>Senha atual</span>
                            <input name="CurrentPassword" type="password" autocomplete="current-password" value="" />
                        </label>
                        <label class="account-field">
                            <span>Nova senha</span>
                            <input name="NewPassword" type="password" autocomplete="new-password" value="" />
                        </label>
                        <label class="account-field">
                            <span>Confirmar nova senha</span>
                            <input name="ConfirmPassword" type="password" autocomplete="new-password" value="" />
                        </label>
                    </div>
                    <div class="account-actions">
                        <button type="submit" class="account-primary" data-loading-text="Salvando...">Trocar senha</button>
                    </div>
                </form>
            </section>
        </div>
    }
</section>

<style>
.account-page {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 980px;
}
.account-hero,
.account-card {
    border: 1px solid rgba(107,192,255,.18);
    background: linear-gradient(135deg, rgba(46,155,255,.10), rgba(9,12,22,.94));
    border-radius: 22px;
}
.account-hero {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding: 18px;
}
.account-photo-preview {
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: 22px;
    color: #fff;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--blue-bright), var(--blue-deep));
    border: 1px solid rgba(107,192,255,.28);
}
.account-photo-preview.compact {
    width: 86px;
    height: 86px;
    border-radius: 24px;
}
.account-photo-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.account-kicker,
.account-section-head span {
    display: block;
    color: var(--blue-bright);
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
}
.account-hero h1,
.account-section-head h2 {
    margin: 4px 0 0;
    font-family: var(--font-display);
    line-height: 1.05;
    overflow-wrap: anywhere;
}
.account-hero h1 {
    font-size: clamp(26px, 7vw, 42px);
}
.account-hero p {
    margin: 4px 0 0;
    color: var(--muted);
}
.account-layout {
    display: grid;
    gap: 16px;
}
.account-card {
    padding: 18px;
}
.account-form,
.account-form form {
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.account-section-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
}
.level-badge {
    flex-shrink: 0;
    padding: 8px 12px;
    border-radius: 999px;
    color: #fff;
    background: rgba(46,155,255,.14);
    border: 1px solid rgba(107,192,255,.28);
    font-size: 12px;
}
.account-photo-row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    align-items: center;
}
.account-photo-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
}
.account-photo-actions small {
    flex-basis: 100%;
    color: var(--muted);
    font-size: 12px;
}
.account-file-btn,
.account-check {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
}
.account-file-btn {
    padding: 10px 14px;
    color: #fff;
    background: linear-gradient(135deg, var(--blue-bright), var(--blue-deep));
    cursor: pointer;
}
.account-file-btn input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
}
.account-check {
    color: var(--muted);
}
.account-check input {
    width: 18px;
    height: 18px;
    accent-color: var(--blue-bright);
}
.account-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
}
.account-field {
    display: flex;
    flex-direction: column;
    gap: 7px;
}
.account-field.span-2 {
    grid-column: span 2;
}
.account-field span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
}
.account-field input {
    width: 100%;
    box-sizing: border-box;
    min-height: 46px;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid var(--border-soft);
    color: var(--ink);
    background: rgba(255,255,255,.045);
    font: inherit;
    outline: none;
}
.account-field input:focus {
    border-color: var(--blue-bright);
    box-shadow: 0 0 0 3px rgba(46,155,255,.16);
}
.account-field input:disabled {
    color: #c8d3ec;
    opacity: .78;
}
.account-field small,
.account-field em {
    color: var(--muted);
    font-size: 12px;
    font-style: normal;
    line-height: 1.35;
}
.account-field em:not(:empty) {
    color: #ffb0b0;
}
.account-actions {
    display: flex;
    justify-content: flex-end;
}
.account-primary {
    min-height: 44px;
    padding: 11px 18px;
    border: 0;
    border-radius: 999px;
    color: #fff;
    background: linear-gradient(135deg, var(--blue-bright), var(--blue-deep));
    font: inherit;
    font-weight: 800;
    cursor: pointer;
}
.account-primary:disabled {
    opacity: .65;
    cursor: wait;
}
.account-feedback {
    max-width: 980px;
    padding: 12px 16px;
    border-radius: 14px;
    font-size: 13px;
    font-weight: 800;
}
.account-feedback.success {
    color: #a9f3c8;
    background: rgba(34,208,122,.10);
    border: 1px solid rgba(34,208,122,.26);
}
.account-feedback.error {
    color: #ffb0b0;
    background: rgba(255,100,100,.10);
    border: 1px solid rgba(255,100,100,.26);
}
@@media (min-width: 900px) {
    .account-layout {
        grid-template-columns: 1fr 1fr;
    }
    #profile {
        grid-column: 1 / -1;
    }
}
@@media (max-width: 620px) {
    .account-page {
        gap: 12px;
    }
    .account-hero,
    .account-card {
        border-radius: 18px;
    }
    .account-hero,
    .account-card {
        padding: 14px;
    }
    .account-photo-preview {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        font-size: 18px;
    }
    .account-photo-preview.compact {
        width: 74px;
        height: 74px;
    }
    .account-photo-row,
    .account-grid {
        grid-template-columns: 1fr;
    }
    .account-field.span-2 {
        grid-column: auto;
    }
    .account-section-head {
        flex-direction: column;
    }
    .account-photo-actions,
    .account-actions,
    .account-primary,
    .account-file-btn {
        width: 100%;
    }
}
</style>

<script>
(function () {
    document.querySelectorAll('[data-photo-input]').forEach(function (input) {
        input.addEventListener('change', function () {
            var file = input.files && input.files[0];
            if (!file) return;
            var form = input.closest('form') || document;
            var preview = form.querySelector('[data-photo-preview]');
            if (!preview) return;
            var img = document.createElement('img');
            img.alt = 'Previa da foto selecionada';
            img.src = URL.createObjectURL(file);
            preview.replaceChildren(img);
        });
    });

    document.querySelectorAll('[data-safe-submit]').forEach(function (form) {
        form.addEventListener('submit', function () {
            var button = form.querySelector('button[type="submit"]');
            if (!button || button.disabled) return;
            button.dataset.originalText = button.textContent || '';
            button.textContent = button.dataset.loadingText || 'Salvando...';
            button.disabled = true;
        });
    });
}());
</script>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        return parts.Length == 0 ? "YR" : string.Concat(parts.Select(part => char.ToUpperInvariant(part[0])));
    }
}
