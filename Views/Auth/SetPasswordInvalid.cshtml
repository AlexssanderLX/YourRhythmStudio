@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Link inválido";
}

<main class="auth-shell">
    <section class="auth-card" style="max-width:440px;text-align:center">
        <div class="auth-brand">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
            <span>YourRhythm<span>.</span></span>
        </div>
        <h1 style="font-size:18px;margin-bottom:10px">Link inválido ou expirado</h1>
        <p style="color:var(--muted);font-size:14px;margin-bottom:20px">
            Este link de definição de senha é inválido ou já expirou.<br>
            Entre em contato com o administrador para solicitar um novo link.
        </p>
        <a asp-controller="Auth" asp-action="Login" style="color:var(--blue-bright)">Ir para o login</a>
    </section>
</main>
