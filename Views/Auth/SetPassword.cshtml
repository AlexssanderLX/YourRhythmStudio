@model YourRhythmStudio.ViewModels.Auth.SetPasswordViewModel
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Definir senha";
}

<main class="auth-shell">
    <section class="auth-card" aria-labelledby="setpwd-title" style="max-width:440px">
        <div class="auth-brand">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
            <span>YourRhythm<span>.</span></span>
        </div>

        <div class="auth-copy">
            <h1 id="setpwd-title">Crie sua senha</h1>
            <p>Sua conta foi aprovada. Defina uma senha segura para acessar o sistema.</p>
        </div>

        <form asp-controller="Auth" asp-action="SetPassword" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <label asp-for="Password">Nova senha</label>
            <input asp-for="Password" type="password" autocomplete="new-password" placeholder="Mínimo 8 caracteres" />
            <span asp-validation-for="Password" class="field-error"></span>

            <label asp-for="ConfirmPassword">Confirmar senha</label>
            <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" placeholder="Repita a senha" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>

            <button type="submit" class="btn-full">Definir senha e acessar</button>
        </form>
    </section>
</main>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
