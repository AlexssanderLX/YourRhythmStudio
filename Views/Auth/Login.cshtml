@model YourRhythmStudio.ViewModels.Auth.LoginViewModel

@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Entrar";
}

<main class="auth-shell">
    <section class="auth-card" aria-labelledby="login-title">
        <a href="/" class="auth-back">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Voltar ao início
        </a>
        <div class="auth-brand">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
            <span>YourRhythm<span>.</span></span>
        </div>

        <div class="auth-copy">
            <p class="auth-kicker">Acesso seguro</p>
            <h1 id="login-title">Entre no seu studio</h1>
            <p>Continue acompanhando alunos, aulas, repertorio e progresso musical.</p>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post" class="auth-form" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="email" placeholder="root@yourrhythm.local" />
            <span asp-validation-for="Email"></span>

            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" placeholder="Sua senha" />
            <span asp-validation-for="Password"></span>

            <label class="auth-check">
                <input asp-for="RememberMe" />
                <span>Manter conectado</span>
            </label>

            <button type="submit">Entrar</button>
        </form>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
