@model YourRhythmStudio.ViewModels.Auth.RegisterViewModel

@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Solicitar acesso";
}

<style>
.plan-step { margin-bottom: 28px; }
.plan-step-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
}
.plan-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}
.plan-card {
    position: relative;
    border: 2px solid var(--border-soft);
    border-radius: 14px;
    padding: 18px 16px 16px;
    cursor: pointer;
    transition: border-color .2s, box-shadow .2s;
    background: var(--surface);
    user-select: none;
}
.plan-card:hover { border-color: var(--blue-bright); }
.plan-card.unavailable {
    cursor: not-allowed;
    opacity: .72;
    border-style: dashed;
    background: color-mix(in srgb, var(--surface) 86%, #111827);
}
.plan-card.unavailable:hover {
    border-color: var(--border-soft);
    box-shadow: none;
}
.plan-card.unavailable .plan-icon,
.plan-card.unavailable .plan-price strong {
    color: var(--muted);
}
.plan-card.unavailable .plan-check {
    border-color: color-mix(in srgb, var(--border) 70%, transparent);
}
.plan-card input[type=radio] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
}
.plan-card.selected {
    border-color: var(--blue-bright);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--blue-bright) 18%, transparent);
    background: color-mix(in srgb, var(--blue-bright) 6%, var(--surface));
}
.plan-check {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
}
.plan-card.selected .plan-check {
    background: var(--blue-bright);
    border-color: var(--blue-bright);
}
.plan-check svg { display: none; }
.plan-card.selected .plan-check svg { display: block; }
.plan-icon { display: flex; align-items: center; margin-bottom: 8px; color: var(--blue-bright); }
.plan-name { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
.plan-desc { font-size: 12px; color: var(--muted); margin-bottom: 10px; line-height: 1.45; }
.plan-price { font-size: 13px; color: var(--text); }
.plan-price strong { font-size: 20px; font-weight: 800; color: var(--blue-bright); }
.plan-price span { color: var(--muted); font-size: 12px; }
.plan-badge {
    position: absolute;
    top: -10px;
    right: 12px;
    background: var(--blue-bright);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .05em;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
}
.plan-badge.disabled {
    background: #334155;
    color: #dbeafe;
}
.plan-unavailable {
    display: inline-flex;
    margin-top: 10px;
    border: 1px solid rgba(96, 165, 250, .28);
    border-radius: 999px;
    padding: 4px 9px;
    color: #bfdbfe;
    background: rgba(37, 99, 235, .12);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .03em;
    text-transform: uppercase;
}
.plan-error { color: #e53e3e; font-size: 12.5px; margin-top: 6px; }
.password-field {
    position: relative;
}
.password-field input {
    padding-right: 54px;
}

@@media (max-width: 480px) {
    .plan-cards { grid-template-columns: 1fr; }
}
</style>

<main class="auth-shell">
    <section class="auth-card" aria-labelledby="register-title" style="max-width:500px">
        <a href="/" class="auth-back">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Voltar ao início
        </a>
        <div class="auth-brand">
            <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
            <span>YourRhythm<span>.</span></span>
        </div>

        <div class="auth-copy">
            <p class="auth-kicker">Acesso mediante analise</p>
            <h1 id="register-title">Solicite seu acesso</h1>
            <p>Preencha o formulario e nossa equipe entrara em contato em breve.</p>
        </div>

        <form asp-controller="Auth" asp-action="Register" method="post" class="auth-form" novalidate id="reg-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <div class="plan-step">
                <span class="plan-step-label">Escolha seu plano</span>
                <div class="plan-cards" id="plan-cards">
                    @foreach (var plan in Model.PlanOptions)
                    {
                        var unavailable = !plan.IsAvailableForRequest;
                        var checkedAttr = !unavailable && string.Equals(Model.PlanCode, plan.Code, StringComparison.OrdinalIgnoreCase) ? "checked" : null;
                        <label class="plan-card@(unavailable ? " unavailable" : "")" id="card-@plan.Code" role="radio" aria-checked="false" aria-disabled="@(unavailable ? "true" : "false")">
                            @if (plan.IsSchoolPlan)
                            {
                                <div class="plan-badge@(unavailable ? " disabled" : "")">Escola</div>
                            }
                            <input type="radio" name="PlanCode" value="@plan.Code" id="plan-@plan.Code" checked="@checkedAttr" disabled="@unavailable" />
                            <div class="plan-check">
                                <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                                    <path d="M1 4l3 3 5-6" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div class="plan-icon">
                                @if (plan.IsSchoolPlan)
                                {
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-5 9 5v13" /><path d="M9 21V15h6v6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                                }
                                else
                                {
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" /></svg>
                                }
                            </div>
                            <div class="plan-name">@plan.Name</div>
                            <div class="plan-desc">@plan.Description</div>
                            <div class="plan-price">
                                <strong>@plan.MonthlyPriceBrl.ToString("C0", new System.Globalization.CultureInfo("pt-BR"))</strong>
                                <span>/mes (informativo)</span>
                            </div>
                            @if (unavailable)
                            {
                                <span class="plan-unavailable">Indisponivel · em desenvolvimento</span>
                            }
                        </label>
                    }
                </div>
                @if (!Model.PlanOptions.Any())
                {
                    <div class="plan-error">Nenhum plano disponivel para solicitacao no momento.</div>
                }
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState["PlanCode"]?.Errors.Count > 0)
                {
                    <div class="plan-error">Escolha um plano para continuar.</div>
                }
            </div>

            <label asp-for="DisplayName">Nome completo do responsavel</label>
            <input asp-for="DisplayName" autocomplete="name" placeholder="Ex.: Ana Silva" />
            <span asp-validation-for="DisplayName" class="field-error"></span>

            <label asp-for="Email">E-mail</label>
            <input asp-for="Email" autocomplete="email" placeholder="seu@email.com" />
            <span asp-validation-for="Email" class="field-error"></span>

            <div id="school-name-field" hidden>
                <label asp-for="SchoolName">Nome da escola / studio</label>
                <input asp-for="SchoolName" autocomplete="organization" placeholder="Ex.: Studio Musica Viva" />
                <span asp-validation-for="SchoolName" class="field-error"></span>
            </div>

            <label asp-for="Phone">Telefone / WhatsApp (opcional)</label>
            <input asp-for="Phone" autocomplete="tel" placeholder="(11) 99999-9999" />

            <label asp-for="Password">Senha</label>
            <div class="password-field">
                <input asp-for="Password" autocomplete="new-password" placeholder="Crie uma senha segura" />
                <button type="button" class="password-toggle" data-password-toggle="Password" aria-label="Mostrar senha">Ver</button>
            </div>
            <span asp-validation-for="Password" class="field-error"></span>

            <label asp-for="ConfirmPassword">Confirmar senha</label>
            <div class="password-field">
                <input asp-for="ConfirmPassword" autocomplete="new-password" placeholder="Repita a senha" />
                <button type="button" class="password-toggle" data-password-toggle="ConfirmPassword" aria-label="Mostrar confirmacao da senha">Ver</button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>

            <button type="submit" class="btn-full" id="submit-btn">Solicitar acesso</button>

            <p style="font-size:12px;color:var(--muted);text-align:center;margin-top:8px">
                Solicitacoes sao revisadas antes da liberacao da conta
            </p>
        </form>

        <p class="auth-switch">
            Ja tem conta? <a asp-controller="Auth" asp-action="Login">Entrar</a>
        </p>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var cards = document.querySelectorAll(".plan-card");
        var radios = document.querySelectorAll('input[name="PlanCode"]');
        var submitBtn = document.getElementById("submit-btn");
        var schoolField = document.getElementById("school-name-field");
        var schoolInput = document.getElementById("SchoolName");

        function updateCards() {
            var anyChecked = false;
            radios.forEach(function (radio) {
                var card = radio.closest(".plan-card");
                if (!radio.disabled && radio.checked) {
                    card.classList.add("selected");
                    card.setAttribute("aria-checked", "true");
                    anyChecked = true;
                } else {
                    card.classList.remove("selected");
                    card.setAttribute("aria-checked", "false");
                }
            });

            var selected = document.querySelector('input[name="PlanCode"]:checked');
            var isSchool = selected && selected.value === "escola";
            if (schoolField) schoolField.hidden = !isSchool;
            if (schoolInput) {
                schoolInput.toggleAttribute("required", !!isSchool);
                if (!isSchool) schoolInput.value = "";
            }
            if (submitBtn) {
                submitBtn.textContent = anyChecked ? "Solicitar acesso" : "Selecione um plano";
            }
        }

        var preSelected = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PlanCode ?? string.Empty));
        if (preSelected) {
            var pre = document.querySelector('input[name="PlanCode"][value="' + preSelected + '"]');
            if (pre && !pre.disabled) pre.checked = true;
        }

        radios.forEach(function (radio) { radio.addEventListener("change", updateCards); });
        cards.forEach(function (card) {
            card.addEventListener("click", function () {
                var radio = card.querySelector("input[type=radio]");
                if (radio && !radio.disabled) {
                    radio.checked = true;
                    updateCards();
                }
            });
        });

        document.querySelectorAll("[data-password-toggle]").forEach(function (button) {
            button.addEventListener("click", function () {
                var input = document.getElementById(button.getAttribute("data-password-toggle"));
                if (!input) return;

                var show = input.type === "password";
                input.type = show ? "text" : "password";
                button.textContent = show ? "Ocultar" : "Ver";
                button.setAttribute("aria-label", show ? "Ocultar senha" : "Mostrar senha");
            });
        });

        updateCards();
    })();
    </script>
}
