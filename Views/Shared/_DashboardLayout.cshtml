@{
    var displayName = User.Identity?.Name ?? "Usuário";
    var role = (ViewData["Role"] as string) ?? "school";
    var roleLabel = role switch
    {
        "student" => "Aluno",
        "teacher" => "Professor",
        "school"  => "Escola",
        _ => "Studio"
    };
    var initials = string.Concat(displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2).Select(p => char.ToUpperInvariant(p[0])));

    var currentAction = (ViewContext.RouteData.Values["action"] as string ?? "").ToLower();

    (string Action, string Label, string Icon)[] navDef = role switch
    {
        "student" => new[]
        {
            ("Dashboard",   "Visão geral", "home"),
            ("Assignments", "Missões",     "target"),
            ("Repertoire",  "Repertório",  "music"),
            ("Feedback",    "Feedback",    "message"),
            ("Progress",    "Progresso",   "calendar"),
            ("Levels",      "Níveis",      "trophy"),
        },
        "teacher" => new[]
        {
            ("Dashboard",   "Visão geral",   "home"),
            ("Students",    "Meus alunos",   "users"),
            ("Skills",      "Habilidades",   "target"),
            ("QuickLesson", "Registrar Aula","calendar"),
        },
        _ => new[]
        {
            ("Index",         "Visão geral",  "home"),
            ("Teachers",      "Professores",  "users"),
            ("SchoolStudents","Alunos",        "graduation"),
        }
    };

    var navController = role switch
    {
        "student" => "Student",
        "teacher" => "Teacher",
        _ => "Dashboard"
    };

    var nav = navDef.Select(n => (
        Href:   Url.Action(n.Action, navController)!,
        Label:  n.Label,
        Icon:   n.Icon,
        Active: string.Equals(currentAction, n.Action, StringComparison.OrdinalIgnoreCase)
    )).ToArray();

    var settingsUrl = Url.Action("Settings", "Dashboard")!;
    var isSettings  = currentAction == "settings";
    var hideDashTopbar = ViewData["HideDashTopbar"] as bool? == true;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · YourRhythm Studio</title>
    <link rel="icon" type="image/svg+xml" href="~/img/logo-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @if (role == "student") {
        <link rel="stylesheet" href="~/css/student.css" asp-append-version="true" />
    }
    <script>
    /* YR Performance detection — runs sync to stamp class before first paint */
    (function(){
      var c  = navigator.hardwareConcurrency || 2;
      var m  = navigator.deviceMemory       || 2;
      var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var conn = navigator.connection || {};
      var slow = /^(2g|slow-2g)$/.test(conn.effectiveType || '');
      var tier = 'high';
      if (rm || slow || (c <= 2 && m <= 1)) tier = 'low';
      else if (c < 4 || m < 4)             tier = 'mid';
      document.documentElement.dataset.yr = tier;
      window.yrTier = tier;
    }());
    </script>
</head>
<body class="dash-body" data-role="@role">
    <div class="dash-shell">
        <aside class="dash-sidebar">

            
            <a class="dash-brand" asp-controller="Home" asp-action="Index">
                <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
                <span>YourRhythm<span>.</span><small>Studio</small></span>
            </a>

            
            <div class="mob-topbar">
                <a class="dash-brand mob-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/img/logo-mark.svg" alt="YourRhythm Studio" />
                    <span>YourRhythm<span>.</span></span>
                </a>
                <div class="mob-actions">
                    <a href="@settingsUrl" class="mob-avatar-btn @(isSettings ? "mob-avatar-active" : "")" title="Configurações" aria-label="Configurações">
                        <div class="dash-avatar mob-avatar">@initials</div>
                    </a>
                </div>
            </div>

            
            <div class="dash-nav-wrap"><nav class="dash-nav" id="dashNav">
                @foreach (var item in nav)
                {
                    <a href="@item.Href" class="dash-nav-item @(item.Active ? "active" : "")">
                        <partial name="_DashIcon" model="item.Icon" />
                        <span>@item.Label</span>
                    </a>
                }
                <a href="@settingsUrl" class="dash-nav-item dash-nav-settings @(isSettings ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    <span>Config.</span>
                </a>
            </nav></div>

            
            <a href="@settingsUrl" class="dash-user @(isSettings ? "dash-user-active" : "")" title="Configurações">
                <div class="dash-avatar">@initials</div>
                <div class="dash-user-meta">
                    <strong>@displayName</strong>
                    <span>@roleLabel</span>
                </div>
                <svg class="dash-user-caret" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        </aside>

        <main class="dash-main">
            @if (role != "student" && !isSettings && !hideDashTopbar) {
            <header class="dash-topbar">
                <div>
                    <p class="dash-kicker">@roleLabel · YourRhythm Studio</p>
                    <h1>@ViewData["DashTitle"]</h1>
                </div>
                <a class="dash-back" asp-controller="Home" asp-action="Index">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
                    Voltar ao site
                </a>
            </header>
            }

            <div class="dash-content">
                @RenderBody()
            </div>
        </main>
    </div>

<script>
(function () {
    var nav = document.getElementById('dashNav');
    if (!nav) return;

    var wrap = nav.parentElement;

    // Centraliza item ativo usando scrollIntoView (padrão ZeroPaper)
    var active = nav.querySelector('.dash-nav-item.active');
    if (active) {
        window.requestAnimationFrame(function () {
            active.scrollIntoView({ behavior: 'instant', block: 'nearest', inline: 'center' });
        });
    }

    // Converte scroll vertical em horizontal (padrão ZeroPaper)
    nav.addEventListener('wheel', function (e) {
        if (nav.scrollWidth <= nav.clientWidth) return;
        var delta = Math.abs(e.deltaX) > Math.abs(e.deltaY) ? e.deltaX : e.deltaY;
        if (!delta) return;
        e.preventDefault();
        nav.scrollLeft += delta;
    }, { passive: false });


    function updateFades() {
        if (window.innerWidth > 900) return;
        wrap.classList.toggle('fade-left',  nav.scrollLeft > 8);
        wrap.classList.toggle('fade-right', nav.scrollLeft < nav.scrollWidth - nav.clientWidth - 8);
    }

    nav.addEventListener('scroll', updateFades, { passive: true });
    window.addEventListener('resize', updateFades);
    setTimeout(updateFades, 50);
}());
</script>
@RenderSection("Scripts", required: false)
<script>
/* YR Reveal observer — skipped on yr-low */
(function(){
  if (window.yrTier === 'low') {
    document.querySelectorAll('[data-yr-reveal]').forEach(function(el){
      el.classList.add('yr-visible');
    });
    return;
  }
  if (!window.IntersectionObserver) return;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) { e.target.classList.add('yr-visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('[data-yr-reveal]').forEach(function(el){ io.observe(el); });
}());

/* YR Count-up — only high/mid */
window.yrCountUp = function(el, target, duration){
  if (window.yrTier === 'low') { el.textContent = target; return; }
  var start = 0, startTime = null, dur = duration || 900;
  function step(ts){
    if (!startTime) startTime = ts;
    var p = Math.min((ts - startTime) / dur, 1);
    var ease = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(start + (target - start) * ease);
    if (p < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
};

/* XP bar animate */
window.yrBarAnimate = function(fill, pct){
  if (!fill) return;
  if (window.yrTier === 'low') { fill.style.width = pct + '%'; return; }
  setTimeout(function(){ fill.style.width = pct + '%'; }, 180);
};
</script>
</body>
</html>
