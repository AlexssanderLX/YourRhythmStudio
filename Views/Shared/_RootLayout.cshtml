@{
    var displayName = User.Identity?.Name ?? "Root";
    var section = ViewData["RootSection"] as string ?? "dashboard";

    var navItems = new (string key, string label, string href, string svgPaths)[]
    {
        ("dashboard", "Visão Geral",   "/Root",           "<path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'/><polyline points='9 22 9 12 15 12 15 22'/>"),
        ("requests",  "Solicitações",  "/Root/Requests",  "<circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/>"),
        ("accounts",  "Contas",        "/Root/Accounts",  "<path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><path d='M23 21v-2a4 4 0 0 0-3-3.87'/><path d='M16 3.13a4 4 0 0 1 0 7.75'/>"),
        ("plans",     "Planos",        "/Root/Plans",     "<polyline points='8 11 12 15 16 11'/><polyline points='5 7 5 3 19 3 19 7'/><path d='M5 7c0 5.5 3 9 7 10 4-1 7-4.5 7-10'/>"),
        ("storage",   "Armazenamento", "/Root/Storage",   "<path d='M9 18V5l12-2v13'/><circle cx='6' cy='18' r='3'/><circle cx='18' cy='16' r='3'/>"),
        ("soundtrack", "Trilha Sonora", "/Root/Soundtrack", "<path d='M9 18V5l12-2v13'/><circle cx='6' cy='18' r='3'/><circle cx='18' cy='16' r='3'/>"),
        ("settings",  "Configuracoes", "/Root/Settings",  "<circle cx='12' cy='12' r='3'/><path d='M19.07 4.93a10 10 0 0 1 0 14.14'/><path d='M4.93 4.93a10 10 0 0 0 0 14.14'/>"),
    };
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Root Admin · YourRhythm Studio</title>
    <link rel="icon" type="image/svg+xml" href="~/img/logo-mark.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <style>
        .root-shell { display: flex; min-height: 100vh; background: var(--bg); }

        .root-sidebar {
            width: 220px; min-height: 100vh; background: #0a0e1a;
            display: flex; flex-direction: column;
            border-right: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
        }
        .root-brand {
            display: flex; align-items: center; gap: 10px;
            padding: 20px 16px 16px; text-decoration: none; color: #fff;
            font-family: var(--font-display); font-weight: 700; font-size: 15px;
        }
        .root-brand img { width: 28px; height: 28px; }
        .root-brand-badge {
            font-size: 9px; font-weight: 700; letter-spacing: .06em;
            background: #2563EB; color: #fff; border-radius: 4px;
            padding: 2px 6px; text-transform: uppercase; margin-left: auto;
        }
        .root-nav { padding: 8px 8px; flex: 1; }
        .root-nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 12px; border-radius: 8px; text-decoration: none;
            color: rgba(255,255,255,.55); font-size: 14px; font-weight: 500;
            transition: background .15s, color .15s; margin-bottom: 2px;
        }
        .root-nav-item:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.9); }
        .root-nav-item.active { background: rgba(37,99,235,.2); color: #60a5fa; }
        .root-nav-icon { width: 18px; height: 18px; flex-shrink: 0; }
        .root-user {
            padding: 12px 16px; border-top: 1px solid rgba(255,255,255,.06);
            font-size: 12px; color: rgba(255,255,255,.4);
        }
        .root-user strong { display: block; color: rgba(255,255,255,.7); margin-bottom: 2px; }

        .root-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
        .root-topbar {
            background: var(--surface); border-bottom: 1px solid var(--border-soft);
            padding: 14px 24px; display: flex; align-items: center; gap: 12px;
        }
        .root-topbar h1 { font-size: 16px; font-weight: 700; color: var(--ink); margin: 0; }
        .root-topbar-kicker { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
        .root-content { padding: 24px; flex: 1; }

        .root-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 24px; }
        .root-stat {
            background: var(--surface); border: 1px solid var(--border-soft);
            border-radius: 12px; padding: 16px; text-align: center;
        }
        .root-stat-value { font-size: 28px; font-weight: 800; font-family: var(--font-display); color: var(--ink); }
        .root-stat-label { font-size: 12px; color: var(--muted); margin-top: 2px; }

        .root-table-wrap { overflow-x: auto; }
        .root-table { width: 100%; border-collapse: collapse; font-size: 14px; }
        .root-table th { text-align: left; padding: 8px 12px; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); border-bottom: 1px solid var(--border-soft); }
        .root-table td { padding: 10px 12px; border-bottom: 1px solid var(--border-soft); color: var(--text); vertical-align: middle; }
        .root-table tr:last-child td { border-bottom: none; }
        .root-table tr:hover td { background: var(--bg); }

        .badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-green { background: rgba(34,197,94,.15); color: #22c55e; }
        .badge-yellow { background: rgba(234,179,8,.15); color: #ca8a04; }
        .badge-red { background: rgba(239,68,68,.15); color: #ef4444; }
        .badge-gray { background: rgba(100,116,139,.15); color: #64748b; }
        .badge-blue { background: rgba(37,99,235,.15); color: #2563eb; }

        .btn-root { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: opacity .15s; }
        .btn-root:hover { opacity: .85; }
        .btn-primary { background: #2563EB; color: #fff; }
        .btn-danger { background: #ef4444; color: #fff; }
        .btn-warning { background: #f59e0b; color: #fff; }
        .btn-success { background: #22c55e; color: #fff; }
        .btn-ghost { background: var(--bg); color: var(--text); border: 1px solid var(--border-soft); }
        .btn-sm { padding: 5px 10px; font-size: 12px; }

        .root-form .form-group { margin-bottom: 16px; }
        .root-form label { display: block; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
        .root-form input, .root-form select, .root-form textarea {
            width: 100%; padding: 10px 12px; border-radius: 8px;
            border: 1px solid var(--border); background: var(--surface);
            color: var(--text); font-size: 14px; box-sizing: border-box;
        }
        .root-form input:focus, .root-form select:focus { outline: 2px solid #2563EB; border-color: transparent; }
        .field-error { color: #ef4444; font-size: 12px; }
        .root-card { background: var(--surface); border: 1px solid var(--border-soft); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
        .root-card-title { font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 16px; }

        .alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 16px; }
        .alert-success { background: rgba(34,197,94,.1); color: #16a34a; border: 1px solid rgba(34,197,94,.2); }
        .alert-error { background: rgba(239,68,68,.1); color: #dc2626; border: 1px solid rgba(239,68,68,.2); }

        .storage-bar-wrap { background: var(--border-soft); border-radius: 4px; height: 8px; min-width: 80px; }
        .storage-bar-fill { height: 8px; border-radius: 4px; background: #2563EB; transition: width .4s; }
        .storage-bar-fill.warn { background: #f59e0b; }
        .storage-bar-fill.danger { background: #ef4444; }

        @@media (max-width: 768px) {
            .root-shell { flex-direction: column; }
            .root-sidebar { width: 100%; min-height: auto; }
            .root-nav { display: flex; flex-direction: row; overflow-x: auto; padding: 4px 8px 8px; gap: 4px; }
            .root-nav-item { flex-shrink: 0; padding: 7px 10px; font-size: 13px; margin-bottom: 0; }
            .root-user { display: none; }
            .root-content { padding: 16px; }
        }

        @@media (prefers-reduced-motion: reduce) {
            .storage-bar-fill { transition: none; }
        }
    </style>
</head>
<body style="margin:0;padding:0;">
<div class="root-shell">
    <aside class="root-sidebar" aria-label="Navegação Root Admin">
        <a class="root-brand" href="/Root">
            <img src="~/img/logo-mark.svg" alt="" aria-hidden="true" />
            <span>YourRhythm</span>
            <span class="root-brand-badge">Root</span>
        </a>
        <nav class="root-nav">
            @foreach (var item in navItems)
            {
                <a class="root-nav-item @(section == item.key ? "active" : "")"
                   href="@item.href"
                   aria-current="@(section == item.key ? "page" : null)">
                    <svg class="root-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        @Html.Raw(item.svgPaths)
                    </svg>
                    @item.label
                </a>
            }
        </nav>
        <div class="root-user">
            <strong>@displayName</strong>
            Root Admin
            <form method="post" action="/Auth/Logout" style="margin-top:6px">
                @Html.AntiForgeryToken()
                <button type="submit" style="background:none;border:none;color:rgba(255,255,255,.4);font-size:12px;cursor:pointer;padding:0;text-decoration:underline">
                    Sair
                </button>
            </form>
        </div>
    </aside>

    <main class="root-main">
        <div class="root-topbar">
            <div>
                <div class="root-topbar-kicker">Root Admin · YourRhythm Studio</div>
                <h1>@ViewData["Title"]</h1>
            </div>
        </div>
        <div class="root-content">
            @if (TempData["SuccessMessage"] is string successMsg)
            {
                <div class="alert alert-success" role="alert">@successMsg</div>
            }
            @if (TempData["ErrorMessage"] is string errorMsg)
            {
                <div class="alert alert-error" role="alert">@errorMsg</div>
            }
            @RenderBody()
        </div>
    </main>
</div>
@RenderSection("Scripts", required: false)
</body>
</html>
