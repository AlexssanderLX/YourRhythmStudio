@using YourRhythmStudio.Domain.Learning.Enums
@model YourRhythmStudio.ViewModels.Learning.TeacherSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Habilidades";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Habilidades";

    var levelNames  = new[] { "", "Iniciante", "Aprendiz", "Intermediário", "Avançado", "Mestre" };
    var levelColors = new[] { "", "#64748B", "#22C55E", "#3B82F6", "#A855F7", "#FFB020" };
}

<div class="card" style="margin-bottom:20px">
    <h3 style="margin-bottom:4px">Definir nova habilidade</h3>
    <p class="card-sub" style="margin-bottom:16px">Habilidades definem conquistas que o aluno deve dominar para avançar de nível.</p>
    <form asp-controller="Teacher" asp-action="CreateSkill" method="post" class="auth-form">
        @Html.AntiForgeryToken()
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
            <div>
                <label asp-for="NewSkill.Name">Nome da habilidade</label>
                <input asp-for="NewSkill.Name" placeholder="Ex: Leitura de partitura em clave de sol" />
                <span asp-validation-for="NewSkill.Name" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="NewSkill.RequiredLevel">Nível (1–5)</label>
                <select asp-for="NewSkill.RequiredLevel">
                    @for (var i = 1; i <= 5; i++) {
                        <option value="@i">Nível @i · @levelNames[i]</option>
                    }
                </select>
            </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px">
            <div>
                <label asp-for="NewSkill.SkillType">Tipo</label>
                <select asp-for="NewSkill.SkillType">
                    <option value="@((int)SkillType.PromotionRequired)">Promoção obrigatória — desbloqueia o próximo nível</option>
                    <option value="@((int)SkillType.MissionReward)" selected>Recompensa lendária — ganho ao completar missão épica</option>
                    <option value="@((int)SkillType.ProfessorSpecial)">Especial do professor — concedida livremente</option>
                </select>
                <span class="auth-error" id="skillTypeHint" style="color:var(--muted);font-size:12px;margin-top:4px;display:block"></span>
            </div>
            <div>
                <label asp-for="NewSkill.Description">Descrição (opcional)</label>
                <input asp-for="NewSkill.Description" placeholder="Critério de domínio…" />
            </div>
        </div>
        <button type="submit" style="margin-top:4px">Adicionar habilidade</button>
    </form>
</div>

@if (Model.Skills.Any()) {
    @for (var level = 1; level <= 5; level++) {
        var levelSkills = Model.Skills.Where(s => s.RequiredLevel == level).ToList();
        if (!levelSkills.Any()) continue;
        <div class="card" style="margin-bottom:16px">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
                <div style="width:32px;height:32px;border-radius:50%;background:@levelColors[level];display:grid;place-items:center;font-family:var(--font-display);font-weight:700;font-size:14px;color:#fff;flex-shrink:0">@level</div>
                <div>
                    <div style="font-size:15px;font-weight:600;color:var(--ink)">Nível @level · @levelNames[level]</div>
                    <div style="font-size:12px;color:var(--muted)">@levelSkills.Count habilidade(s)</div>
                </div>
            </div>
            <div class="row-list">
                @foreach (var skill in levelSkills) {
                    var typeLbl = skill.SkillType switch {
                        SkillType.PromotionRequired => "Promoção",
                        SkillType.MissionReward     => "Lendária",
                        _                            => "Especial"
                    };
                    var typeCss = skill.SkillType switch {
                        SkillType.PromotionRequired => "skill-type-promo",
                        SkillType.MissionReward     => "skill-type-legend",
                        _                            => "skill-type-special"
                    };
                    <div class="prow" style="justify-content:space-between;gap:10px">
                        <div class="pmeta" style="min-width:0">
                            <div class="pn" style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                                @skill.Name
                                <span class="skill-type-badge @typeCss">@typeLbl</span>
                            </div>
                            @if (!string.IsNullOrEmpty(skill.Description)) {
                                <div class="ps">@skill.Description</div>
                            }
                        </div>
                        <form asp-controller="Teacher" asp-action="DeleteSkill" asp-route-skillId="@skill.Id" method="post" style="flex-shrink:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" onclick="return confirm('Excluir @skill.Name?')"
                                    style="padding:5px 12px;border-radius:8px;border:1px solid rgba(255,138,138,.3);background:rgba(255,138,138,.08);color:#ff8a8a;cursor:pointer;font-size:12px">
                                Excluir
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
} else {
    <div class="empty-state">
        <p>Nenhuma habilidade definida ainda.<br>Crie habilidades acima para cada nível de progressão.</p>
    </div>
}

<style>
.skill-type-badge {
    display: inline-flex; align-items: center;
    font-size: 10px; font-weight: 600; letter-spacing: .5px; text-transform: uppercase;
    padding: 2px 7px; border-radius: 6px; flex-shrink: 0;
}
.skill-type-promo  { background: rgba(255,176,32,.12);  color: #ffb020; border: 1px solid rgba(255,176,32,.2);  }
.skill-type-legend { background: rgba(168,85,247,.12);  color: #c084fc; border: 1px solid rgba(168,85,247,.2);  }
.skill-type-special{ background: rgba(59,130,246,.10);  color: #60a5fa; border: 1px solid rgba(59,130,246,.18); }
</style>

<script>
(function(){
    var sel  = document.querySelector('select[name="NewSkill.SkillType"]');
    var hint = document.getElementById('skillTypeHint');
    var hints = {
        '@((int)SkillType.PromotionRequired)': 'Apenas uma por nível. O aluno só avança quando essa habilidade for concedida e houver XP suficiente.',
        '@((int)SkillType.MissionReward)':     'Concedida como recompensa por completar uma missão épica ou lendária.',
        '@((int)SkillType.ProfessorSpecial)':  'Você pode conceder e revogar a qualquer momento, sem restrições de XP.',
    };
    function update() { if (hint) hint.textContent = hints[sel.value] || ''; }
    if (sel) { sel.addEventListener('change', update); update(); }
}());
</script>
