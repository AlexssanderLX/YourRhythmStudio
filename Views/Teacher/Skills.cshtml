@using YourRhythmStudio.Domain.Learning.Enums
@using YourRhythmStudio.Application.Learning
@model YourRhythmStudio.ViewModels.Learning.TeacherSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Skills";
    ViewData["Role"] = "teacher";
    ViewData["HideDashTopbar"] = true;

    var levels = LearningLevelCalculator.Levels;
    var levelColors = new[] { "", "#64748B", "#22C55E", "#3B82F6", "#A855F7", "#FFB020" };
}

<div class="skills-page-header">
    <div>
        <h1 class="skills-page-title">Skills</h1>
        <p class="skills-page-sub">Conquistas que definem a evolução pedagógica dos seus alunos.</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" data-open-create>+ Criar skill</button>
</div>

@if (TempData["Error"] is string error) {
    <div class="auth-validation" style="margin-bottom:16px" role="alert">@error</div>
}
@if (TempData["Success"] is string success) {
    <div class="auth-success" style="margin-bottom:16px" role="status">@success</div>
}

<div class="skill-type-cards">
    <div class="skill-type-card">
        <div class="skill-type-card-icon stc-promo" aria-hidden="true">🔒</div>
        <div class="skill-type-card-content">
            <strong>Promoção</strong>
            <p>Obrigatória para subir de nível. Bloqueia a progressão até ser concedida com XP suficiente.</p>
        </div>
    </div>
    <div class="skill-type-card">
        <div class="skill-type-card-icon stc-legend" aria-hidden="true">⚔️</div>
        <div class="skill-type-card-content">
            <strong>Missão</strong>
            <p>Conquistada ao completar uma missão Épica ou Lendária. Não bloqueia progressão.</p>
        </div>
    </div>
    <div class="skill-type-card">
        <div class="skill-type-card-icon stc-special" aria-hidden="true">✨</div>
        <div class="skill-type-card-content">
            <strong>Especial</strong>
            <p>Concedida pelo professor conforme avaliação pedagógica. Sem restrições de XP ou missão.</p>
        </div>
    </div>
</div>

@if (Model.Skills.Any()) {
    @foreach (var level in levels) {
        var levelSkills = Model.Skills.Where(s => s.RequiredLevel == level.Level).ToList();
        if (!levelSkills.Any()) continue;
        <div class="card" style="margin-bottom:16px">
            <div class="skills-level-header">
                <div class="skills-level-badge" style="background:@levelColors[level.Level]" aria-hidden="true">@level.Level</div>
                <div>
                    <div class="skills-level-title">Nível @level.Level · @level.Name</div>
                    <div class="skills-level-count">@levelSkills.Count skill(s)</div>
                </div>
            </div>
            <div class="skill-mgmt-list" role="list">
                @foreach (var skill in levelSkills) {
                    var typeLbl = skill.SkillType switch {
                        SkillType.PromotionRequired => "Promoção",
                        SkillType.MissionReward     => "Missão",
                        _                            => "Especial"
                    };
                    var typeCss = skill.SkillType switch {
                        SkillType.PromotionRequired => "skill-type-promo",
                        SkillType.MissionReward     => "skill-type-legend",
                        _                            => "skill-type-special"
                    };
                    var dotCss = skill.SkillType switch {
                        SkillType.PromotionRequired => "dot-promo",
                        SkillType.MissionReward     => "dot-legend",
                        _                            => "dot-special"
                    };
                    <button type="button" role="listitem"
                            class="skill-mgmt-card@(!skill.IsActive ? " smk-inactive" : "")"
                            data-open-edit
                            data-id="@skill.Id"
                            data-name="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(skill.Name))"
                            data-description="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(skill.Description ?? ""))"
                            data-level="@skill.RequiredLevel"
                            data-type="@((int)skill.SkillType)"
                            data-icon="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(skill.IconName ?? ""))"
                            data-achievement="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(skill.AchievementText ?? ""))"
                            data-criteria="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(skill.ConquestCriteria ?? ""))"
                            aria-label="Editar skill: @skill.Name">
                        <span class="skill-mgmt-dot @dotCss" aria-hidden="true"></span>
                        <span class="skill-mgmt-body">
                            <span class="skill-mgmt-name">
                                @skill.Name
                                <span class="skill-type-badge @typeCss">@typeLbl</span>
                                @if (!skill.IsActive) { <span class="skill-type-badge smk-inactive-badge">Inativa</span> }
                            </span>
                            @if (!string.IsNullOrEmpty(skill.ConquestCriteria)) {
                                <span class="skill-mgmt-criteria">@skill.ConquestCriteria</span>
                            }
                        </span>
                        <span class="skill-mgmt-arrow" aria-hidden="true">›</span>
                    </button>
                }
            </div>
        </div>
    }
} else {
    <div class="empty-state">
        <p>Nenhuma skill criada ainda.<br>Clique em <strong>+ Criar skill</strong> para começar.</p>
    </div>
}

<div class="student-action-modal" data-create-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-create-title">
        <div class="student-panel-head">
            <div>
                <span class="student-section-kicker">Nova skill</span>
                <h2 id="modal-create-title">Criar skill</h2>
            </div>
            <button type="button" class="student-jump-btn" data-close-modal aria-label="Fechar modal">✕</button>
        </div>
        <form asp-controller="Teacher" asp-action="CreateSkill" method="post" class="auth-form compact-form">
            @Html.AntiForgeryToken()
            <div>
                <label for="c-name">Nome da skill</label>
                <input id="c-name" name="NewSkill.Name" required maxlength="200" placeholder="Ex: Leitura em clave de sol" autocomplete="off" />
            </div>
            <div class="form-grid-compact two">
                <div>
                    <label for="c-level">Nível (1–5)</label>
                    <select id="c-level" name="NewSkill.RequiredLevel">
                        @foreach (var level in levels) {
                            <option value="@level.Level">Nível @level.Level · @level.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="c-type">Tipo</label>
                    <select id="c-type" name="NewSkill.SkillType" data-type-select="create">
                        <option value="@((int)SkillType.PromotionRequired)">Promoção</option>
                        <option value="@((int)SkillType.MissionReward)" selected>Missão</option>
                        <option value="@((int)SkillType.ProfessorSpecial)">Especial</option>
                    </select>
                </div>
            </div>
            <p class="skill-type-hint" data-type-hint="create" aria-live="polite"></p>
            <div>
                <label for="c-description">Descrição (opcional)</label>
                <textarea id="c-description" name="NewSkill.Description" maxlength="1000" rows="2" placeholder="Descreva o critério de domínio…"></textarea>
            </div>
            <div class="form-grid-compact two">
                <div>
                    <label for="c-criteria">Critério de conquista</label>
                    <input id="c-criteria" name="NewSkill.ConquestCriteria" maxlength="500" placeholder="Ex: Lê 20 compassos sem erro" />
                </div>
                <div>
                    <label for="c-achievement">Texto de conquista</label>
                    <input id="c-achievement" name="NewSkill.AchievementText" maxlength="500" placeholder="Ex: Dominou clave de sol" />
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
                <button type="submit" class="btn btn-primary">Criar skill</button>
            </div>
        </form>
    </section>
</div>

<div class="student-action-modal" data-edit-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-edit-title">
        <div class="student-panel-head">
            <div>
                <span class="student-section-kicker">Editar skill</span>
                <h2 id="modal-edit-title" data-edit-heading>Skill</h2>
            </div>
            <button type="button" class="student-jump-btn" data-close-modal aria-label="Fechar modal">✕</button>
        </div>
        <form method="post" class="auth-form compact-form" data-edit-form>
            @Html.AntiForgeryToken()
            <input name="SkillId" type="hidden" data-edit-id />
            <div>
                <label for="e-name">Nome da skill</label>
                <input id="e-name" name="Name" data-edit-name required maxlength="200" autocomplete="off" />
            </div>
            <div class="form-grid-compact two">
                <div>
                    <label for="e-level">Nível (1–5)</label>
                    <select id="e-level" name="RequiredLevel" data-edit-level>
                        @foreach (var level in levels) {
                            <option value="@level.Level">Nível @level.Level · @level.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label for="e-type">Tipo</label>
                    <select id="e-type" name="SkillType" data-edit-type data-type-select="edit">
                        <option value="@((int)SkillType.PromotionRequired)">Promoção</option>
                        <option value="@((int)SkillType.MissionReward)">Missão</option>
                        <option value="@((int)SkillType.ProfessorSpecial)">Especial</option>
                    </select>
                </div>
            </div>
            <p class="skill-type-hint" data-type-hint="edit" aria-live="polite"></p>
            <div>
                <label for="e-description">Descrição (opcional)</label>
                <textarea id="e-description" name="Description" data-edit-description maxlength="1000" rows="2"></textarea>
            </div>
            <div class="form-grid-compact two">
                <div>
                    <label for="e-criteria">Critério de conquista</label>
                    <input id="e-criteria" name="ConquestCriteria" data-edit-criteria maxlength="500" />
                </div>
                <div>
                    <label for="e-achievement">Texto de conquista</label>
                    <input id="e-achievement" name="AchievementText" data-edit-achievement maxlength="500" />
                </div>
            </div>
            <input name="IconName" data-edit-icon type="hidden" />
            <div class="modal-actions">
                <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
                <button type="submit" class="btn btn-primary">Salvar alterações</button>
            </div>
        </form>
        <form method="post" data-delete-form style="margin-top:8px">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-sm btn-full" data-delete-button>
                Excluir skill
            </button>
        </form>
    </section>
</div>

<style>
.skills-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}
.skills-page-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 4px;
}
.skills-page-sub {
    color: var(--muted);
    font-size: 13px;
    margin: 0;
}

/* --- Type cards --- */
.skill-type-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-bottom: 24px;
}
@@media (min-width: 640px) {
    .skill-type-cards { grid-template-columns: repeat(3, 1fr); }
}
.skill-type-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(16,22,40,0.55), rgba(9,12,22,0.65));
    border: 1px solid var(--border-soft);
}
.skill-type-card-icon {
    font-size: 20px;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
}
.stc-promo  { background: rgba(255,176,32,.12);  border: 1px solid rgba(255,176,32,.2); }
.stc-legend { background: rgba(168,85,247,.12);  border: 1px solid rgba(168,85,247,.2); }
.stc-special{ background: rgba(59,130,246,.10);  border: 1px solid rgba(59,130,246,.18); }
.skill-type-card-content strong {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
}
.skill-type-card-content p {
    margin: 0;
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
}

/* --- Level header --- */
.skills-level-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
}
.skills-level-badge {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: #fff;
    flex-shrink: 0;
}
.skills-level-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
}
.skills-level-count {
    font-size: 12px;
    color: var(--muted);
    margin-top: 1px;
}

/* --- Skill management cards --- */
.skill-mgmt-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.skill-mgmt-card {
    width: 100%;
    display: grid;
    grid-template-columns: 10px 1fr 16px;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: transparent;
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: background .15s ease, border-color .15s ease;
    font-family: var(--font-body);
}
.skill-mgmt-card:hover {
    background: var(--surface);
    border-color: var(--border);
}
.skill-mgmt-card.smk-inactive {
    opacity: .55;
}
.skill-mgmt-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    align-self: center;
}
.dot-promo   { background: #ffb020; }
.dot-legend  { background: #c084fc; }
.dot-special { background: #60a5fa; }
.skill-mgmt-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
}
.skill-mgmt-name {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
}
.skill-mgmt-criteria {
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.skill-mgmt-arrow {
    color: var(--muted);
    font-size: 18px;
    line-height: 1;
    user-select: none;
}
.smk-inactive-badge {
    background: rgba(148,163,184,.1);
    color: #94a3b8;
    border: 1px solid rgba(148,163,184,.2);
}

/* --- Skill type badges --- */
.skill-type-badge {
    display: inline-flex;
    align-items: center;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 6px;
    flex-shrink: 0;
}
.skill-type-promo  { background: rgba(255,176,32,.12);  color: #ffb020; border: 1px solid rgba(255,176,32,.2);  }
.skill-type-legend { background: rgba(168,85,247,.12);  color: #c084fc; border: 1px solid rgba(168,85,247,.2);  }
.skill-type-special{ background: rgba(59,130,246,.10);  color: #60a5fa; border: 1px solid rgba(59,130,246,.18); }

/* --- Modal actions row --- */
.modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 4px;
    flex-wrap: wrap;
}

/* --- Type hint text --- */
.skill-type-hint {
    margin: -4px 0 0;
    font-size: 12px;
    color: var(--muted);
    min-height: 16px;
}

@@media (prefers-reduced-motion: reduce) {
    .skill-mgmt-card { transition: none; }
}
</style>

@section Scripts {
<script>
(function () {
    'use strict';

    var TYPE_HINTS = {
        '@((int)SkillType.PromotionRequired)': 'Apenas uma por nível recomendada. Bloqueia a promoção até o professor conceder e o aluno ter XP suficiente.',
        '@((int)SkillType.MissionReward)':     'Vinculada a missões Épicas ou Lendárias. Não bloqueia progressão de nível.',
        '@((int)SkillType.ProfessorSpecial)':  'Concedida e revogada livremente pelo professor. Sem restrições de XP.',
    };

    var createPanel = document.querySelector('[data-create-panel]');
    var editPanel   = document.querySelector('[data-edit-panel]');
    var lastFocus   = null;

    function openModal(panel) {
        lastFocus = document.activeElement;
        panel.hidden = false;
        document.body.classList.add('modal-open');
        var first = panel.querySelector('input:not([type=hidden]),textarea,select,button');
        if (first) first.focus();
    }

    function closeAll() {
        document.querySelectorAll('.student-action-modal').forEach(function (p) { p.hidden = true; });
        document.body.classList.remove('modal-open');
        if (lastFocus) lastFocus.focus();
    }

    document.querySelector('[data-open-create]').addEventListener('click', function () {
        openModal(createPanel);
    });

    document.querySelectorAll('[data-close-modal]').forEach(function (el) {
        el.addEventListener('click', closeAll);
    });

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAll();
    });

    // Type hints
    document.querySelectorAll('[data-type-select]').forEach(function (sel) {
        var key = sel.dataset.typeSelect;
        var hint = document.querySelector('[data-type-hint="' + key + '"]');
        function updateHint() { if (hint) hint.textContent = TYPE_HINTS[sel.value] || ''; }
        sel.addEventListener('change', updateHint);
        updateHint();
    });

    // Edit modal
    document.querySelectorAll('[data-open-edit]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var d = btn.dataset;
            var editForm   = document.querySelector('[data-edit-form]');
            var deleteForm = document.querySelector('[data-delete-form]');

            editForm.action   = '/Teacher/Skills/' + d.id;
            deleteForm.action = '/Teacher/Skills/' + d.id + '/Delete';

            document.querySelector('[data-edit-id]').value          = d.id;
            document.querySelector('[data-edit-name]').value        = JSON.parse(d.name);
            document.querySelector('[data-edit-description]').value = JSON.parse(d.description);
            document.querySelector('[data-edit-level]').value       = d.level;
            document.querySelector('[data-edit-type]').value        = d.type;
            document.querySelector('[data-edit-icon]').value        = JSON.parse(d.icon);
            document.querySelector('[data-edit-achievement]').value = JSON.parse(d.achievement);
            document.querySelector('[data-edit-criteria]').value    = JSON.parse(d.criteria);
            document.querySelector('[data-edit-heading]').textContent = JSON.parse(d.name);

            // Trigger hint update for edit type select
            document.querySelector('[data-edit-type]').dispatchEvent(new Event('change'));

            // Delete confirmation
            var delBtn = document.querySelector('[data-delete-button]');
            var name = JSON.parse(d.name);
            delBtn.onclick = function () {
                return confirm('Desativar ou excluir a skill "' + name + '"?');
            };

            openModal(editPanel);
        });
    });
}());
</script>
}
