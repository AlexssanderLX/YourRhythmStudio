@model YourRhythmStudio.ViewModels.Learning.TeacherStudentDetailWithSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = $"Repertorio · {Model.Base.Detail.Student.DisplayName}";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Repertorio";
    var student = Model.Base.Detail.Student;
    var studentId = student.StudentProfileId;
}

<section class="teacher-student-page">
    <div class="module-header">
        <div>
            <a class="student-back-link module-summary-link" asp-action="StudentDetail" asp-route-studentId="@studentId">
                <span aria-hidden="true">←</span>
                <span>Resumo de @student.DisplayName</span>
            </a>
            <h1>Repertorio</h1>
            <p>Materiais de estudo enviados para @student.DisplayName.</p>
        </div>
        <div class="module-header-actions">
            <button type="button" class="btn btn-primary btn-sm" data-open-create>Criar repertorio</button>
            <partial name="_StudentManagementActions" model="Model" />
        </div>
    </div>

    @if (TempData["Error"] is string error) { <div class="auth-validation">@error</div> }
    @if (TempData["Success"] is string success) { <div class="auth-success">@success</div> }

    <section class="student-form-panel module-list-panel">
        <div class="student-panel-head compact">
            <div><span class="student-section-kicker">Lista</span><h2>@Model.Base.Detail.Repertoire.Count materiais</h2></div>
        </div>
        <div class="module-list">
            @foreach (var item in Model.Base.Detail.Repertoire)
            {
                <button type="button"
                        class="module-row"
                        data-open-edit
                        data-id="@item.Id"
                        data-title="@item.Title"
                        data-notes="@item.Notes"
                        data-url="@item.ReferenceUrl">
                    <span class="module-row-main">
                        <strong>@item.Title</strong>
                        <small>@(item.HasAudio ? "audio" : "link") · criado em @item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy") · @item.ProgressPercent%</small>
                    </span>
                    <span class="module-row-meta">@(item.ReferenceUrl is not null ? "link" : item.HasAudio ? "audio" : "sem ref")</span>
                </button>
            }
            @if (!Model.Base.Detail.Repertoire.Any())
            {
                <div class="module-empty">
                    <strong>Nenhum repertorio enviado.</strong>
                    <p>Adicione um link ou audio para orientar o estudo do aluno.</p>
                </div>
            }
        </div>
    </section>
</section>

<div class="student-action-modal" data-create-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Criar repertorio">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Novo repertorio</span><h2>@student.DisplayName</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form asp-action="AddRepertoire" asp-route-studentId="@studentId" method="post" enctype="multipart/form-data" class="auth-form compact-form">
            @Html.AntiForgeryToken()
            <input name="Repertoire.StudentProfileId" type="hidden" value="@studentId" />
            <div>
                <label>Nome</label>
                <input name="Repertoire.Title" required maxlength="180" placeholder="Ex: Clair de Lune referencia" />
            </div>
            <div>
                <label>Link de referencia</label>
                <input name="Repertoire.ReferenceUrl" type="url" maxlength="500" placeholder="https://..." />
            </div>
            <div>
                <label>Arquivo de audio opcional</label>
                <input name="Repertoire.AudioFile" type="file" accept="audio/*,.mp3,.wav,.m4a,.aac,.ogg,.flac,.webm" />
            </div>
            <div>
                <label>Descricao opcional</label>
                <textarea name="Repertoire.Notes" maxlength="2000" placeholder="Como usar este material?"></textarea>
            </div>
            <button type="submit">Salvar repertorio</button>
        </form>
    </section>
</div>

<div class="student-action-modal" data-edit-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Editar repertorio">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Editar repertorio</span><h2 data-edit-heading>Material</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form method="post" enctype="multipart/form-data" class="auth-form compact-form" data-edit-form>
            @Html.AntiForgeryToken()
            <input name="StudentProfileId" type="hidden" value="@studentId" />
            <input name="RepertoireItemId" type="hidden" data-edit-id />
            <div>
                <label>Nome</label>
                <input name="Title" data-edit-title required maxlength="180" />
            </div>
            <div>
                <label>Link de referencia</label>
                <input name="ReferenceUrl" data-edit-url type="url" maxlength="500" />
            </div>
            <div>
                <label>Trocar/adicionar audio opcional</label>
                <input name="AudioFile" type="file" accept="audio/*,.mp3,.wav,.m4a,.aac,.ogg,.flac,.webm" />
            </div>
            <div>
                <label>Descricao opcional</label>
                <textarea name="Notes" data-edit-notes maxlength="2000"></textarea>
            </div>
            <button type="submit">Salvar repertorio</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function(){
        var studentId = '@studentId';
        var createPanel = document.querySelector('[data-create-panel]');
        var editPanel = document.querySelector('[data-edit-panel]');
        function open(panel){ panel.hidden = false; document.body.classList.add('modal-open'); }
        function close(){ document.querySelectorAll('.student-action-modal').forEach(function(p){ p.hidden = true; }); document.body.classList.remove('modal-open'); }
        document.querySelector('[data-open-create]')?.addEventListener('click', function(){ open(createPanel); });
        document.querySelectorAll('[data-close-modal]').forEach(function(btn){ btn.addEventListener('click', close); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') close(); });
        document.querySelectorAll('[data-open-edit]').forEach(function(row){
            row.addEventListener('click', function(){
                var id = row.dataset.id;
                var form = document.querySelector('[data-edit-form]');
                form.action = '/Teacher/Students/' + studentId + '/Repertoire/' + id;
                document.querySelector('[data-edit-id]').value = id;
                document.querySelector('[data-edit-title]').value = row.dataset.title || '';
                document.querySelector('[data-edit-url]').value = row.dataset.url || '';
                document.querySelector('[data-edit-notes]').value = row.dataset.notes || '';
                document.querySelector('[data-edit-heading]').textContent = row.dataset.title || 'Material';
                open(editPanel);
            });
        });
    }());
    </script>
}
