@model YourRhythmStudio.ViewModels.Learning.TeacherStudentDetailWithSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = $"Feedbacks · {Model.Base.Detail.Student.DisplayName}";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Feedbacks";
    var student = Model.Base.Detail.Student;
    var studentId = student.StudentProfileId;
}

<section class="teacher-student-page">
    <div class="module-header">
        <div>
            <a class="student-back-link" asp-action="StudentDetail" asp-route-studentId="@studentId">Resumo de @student.DisplayName</a>
            <h1>Feedbacks</h1>
            <p>Retornos publicos e privados registrados pelo professor.</p>
        </div>
        <button type="button" class="btn btn-primary btn-sm" data-open-create>Criar feedback</button>
    </div>

    @if (TempData["Error"] is string error) { <div class="auth-validation">@error</div> }
    @if (TempData["Success"] is string success) { <div class="auth-success">@success</div> }

    <section class="student-form-panel module-list-panel">
        <div class="student-panel-head compact">
            <div><span class="student-section-kicker">Historico</span><h2>@Model.Base.Detail.Feedback.Count registros</h2></div>
        </div>
        <div class="module-list">
            @foreach (var item in Model.Base.Detail.Feedback.OrderByDescending(f => f.CreatedAtUtc))
            {
                <button type="button"
                        class="module-row"
                        data-open-edit
                        data-id="@item.Id"
                        data-message="@item.Message"
                        data-visible="@item.VisibleToStudent.ToString().ToLowerInvariant()">
                    <span class="module-row-main">
                        <strong>@Summary(item.Message)</strong>
                        <small>@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") · professor</small>
                    </span>
                    <span class="module-row-meta">@(item.VisibleToStudent ? "visivel" : "privado")</span>
                </button>
            }
            @if (!Model.Base.Detail.Feedback.Any())
            {
                <div class="module-empty">
                    <strong>Nenhum feedback registrado.</strong>
                    <p>Registre um retorno simples para orientar o aluno.</p>
                </div>
            }
        </div>
    </section>
</section>

<div class="student-action-modal" data-create-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Criar feedback">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Novo feedback</span><h2>@student.DisplayName</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form asp-action="CreateFeedback" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
            @Html.AntiForgeryToken()
            <input name="Feedback.StudentProfileId" type="hidden" value="@studentId" />
            <div>
                <label>Mensagem</label>
                <textarea name="Feedback.Message" required maxlength="2000" placeholder="Escreva um retorno claro e util."></textarea>
            </div>
            <label class="auth-check">
                <input name="Feedback.VisibleToStudent" type="checkbox" value="true" checked />
                <input name="Feedback.VisibleToStudent" type="hidden" value="false" />
                <span>Visivel para o aluno</span>
            </label>
            <button type="submit">Salvar feedback</button>
        </form>
    </section>
</div>

<div class="student-action-modal" data-edit-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Editar feedback">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Editar feedback</span><h2>Retorno</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form method="post" class="auth-form compact-form" data-edit-form>
            @Html.AntiForgeryToken()
            <input name="StudentProfileId" type="hidden" value="@studentId" />
            <input name="FeedbackId" type="hidden" data-edit-id />
            <div>
                <label>Mensagem</label>
                <textarea name="Message" data-edit-message required maxlength="2000"></textarea>
            </div>
            <label class="auth-check">
                <input name="VisibleToStudent" data-edit-visible type="checkbox" value="true" />
                <input name="VisibleToStudent" type="hidden" value="false" />
                <span>Visivel para o aluno</span>
            </label>
            <button type="submit">Salvar feedback</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function(){
        var studentId = '@studentId';
        var createPanel = document.querySelector('[data-create-panel]');
        var editPanel = document.querySelector('[data-edit-panel]');
        function open(panel){ panel.hidden = false; document.body.classList.add('modal-open'); }
        function close(){ document.querySelectorAll('.student-action-modal').forEach(function(p){ p.hidden = true; }); document.body.classList.remove('modal-open'); }
        document.querySelector('[data-open-create]')?.addEventListener('click', function(){ open(createPanel); });
        document.querySelectorAll('[data-close-modal]').forEach(function(btn){ btn.addEventListener('click', close); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') close(); });
        document.querySelectorAll('[data-open-edit]').forEach(function(row){
            row.addEventListener('click', function(){
                var id = row.dataset.id;
                var form = document.querySelector('[data-edit-form]');
                form.action = '/Teacher/Students/' + studentId + '/Feedback/' + id;
                document.querySelector('[data-edit-id]').value = id;
                document.querySelector('[data-edit-message]').value = row.dataset.message || '';
                document.querySelector('[data-edit-visible]').checked = row.dataset.visible === 'true';
                open(editPanel);
            });
        });
    }());
    </script>
}

@functions {
    private static string Summary(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return "Feedback";
        return value.Length <= 80 ? value : value[..80] + "...";
    }
}
