@model YourRhythmStudio.ViewModels.Learning.CreateStudentViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Cadastrar aluno";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Cadastrar aluno";
}

<a class="back-link" asp-controller="Teacher" asp-action="Students">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    Voltar para alunos
</a>

<section class="create-student-shell">
    <div class="card create-student-card">
        <div class="student-panel-head compact">
            <div>
                <span class="student-section-kicker">Novo aluno</span>
                <h2>Cadastrar aluno</h2>
            </div>
        </div>
        <p class="create-student-intro">Informe o essencial para acompanhar aulas, missoes, repertorio e progresso.</p>

        <form asp-controller="Teacher" asp-action="CreateStudent" method="post" class="auth-form create-student-form" data-create-student-form novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

            <div>
                <label asp-for="DisplayName">Nome completo <span class="required-mark">*</span></label>
                <input asp-for="DisplayName" placeholder="Ex: Sofia Almeida" autocomplete="name" aria-required="true" />
                <span asp-validation-for="DisplayName" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Contact">Email ou contato <span class="optional-mark">opcional</span></label>
                <input asp-for="Contact" type="text" placeholder="Email, telefone dos pais ou observacao administrativa" autocomplete="off" />
                <p class="field-hint">Pode ser do aluno, responsavel, pais ou apenas um registro administrativo.</p>
                <span asp-validation-for="Contact" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Instrument">Instrumento <span class="required-mark">*</span></label>
                <input asp-for="Instrument" placeholder="Ex: Piano, Violao, Teclado..." aria-required="true" />
                <span asp-validation-for="Instrument" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Level">Nivel inicial <span class="required-mark">*</span></label>
                <select asp-for="Level" class="level-select" aria-required="true">
                    <option value="1">Nivel 1 - Iniciante</option>
                    <option value="2">Nivel 2 - Aprendiz</option>
                    <option value="3">Nivel 3 - Intermediario</option>
                    <option value="4">Nivel 4 - Avancado</option>
                    <option value="5">Nivel 5 - Lendario</option>
                </select>
                <span asp-validation-for="Level" class="field-error"></span>
            </div>

            <div>
                <label asp-for="Notes">Observacoes <span class="optional-mark">opcional</span></label>
                <textarea asp-for="Notes" placeholder="Historico, objetivos, dificuldades..."></textarea>
                <span asp-validation-for="Notes" class="field-error"></span>
            </div>

            <button type="submit" class="btn-full" data-submit-label="Cadastrar aluno">
                <span data-button-text>Cadastrar aluno</span>
            </button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function(){
        var form = document.querySelector('[data-create-student-form]');
        if (!form) return;
        var button = form.querySelector('button[type="submit"]');
        var buttonText = form.querySelector('[data-button-text]');
        var hasErrors = form.querySelector('.field-error:not(:empty), .auth-validation:not(:empty)');
        if (hasErrors) {
            var invalid = form.querySelector('.input-validation-error, [aria-invalid="true"]');
            if (invalid && typeof invalid.focus === 'function') invalid.focus();
        }
        form.addEventListener('submit', function(event){
            if (form.dataset.submitting === 'true') {
                event.preventDefault();
                return;
            }
            if (window.jQuery && !window.jQuery(form).valid()) {
                return;
            }
            form.dataset.submitting = 'true';
            if (button) button.disabled = true;
            if (buttonText) buttonText.textContent = 'Salvando...';
        });
    }());
    </script>
}
