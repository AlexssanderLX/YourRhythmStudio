@model YourRhythmStudio.ViewModels.Learning.TeacherStudentDetailWithSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = $"Aulas · {Model.Base.Detail.Student.DisplayName}";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Aulas";
    var student = Model.Base.Detail.Student;
    var studentId = student.StudentProfileId;
}

<section class="teacher-student-page">
    <div class="module-header">
        <div>
            <a class="student-back-link module-summary-link" asp-action="StudentDetail" asp-route-studentId="@studentId">
                <span aria-hidden="true">←</span>
                <span>Resumo de @student.DisplayName</span>
            </a>
            <h1>Aulas</h1>
            <p>Registros com nome, data, hora e descricao da aula.</p>
        </div>
        <div class="module-header-actions">
            <button type="button" class="btn btn-primary btn-sm" data-open-create>Criar aula</button>
            <partial name="_StudentManagementActions" model="Model" />
        </div>
    </div>

    @if (TempData["Error"] is string error) { <div class="auth-validation">@error</div> }
    @if (TempData["Success"] is string success) { <div class="auth-success">@success</div> }

    <section class="student-form-panel module-list-panel">
        <div class="student-panel-head compact">
            <div><span class="student-section-kicker">Historico</span><h2>@Model.Base.Detail.Lessons.Count aulas</h2></div>
        </div>
        <div class="module-list">
            @foreach (var lesson in Model.Base.Detail.Lessons.OrderByDescending(l => l.LessonDateUtc))
            {
                <button type="button"
                        class="module-row"
                        data-open-edit
                        data-id="@lesson.Id"
                        data-title="@lesson.Title"
                        data-notes="@lesson.Notes"
                        data-date="@lesson.LessonDateUtc.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")">
                    <span class="module-row-main">
                        <strong>@lesson.Title</strong>
                        <small>@lesson.LessonDateUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") · @lesson.Status</small>
                    </span>
                    <span class="module-row-meta">abrir</span>
                </button>
            }
            @if (!Model.Base.Detail.Lessons.Any())
            {
                <div class="module-empty">
                    <strong>Nenhuma aula registrada.</strong>
                    <p>Crie a primeira aula com data, hora e descricao simples.</p>
                </div>
            }
        </div>
    </section>
</section>

<div class="student-action-modal" data-create-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Criar aula">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Nova aula</span><h2>@student.DisplayName</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form asp-action="CreateLesson" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
            @Html.AntiForgeryToken()
            <input name="Lesson.StudentProfileId" type="hidden" value="@studentId" />
            <div>
                <label>Data e hora</label>
                <input name="Lesson.LessonDateUtc" type="datetime-local" step="60" required />
            </div>
            <div>
                <label>Nome da aula</label>
                <input name="Lesson.Title" required maxlength="180" placeholder="Ex: Escalas maiores" />
            </div>
            <div>
                <label>Descricao da aula</label>
                <textarea name="Lesson.Notes" maxlength="2000" placeholder="O que foi ou sera trabalhado?"></textarea>
            </div>
            <button type="submit">Registrar aula</button>
        </form>
    </section>
</div>

<div class="student-action-modal" data-edit-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Editar aula">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Editar aula</span><h2 data-edit-heading>Aula</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form method="post" class="auth-form compact-form" data-edit-form>
            @Html.AntiForgeryToken()
            <input name="StudentProfileId" type="hidden" value="@studentId" />
            <input name="LessonId" type="hidden" data-edit-id />
            <div>
                <label>Data e hora</label>
                <input name="LessonDateUtc" data-edit-date type="datetime-local" step="60" required />
            </div>
            <div>
                <label>Nome da aula</label>
                <input name="Title" data-edit-title required maxlength="180" />
            </div>
            <div>
                <label>Descricao da aula</label>
                <textarea name="Notes" data-edit-notes maxlength="2000"></textarea>
            </div>
            <button type="submit">Salvar aula</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function(){
        var studentId = '@studentId';
        var createPanel = document.querySelector('[data-create-panel]');
        var editPanel = document.querySelector('[data-edit-panel]');
        function open(panel){ panel.hidden = false; document.body.classList.add('modal-open'); }
        function close(){ document.querySelectorAll('.student-action-modal').forEach(function(p){ p.hidden = true; }); document.body.classList.remove('modal-open'); }
        document.querySelector('[data-open-create]')?.addEventListener('click', function(){ open(createPanel); });
        document.querySelectorAll('[data-close-modal]').forEach(function(btn){ btn.addEventListener('click', close); });
        document.addEventListener('keydown', function(e){ if (e.key === 'Escape') close(); });
        document.querySelectorAll('[data-open-edit]').forEach(function(row){
            row.addEventListener('click', function(){
                var id = row.dataset.id;
                var form = document.querySelector('[data-edit-form]');
                form.action = '/Teacher/Students/' + studentId + '/Lessons/' + id;
                document.querySelector('[data-edit-id]').value = id;
                document.querySelector('[data-edit-title]').value = row.dataset.title || '';
                document.querySelector('[data-edit-notes]').value = row.dataset.notes || '';
                document.querySelector('[data-edit-date]').value = row.dataset.date || '';
                document.querySelector('[data-edit-heading]').textContent = row.dataset.title || 'Aula';
                open(editPanel);
            });
        });
    }());
    </script>
}
