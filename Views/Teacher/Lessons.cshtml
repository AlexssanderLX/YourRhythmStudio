@model YourRhythmStudio.ViewModels.Learning.TeacherLessonsViewModel
@using YourRhythmStudio.Domain.Learning.Enums
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Aulas";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Aulas";

    var openCreate = ViewData["OpenCreateLessonModal"] as bool? == true;
    var openEditId = ViewData["OpenEditLessonModal"] as Guid?;

    string StatusLabel(LessonStatus status) => status switch
    {
        LessonStatus.Completed => "Concluida",
        LessonStatus.Cancelled => "Cancelada",
        _ => "Planejada"
    };
}

<section class="teacher-lessons-page">
    <div class="lessons-head">
        <div>
            <span class="student-section-kicker">Professor · YourRhythm</span>
            <h1>Aulas</h1>
            <p>Consulte, crie e gerencie as aulas registradas da sua turma.</p>
        </div>
        <button type="button" class="btn btn-primary btn-sm" data-open-create>Criar aula</button>
    </div>

    @if (TempData["Error"] is string error)
    {
        <div class="auth-validation" role="alert">@error</div>
    }
    @if (TempData["Success"] is string success)
    {
        <div class="auth-success" role="status">@success</div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="auth-validation" role="alert"></div>
    }

    <section class="lessons-list-panel" aria-busy="false">
        <div class="student-panel-head compact">
            <div>
                <span class="student-section-kicker">Historico</span>
                <h2>@Model.Lessons.Count aula@(Model.Lessons.Count == 1 ? "" : "s") nesta pagina</h2>
            </div>
        </div>

        @if (!Model.Lessons.Any())
        {
            <div class="module-empty">
                <strong>Nenhuma aula registrada.</strong>
                <p>Use “Criar aula” para registrar data, hora, aluno e descricao.</p>
            </div>
        }
        else
        {
            <div class="lesson-list" data-lesson-list>
                @foreach (var lesson in Model.Lessons)
                {
                    var local = lesson.LessonDateUtc.ToLocalTime();
                    var shortNotes = string.IsNullOrWhiteSpace(lesson.Notes)
                        ? "Sem observacoes."
                        : lesson.Notes.Length > 120 ? $"{lesson.Notes[..120]}..." : lesson.Notes;
                    <button type="button"
                            class="lesson-list-card"
                            data-open-detail
                            data-id="@lesson.Id"
                            data-student-id="@lesson.StudentProfileId"
                            data-student-name="@lesson.StudentName"
                            data-instrument="@lesson.StudentInstrument"
                            data-title="@lesson.Title"
                            data-notes="@lesson.Notes"
                            data-date="@local.ToString("yyyy-MM-ddTHH:mm")"
                            data-date-label="@local.ToString("dd/MM/yyyy HH:mm")"
                            data-status="@StatusLabel(lesson.Status)">
                        <span class="lesson-card-main">
                            <strong>@lesson.Title</strong>
                            <small>@lesson.StudentName · @lesson.StudentInstrument</small>
                            <span>@shortNotes</span>
                        </span>
                        <span class="lesson-card-meta">
                            <strong>@local.ToString("dd/MM")</strong>
                            <small>@local.ToString("HH:mm")</small>
                            <em>@StatusLabel(lesson.Status)</em>
                        </span>
                    </button>
                }
            </div>
        }

        @if (Model.HasPreviousPage || Model.HasNextPage)
        {
            <nav class="lesson-pager" aria-label="Paginacao de aulas">
                @if (Model.HasPreviousPage)
                {
                    <a class="btn btn-ghost btn-sm" asp-action="Lessons" asp-route-page="@(Model.Page - 1)">Anterior</a>
                }
                <span>Pagina @Model.Page</span>
                @if (Model.HasNextPage)
                {
                    <a class="btn btn-ghost btn-sm" asp-action="Lessons" asp-route-page="@(Model.Page + 1)">Proxima</a>
                }
            </nav>
        }
    </section>
</section>

<div class="student-action-modal" data-create-panel @(openCreate ? "" : "hidden")>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card lesson-modal-card" role="dialog" aria-modal="true" aria-labelledby="lesson-create-title">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Nova aula</span><h2 id="lesson-create-title">Criar aula</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>
        <form asp-action="CreateLessonFromLessons" method="post" class="auth-form compact-form" data-safe-submit>
            @Html.AntiForgeryToken()
            <div>
                <label asp-for="CreateForm.StudentProfileId">Aluno</label>
                <select asp-for="CreateForm.StudentProfileId" required>
                    <option value="">Selecione o aluno</option>
                    @foreach (var student in Model.Students.OrderBy(s => s.DisplayName))
                    {
                        <option value="@student.StudentProfileId">@student.DisplayName - @student.Instrument</option>
                    }
                </select>
                <span asp-validation-for="CreateForm.StudentProfileId" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="CreateForm.LessonDateUtc">Data e hora</label>
                <input asp-for="CreateForm.LessonDateUtc" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" required data-create-date />
                <span asp-validation-for="CreateForm.LessonDateUtc" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Title">Nome da aula</label>
                <input asp-for="CreateForm.Title" maxlength="180" placeholder="Gerado automaticamente pela data e hora" data-create-title />
                <span asp-validation-for="CreateForm.Title" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="CreateForm.Notes">Descricao da aula</label>
                <textarea asp-for="CreateForm.Notes" maxlength="2000" placeholder="O que foi trabalhado, observacoes e combinados..."></textarea>
                <span asp-validation-for="CreateForm.Notes" class="auth-error"></span>
            </div>
            <button type="submit" data-loading-text="Criando...">Criar aula</button>
        </form>
    </section>
</div>

<div class="student-action-modal" data-detail-panel hidden>
    <div class="student-action-modal-backdrop" data-close-modal></div>
    <section class="student-action-modal-card lesson-modal-card" role="dialog" aria-modal="true" aria-labelledby="lesson-detail-title">
        <div class="student-panel-head">
            <div><span class="student-section-kicker">Detalhes da aula</span><h2 id="lesson-detail-title" data-detail-title>Aula</h2></div>
            <button type="button" class="student-jump-btn" data-close-modal>Fechar</button>
        </div>

        <div class="lesson-detail-state" data-detail-view>
            <dl>
                <div><dt>Aluno</dt><dd data-detail-student></dd></div>
                <div><dt>Instrumento</dt><dd data-detail-instrument></dd></div>
                <div><dt>Data e hora</dt><dd data-detail-date></dd></div>
                <div><dt>Status</dt><dd data-detail-status></dd></div>
                <div class="wide"><dt>Descricao</dt><dd data-detail-notes></dd></div>
            </dl>
            <div class="lesson-modal-actions">
                <button type="button" class="btn btn-primary btn-sm" data-start-edit>Editar</button>
                <form method="post" data-delete-form data-safe-submit data-confirm-message="Excluir esta aula?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="studentProfileId" data-delete-student-id />
                    <button type="submit" class="btn btn-danger btn-sm" data-loading-text="Excluindo...">Excluir aula</button>
                </form>
            </div>
        </div>

        <form method="post" class="auth-form compact-form" data-edit-form data-safe-submit hidden>
            @Html.AntiForgeryToken()
            <input asp-for="EditForm.StudentProfileId" type="hidden" data-edit-student-id />
            <input asp-for="EditForm.LessonId" type="hidden" data-edit-id />
            <div>
                <label asp-for="EditForm.LessonDateUtc">Data e hora</label>
                <input asp-for="EditForm.LessonDateUtc" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" required data-edit-date />
                <span asp-validation-for="EditForm.LessonDateUtc" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="EditForm.Title">Nome da aula</label>
                <input asp-for="EditForm.Title" required maxlength="180" data-edit-title />
                <span asp-validation-for="EditForm.Title" class="auth-error"></span>
            </div>
            <div>
                <label asp-for="EditForm.Notes">Descricao</label>
                <textarea asp-for="EditForm.Notes" maxlength="2000" data-edit-notes></textarea>
                <span asp-validation-for="EditForm.Notes" class="auth-error"></span>
            </div>
            <div class="lesson-modal-actions">
                <button type="button" class="btn btn-ghost btn-sm" data-cancel-edit>Voltar</button>
                <button type="submit" data-loading-text="Salvando...">Salvar aula</button>
            </div>
        </form>
    </section>
</div>

<style>
    .teacher-lessons-page { max-width: 980px; margin: 0 auto; }
    .lessons-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
    .lessons-head h1 { margin: .2rem 0; font-size: clamp(1.7rem, 7vw, 2.4rem); }
    .lessons-head p { margin: 0; color: var(--text-muted, #9ca3af); max-width: 36rem; }
    .lessons-list-panel { background: var(--card-bg, #111827); border: 1px solid var(--border, #263247); border-radius: 14px; padding: clamp(1rem, 3vw, 1.25rem); overflow: hidden; }
    .lesson-list { display: grid; gap: .75rem; }
    .lesson-list-card { width: 100%; border: 1px solid rgba(148,163,184,.18); border-radius: 12px; background: rgba(15,23,42,.54); color: inherit; text-align: left; padding: .9rem; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: .8rem; cursor: pointer; }
    .lesson-list-card:hover, .lesson-list-card:focus-visible { border-color: rgba(96,165,250,.65); outline: none; }
    .lesson-card-main { min-width: 0; display: grid; gap: .28rem; }
    .lesson-card-main strong { overflow-wrap: anywhere; }
    .lesson-card-main small, .lesson-card-main span, .lesson-card-meta small { color: var(--text-muted, #9ca3af); }
    .lesson-card-main span { font-size: .85rem; line-height: 1.35; }
    .lesson-card-meta { display: grid; justify-items: end; align-content: start; gap: .2rem; white-space: nowrap; }
    .lesson-card-meta em { font-style: normal; font-size: .72rem; color: #93c5fd; border: 1px solid rgba(96,165,250,.35); border-radius: 999px; padding: .08rem .45rem; }
    .lesson-pager { display: flex; align-items: center; justify-content: center; gap: .75rem; margin-top: 1rem; color: var(--text-muted, #9ca3af); }
    .lesson-modal-card { max-width: 620px; }
    .lesson-detail-state dl { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem; margin: 0 0 1rem; }
    .lesson-detail-state dt { color: var(--text-muted, #9ca3af); font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; font-weight: 800; }
    .lesson-detail-state dd { margin: .18rem 0 0; overflow-wrap: anywhere; }
    .lesson-detail-state .wide { grid-column: 1 / -1; }
    .lesson-modal-actions { display: flex; gap: .6rem; flex-wrap: wrap; justify-content: flex-end; }
    .lesson-modal-actions form { margin: 0; }
    @@media (max-width: 560px) {
        .lessons-head { display: grid; }
        .lessons-head .btn { width: 100%; justify-content: center; }
        .lesson-list-card { grid-template-columns: 1fr; }
        .lesson-card-meta { justify-items: start; grid-auto-flow: column; justify-content: start; align-items: center; white-space: normal; }
        .lesson-detail-state dl { grid-template-columns: 1fr; }
        .lesson-modal-actions, .lesson-modal-actions .btn, .lesson-modal-actions button { width: 100%; justify-content: center; }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        var createPanel = document.querySelector('[data-create-panel]');
        var detailPanel = document.querySelector('[data-detail-panel]');
        var detailView = document.querySelector('[data-detail-view]');
        var editForm = document.querySelector('[data-edit-form]');
        var lastFocus = null;

        function open(panel) {
            if (!panel) return;
            lastFocus = document.activeElement;
            panel.hidden = false;
            document.body.classList.add('modal-open');
            panel.querySelector('button, input, select, textarea, a')?.focus();
        }

        function close() {
            document.querySelectorAll('.student-action-modal').forEach(function (panel) { panel.hidden = true; });
            document.body.classList.remove('modal-open');
            if (lastFocus && lastFocus.focus) lastFocus.focus();
        }

        function setText(selector, value) {
            var el = document.querySelector(selector);
            if (el) el.textContent = value || 'Nao informado';
        }

        function showDetailMode() {
            if (detailView) detailView.hidden = false;
            if (editForm) editForm.hidden = true;
        }

        function showEditMode() {
            if (detailView) detailView.hidden = true;
            if (editForm) editForm.hidden = false;
            editForm?.querySelector('input, select, textarea')?.focus();
        }

        function bindLesson(row) {
            var id = row.dataset.id || '';
            var studentId = row.dataset.studentId || '';
            setText('[data-detail-title]', row.dataset.title);
            setText('[data-detail-student]', row.dataset.studentName);
            setText('[data-detail-instrument]', row.dataset.instrument);
            setText('[data-detail-date]', row.dataset.dateLabel);
            setText('[data-detail-status]', row.dataset.status);
            setText('[data-detail-notes]', row.dataset.notes);

            document.querySelector('[data-edit-id]').value = id;
            document.querySelector('[data-edit-student-id]').value = studentId;
            document.querySelector('[data-edit-title]').value = row.dataset.title || '';
            document.querySelector('[data-edit-date]').value = row.dataset.date || '';
            document.querySelector('[data-edit-notes]').value = row.dataset.notes || '';
            editForm.action = '/Teacher/Lessons/' + id;

            document.querySelector('[data-delete-student-id]').value = studentId;
            document.querySelector('[data-delete-form]').action = '/Teacher/Lessons/' + id + '/Delete';
            showDetailMode();
        }

        document.querySelector('[data-open-create]')?.addEventListener('click', function () { open(createPanel); });
        document.querySelectorAll('[data-open-detail]').forEach(function (row) {
            row.addEventListener('click', function () {
                bindLesson(row);
                open(detailPanel);
            });
        });
        document.querySelector('[data-start-edit]')?.addEventListener('click', showEditMode);
        document.querySelector('[data-cancel-edit]')?.addEventListener('click', showDetailMode);
        document.querySelectorAll('[data-close-modal]').forEach(function (el) { el.addEventListener('click', close); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });

        document.querySelectorAll('[data-safe-submit]').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                var msg = form.dataset.confirmMessage;
                if (msg && !confirm(msg)) {
                    e.preventDefault();
                    return;
                }
                if (!form.checkValidity()) return;
                var btn = form.querySelector('button[type="submit"]');
                if (!btn || btn.disabled) {
                    e.preventDefault();
                    return;
                }
                btn.disabled = true;
                btn.textContent = btn.dataset.loadingText || 'Salvando...';
            });
        });

        function pad(v) { return String(v).padStart(2, '0'); }
        function autoTitle(date, title) {
            if (!date || !title) return;
            var touched = false;
            title.addEventListener('input', function () { touched = title.value.trim().length > 0; });
            date.addEventListener('change', function () {
                if (touched || !date.value) return;
                var d = new Date(date.value);
                if (Number.isNaN(d.getTime())) return;
                title.value = 'Aula de ' + pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear()
                    + ' as ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            });
        }
        autoTitle(document.querySelector('[data-create-date]'), document.querySelector('[data-create-title]'));

        if (@(openCreate ? "true" : "false")) open(createPanel);
        var openEditId = '@(openEditId?.ToString() ?? "")';
        if (openEditId) {
            var row = document.querySelector('[data-open-detail][data-id="' + openEditId + '"]');
            if (row) {
                bindLesson(row);
                open(detailPanel);
                showEditMode();
            }
        }
    }());
    </script>
}
