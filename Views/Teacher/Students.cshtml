@model YourRhythmStudio.ViewModels.Learning.TeacherStudentsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Meus alunos";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Meus alunos";
}

<div class="stat-strip">
    <div class="stat-chip"><span class="sc-val">@Model.Students.Count</span><span class="sc-lbl">Alunos ativos</span></div>
</div>

<div class="card">
    <div class="sl-header">
        <div>
            <h3>Meus alunos</h3>
            <div class="card-sub">Clique para gerenciar</div>
        </div>
        <a class="btn btn-primary btn-sm" asp-controller="Teacher" asp-action="CreateStudent">+ Cadastrar aluno</a>
    </div>

    <div class="sl-list">
        @foreach (var student in Model.Students)
        {
            <a asp-controller="Teacher" asp-action="StudentDetail" asp-route-studentId="@student.StudentProfileId" class="sl-row">
                <div class="pavatar">
                    @if (!string.IsNullOrWhiteSpace(student.ProfilePhotoUrl))
                    {
                        <img src="@student.ProfilePhotoUrl" alt="Foto de perfil de @student.DisplayName" />
                    }
                    else
                    {
                        @Initials(student.DisplayName)
                    }
                </div>
                <div class="sl-info">
                    <span class="sl-name">@student.DisplayName</span>
                    <span class="sl-sub">@student.Instrument · @(student.CurrentRepertoireTitle ?? "Sem repertório")</span>
                </div>
                <div class="sl-progress">
                    <div class="pbar"><i style="width:@student.RepertoireProgressPercent%"></i></div>
                    <span class="sl-pct">@student.RepertoireProgressPercent%</span>
                </div>
                <div class="sl-right">
                    <span class="pill lvl">Nível @student.CurrentLevel</span>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--muted);flex-shrink:0"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        }
        @if (!Model.Students.Any())
        {
            <div class="empty-state">
                <p>Nenhum aluno cadastrado ainda.</p>
                <a class="btn btn-primary" asp-controller="Teacher" asp-action="CreateStudent">Cadastrar primeiro aluno</a>
            </div>
        }
    </div>
</div>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        return parts.Length == 0 ? "YR" : string.Concat(parts.Select(part => char.ToUpperInvariant(part[0])));
    }
}
