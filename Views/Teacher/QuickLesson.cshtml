@model YourRhythmStudio.ViewModels.Learning.QuickLessonViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Registrar aula";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Registrar aula";
}

<section class="lesson-compose-page">
    <div class="lesson-compose-hero">
        <span class="student-section-kicker">Registro de aula</span>
        <h2>Nova aula</h2>
        <p>Selecione aluno, data e hora. O nome é gerado automaticamente e pode ser ajustado.</p>
    </div>

    <div class="lesson-compose-card">
        <form asp-controller="Teacher" asp-action="QuickLesson" method="post" class="auth-form compact-form">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="Form.StudentProfileId">Aluno</label>
                <select asp-for="Form.StudentProfileId">
                    <option value="">Selecione o aluno</option>
                    @foreach (var student in Model.Students)
                    {
                        <option value="@student.StudentProfileId">@student.DisplayName - @student.Instrument</option>
                    }
                </select>
                <span asp-validation-for="Form.StudentProfileId" class="auth-error"></span>
            </div>

            <div>
                <label asp-for="Form.LessonDateUtc">Data e hora</label>
                <input asp-for="Form.LessonDateUtc" id="quickLessonDate" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" value="@Model.Form.LessonDateUtc.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="Form.LessonDateUtc" class="auth-error"></span>
            </div>

            <div>
                <label asp-for="Form.Title">Nome da aula</label>
                <input asp-for="Form.Title" id="quickLessonTitle" placeholder="Gerado automaticamente pela data e hora" data-auto-title="true" />
                <span asp-validation-for="Form.Title" class="auth-error"></span>
            </div>

            <div>
                <label asp-for="Form.Notes">Descrição da aula</label>
                <textarea asp-for="Form.Notes" placeholder="O que será trabalhado, observações e combinados..."></textarea>
                <span asp-validation-for="Form.Notes" class="auth-error"></span>
            </div>

            <button type="submit">Registrar aula</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function(){
        var date = document.getElementById('quickLessonDate');
        var title = document.getElementById('quickLessonTitle');
        if (!date || !title) return;
        var custom = false;
        title.addEventListener('input', function(){ custom = title.value.trim().length > 0 && title.dataset.autoTitle !== 'true'; title.dataset.autoTitle = 'false'; });
        function pad(v){ return String(v).padStart(2, '0'); }
        function build(){
            if (custom || !date.value) return;
            var d = new Date(date.value);
            if (Number.isNaN(d.getTime())) return;
            title.value = 'Aula de ' + pad(d.getDate()) + '/' + pad(d.getMonth()+1) + '/' + d.getFullYear() + ' as ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            title.dataset.autoTitle = 'true';
        }
        date.addEventListener('change', build);
        build();
    }());
    </script>
}
