@using YourRhythmStudio.Application.Learning
@model YourRhythmStudio.ViewModels.Learning.TeacherLevelsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Niveis";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Progressao por Niveis";

    var rarityColors = new[] { "", "#64748B", "#22C55E", "#3B82F6", "#A855F7", "#FFB020" };
}

<p class="card-sub" style="margin-bottom:20px">Configure o que cada nivel representa para seus alunos: expectativas, objetivos e mensagem de conquista exibida no momento da promocao.</p>

<div style="display:grid;gap:12px">
    @foreach (var cfg in Model.LevelConfigs)
    {
        var color = rarityColors[cfg.Level];
        var levelSkills = Model.Skills.Where(s => s.RequiredLevel == cfg.Level && s.IsActive).ToList();
        <a class="card lvl-card" href="@Url.Action("LevelDetail", "Teacher", new { level = cfg.Level })"
           style="display:block;text-decoration:none;cursor:pointer;transition:box-shadow .15s">
            <div class="lvl-card-row">
                <div class="lvl-circle" style="background:@color">@cfg.Level</div>
                <div class="lvl-body">
                    <div class="lvl-title">
                        Nivel @cfg.Level - @cfg.LevelName
                        @if (!string.IsNullOrEmpty(cfg.Subtitle))
                        {
                            <span class="lvl-subtitle">- @cfg.Subtitle</span>
                        }
                    </div>
                    <div class="lvl-meta">
                        @cfg.MinXp.ToString("N0") - @cfg.MaxXp.ToString("N0") XP
                        @if (levelSkills.Any())
                        {
                            <span class="lvl-skills">· @levelSkills.Count habilidade(s)</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(cfg.Description))
                    {
                        <div class="lvl-desc">@cfg.Description</div>
                    }
                </div>
                <svg class="lvl-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </div>
        </a>
    }
</div>

<style>
.card:has(a) { padding: 0; }
.card[href]:hover { box-shadow: 0 0 0 2px rgba(var(--accent-rgb),0.25); }

/* ── Level card layout ─────────────────────────────────── */
.lvl-card-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 0; /* card already has padding */
}

.lvl-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    flex-shrink: 0;
    margin-top: 1px;
}

.lvl-body {
    flex: 1;
    min-width: 0; /* allows text to shrink and wrap inside flex */
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.lvl-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    overflow-wrap: anywhere;
    word-break: break-word;
}

.lvl-subtitle {
    font-weight: 400;
    color: var(--muted);
    margin-left: 4px;
}

.lvl-meta {
    font-size: 12px;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 4px 6px;
    align-items: center;
    margin-top: 1px;
}

.lvl-skills {
    /* inherits flex item behaviour from parent flex-wrap */
}

.lvl-desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 3px;
    overflow-wrap: anywhere;
    word-break: break-word;
}

.lvl-chevron {
    flex-shrink: 0;
    color: var(--muted);
    margin-top: 3px;
}

@@media (prefers-reduced-motion: reduce) {
    .lvl-card { transition: none !important; }
}

@@media (max-width: 480px) {
    .lvl-title  { font-size: 14px; }
    .lvl-desc   { font-size: 12.5px; }
    .lvl-meta   { font-size: 11.5px; }
    .lvl-circle { width: 36px; height: 36px; font-size: 14px; }
}
</style>
