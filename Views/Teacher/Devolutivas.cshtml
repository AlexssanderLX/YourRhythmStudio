@model YourRhythmStudio.ViewModels.Learning.DevolutivasViewModel
@using YourRhythmStudio.Domain.Learning.Enums
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Missoes";
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = "Missoes";

    string StatusLabel(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Pending => "Enviada",
        AssignmentStatus.InProgress => "Em andamento",
        AssignmentStatus.AwaitingReview => "Devolutiva enviada",
        AssignmentStatus.AdjustmentsRequested => "Ajustes solicitados",
        AssignmentStatus.Completed => "Concluida",
        AssignmentStatus.Skipped => "Cancelada",
        _ => status.ToString()
    };

    string StatusClass(AssignmentStatus status) => status switch
    {
        AssignmentStatus.AwaitingReview => "status-awaiting",
        AssignmentStatus.Completed => "status-done",
        AssignmentStatus.AdjustmentsRequested => "status-adjust",
        AssignmentStatus.InProgress => "status-live",
        _ => "status-default"
    };
}

<div class="dash-section teacher-missions-page">
    <div class="mission-page-top">
        <div>
            <span class="mission-kicker">Professor · YourRhythm</span>
            <h2>Central de missoes</h2>
            <p>Crie missoes, acompanhe devolutivas e revise respostas dos alunos.</p>
        </div>
        <a class="btn btn-primary" asp-controller="Teacher" asp-action="CreateMission">Nova missao</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">@TempData["Error"]</div>
    }

    <div class="mission-stats">
        <div><strong>@Model.Missions.Count</strong><span>Total</span></div>
        <div><strong>@Model.Pending.Count</strong><span>Para revisar</span></div>
        <div><strong>@Model.Missions.Count(m => m.Status == AssignmentStatus.Completed)</strong><span>Concluidas</span></div>
    </div>

    @if (!Model.Missions.Any())
    {
        <div class="empty-state">
            <strong>Nenhuma missao criada ainda.</strong>
            <p>Use "Nova missao" para enviar a primeira atividade pedagogica a um aluno.</p>
        </div>
    }
    else
    {
        <div class="mission-review-list">
            @foreach (var mission in Model.Missions.OrderBy(m => m.Status == AssignmentStatus.AwaitingReview ? 0 : 1).ThenByDescending(m => m.CreatedAtUtc))
            {
                <article class="mission-card @StatusClass(mission.Status)">
                    <div class="mission-card-header">
                        <div>
                            <span class="mission-student-label">@mission.StudentName</span>
                            <h3 class="mission-title">@mission.Title</h3>
                        </div>
                        <div class="mission-meta">
                            <span class="status-badge @StatusClass(mission.Status)">@StatusLabel(mission.Status)</span>
                            <span class="xp-badge">@mission.XpReward XP</span>
                        </div>
                    </div>
                    <div class="mission-card-body">
                        <span>Criada: @mission.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        @if (mission.SubmittedForReviewAtUtc.HasValue)
                        {
                            <span>Enviada: @mission.SubmittedForReviewAtUtc.Value.ToLocalTime().ToString("dd/MM HH:mm")</span>
                        }
                        @if (mission.CurrentRound > 1)
                        {
                            <span class="round-badge">Rodada @mission.CurrentRound</span>
                        }
                    </div>
                    <div class="mission-card-actions">
                        <a class="btn btn-primary btn-sm"
                           asp-controller="Teacher"
                           asp-action="MissionDetail"
                           asp-route-studentId="@mission.StudentProfileId"
                           asp-route-missionId="@mission.Id">
                            Abrir missao
                        </a>
                        @if (mission.Status != AssignmentStatus.Completed)
                        {
                            <form method="post"
                                  asp-controller="Teacher"
                                  asp-action="CancelMission"
                                  asp-route-studentId="@mission.StudentProfileId"
                                  asp-route-missionId="@mission.Id"
                                  onsubmit="return confirm('Apagar esta missao do historico ativo? Esta acao preserva auditoria, mas remove a missao das listas do aluno.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-sm">Apagar</button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>

<style>
    .teacher-missions-page { max-width: 980px; }
    .mission-page-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.25rem; }
    .mission-page-top h2 { margin: .2rem 0; font-size: clamp(1.5rem, 4vw, 2.1rem); }
    .mission-page-top p { margin: 0; color: var(--text-muted, #9ca3af); }
    .mission-kicker { color: #60a5fa; font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; font-weight: 700; }
    .mission-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .75rem; margin-bottom: 1rem; }
    .mission-stats div { border: 1px solid var(--border, #263247); border-radius: 12px; padding: 1rem; background: var(--card-bg, #111827); }
    .mission-stats strong { display: block; font-size: 1.55rem; line-height: 1; }
    .mission-stats span { color: var(--text-muted, #9ca3af); font-size: .82rem; }
    .empty-state { text-align: center; padding: 2rem; color: var(--text-muted, #9ca3af); border: 1px solid var(--border, #263247); border-radius: 14px; }
    .empty-state strong { color: inherit; }
    .mission-review-list { display: flex; flex-direction: column; gap: .85rem; }
    .mission-card { background: var(--card-bg, #111827); border: 1px solid var(--border, #263247); border-radius: 14px; padding: 1rem; }
    .mission-card.status-awaiting { border-color: rgba(245,158,11,.6); }
    .mission-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: .75rem; }
    .mission-student-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #60a5fa; }
    .mission-title { margin: .2rem 0 0; font-size: 1.05rem; font-weight: 800; }
    .mission-meta { display: flex; flex-direction: column; align-items: flex-end; gap: .3rem; flex-shrink: 0; }
    .status-badge { font-size: .72rem; font-weight: 800; padding: .18rem .55rem; border-radius: 999px; }
    .status-awaiting { background: rgba(245,158,11,.16); color: #fbbf24; }
    .status-done { background: rgba(16,185,129,.16); color: #34d399; }
    .status-adjust { background: rgba(239,68,68,.16); color: #fca5a5; }
    .status-live { background: rgba(96,165,250,.16); color: #93c5fd; }
    .status-default { background: rgba(148,163,184,.16); color: #cbd5e1; }
    .xp-badge { font-size: .75rem; font-weight: 700; color: #34d399; }
    .mission-card-body { font-size: .82rem; color: var(--text-muted, #9ca3af); display: flex; gap: .75rem; flex-wrap: wrap; margin-bottom: .85rem; }
    .round-badge { background: rgba(245,158,11,.16); color: #fbbf24; padding: .1rem .5rem; border-radius: 999px; font-size: .75rem; font-weight: 700; }
    .mission-card-actions { display: flex; justify-content: flex-end; gap: .5rem; flex-wrap: wrap; }
    .mission-card-actions form { margin: 0; }
    @@media (max-width: 620px) {
        .mission-page-top, .mission-card-header { flex-direction: column; }
        .mission-page-top .btn, .mission-card-actions .btn { width: 100%; justify-content: center; }
        .mission-stats { grid-template-columns: 1fr; }
        .mission-meta { align-items: flex-start; flex-direction: row; flex-wrap: wrap; }
    }
</style>
