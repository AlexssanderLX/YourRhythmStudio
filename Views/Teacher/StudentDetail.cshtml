@model YourRhythmStudio.ViewModels.Learning.TeacherStudentDetailWithSkillsViewModel
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Base.Detail.Student.DisplayName;
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = Model.Base.Detail.Student.DisplayName;
    ViewData["HideDashTopbar"] = true;

    var studentId = Model.Base.Detail.Student.StudentProfileId;
    var detail = Model.Base.Detail;
    var student = detail.Student;
    var completedAssignments = detail.Assignments.Count(a => a.Status.ToString() == "Completed");
    var openAssignments = detail.Assignments.Count(a => a.Status.ToString() == "Pending" || a.Status.ToString() == "InProgress");
    var visibleFeedback = detail.Feedback.Count(f => f.VisibleToStudent);
    var initials = string.Concat(student.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(part => char.ToUpperInvariant(part[0])));
    var latestRepertoire = detail.Repertoire.OrderByDescending(r => r.ProgressPercent).FirstOrDefault();
}

<section class="teacher-student-page">
    <div class="student-detail-hero">
        <div class="student-detail-topline">
            <a class="student-back-link" asp-controller="Teacher" asp-action="Students">
                <partial name="_DashIcon" model="@("users")" />
                Meus alunos
            </a>
            <a class="student-home-link" asp-controller="Home" asp-action="Index">
                <span aria-hidden="true">←</span>
                Voltar ao site
            </a>
        </div>

        <div class="student-profile-card">
            <div class="student-avatar-lg">@initials</div>
            <div class="student-profile-main">
                <span class="student-kicker">Aluno ativo</span>
                <h1>@student.DisplayName</h1>
                <p>@(string.IsNullOrWhiteSpace(student.Instrument) ? "Instrumento não informado" : student.Instrument) · Nivel @student.CurrentLevel</p>
            </div>
            <div class="student-xp-badge">
                <strong>@student.CurrentXp</strong>
                <span>XP</span>
            </div>
        </div>

        <div class="student-quick-stats" aria-label="Resumo do aluno">
            <div><strong>@student.CurrentLevel</strong><span>Nivel</span></div>
            <div><strong>@completedAssignments</strong><span>Missões feitas</span></div>
            <div><strong>@openAssignments</strong><span>Em aberto</span></div>
            <div><strong>@detail.Repertoire.Count</strong><span>Repertório</span></div>
        </div>

        @if (latestRepertoire is not null)
        {
            <div class="student-focus-strip">
                <span>Foco atual</span>
                <strong>@latestRepertoire.Title</strong>
                <div class="student-mini-bar"><i style="width:@latestRepertoire.ProgressPercent%"></i></div>
                <em>@latestRepertoire.ProgressPercent%</em>
            </div>
        }
    </div>

    @if (TempData["Error"] is string error)
    {
        <div class="auth-validation">@error</div>
    }

    @if (TempData["StudentAccessLink"] is string accessLink)
    {
        <section class="student-access-panel">
            <div>
                <span class="student-section-kicker">Acesso do aluno</span>
                <strong>Link pronto para enviar</strong>
            </div>
            <div class="student-access-row">
                <input id="student-access-link" type="text" readonly value="@accessLink" />
                <button type="button" class="btn btn-primary btn-sm" onclick="copyStudentLink()">Copiar</button>
            </div>
        </section>
    }

    <div class="student-action-bar">
        <form asp-controller="Teacher" asp-action="GenerateStudentAccessLink" asp-route-studentId="@studentId" method="post" class="student-inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-ghost btn-sm">Link de acesso</button>
        </form>
        <button type="button" class="student-jump-btn active" data-tab="tab-assignment">Missão</button>
        <button type="button" class="student-jump-btn" data-tab="tab-repertoire">Repertório</button>
        <button type="button" class="student-jump-btn" data-tab="tab-feedback">Feedback</button>
        <button type="button" class="student-jump-btn" data-tab="tab-lesson">Aula</button>
        <button type="button" class="student-jump-btn" data-tab="tab-skills">Skills</button>
    </div>

    <section class="student-workspace">
        <div class="student-form-panel">
            <div class="student-form-tab active" id="tab-assignment">
                <div class="student-panel-head">
                    <div>
                        <span class="student-section-kicker">Criar agora</span>
                        <h2>Nova missão</h2>
                    </div>
                    <span class="student-soft-pill">+@Model.Base.Assignment.XpReward XP</span>
                </div>
                <form asp-controller="Teacher" asp-action="CreateAssignment" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="Base.Assignment.StudentProfileId" type="hidden" value="@studentId" />
                    <div>
                        <label asp-for="Base.Assignment.Title">Titulo</label>
                        <input asp-for="Base.Assignment.Title" placeholder="Ex: Praticar escalas por 20 min" />
                    </div>
                    <div>
                        <label asp-for="Base.Assignment.Description">Descrição opcional</label>
                        <textarea asp-for="Base.Assignment.Description" placeholder="O que o aluno deve fazer?"></textarea>
                    </div>
                    <div>
                        <label asp-for="Base.Assignment.Rarity">Raridade</label>
                        <select asp-for="Base.Assignment.Rarity" id="assignRarity">
                            <option value="Comum">Comum — 100 XP</option>
                            <option value="Rara">Rara — 400 XP</option>
                            <option value="MuitoRara">Muito Rara — 1.500 XP</option>
                            <option value="Epica">Épica — 5.000 XP</option>
                            <option value="Lendaria">Lendária — 25.000 XP</option>
                        </select>
                    </div>
                    <div class="form-grid-compact">
                        <div>
                            <label asp-for="Base.Assignment.DueAtUtc">Prazo</label>
                            <input asp-for="Base.Assignment.DueAtUtc" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" />
                        </div>
                        <div>
                            <label asp-for="Base.Assignment.TargetMinutes">Minutos</label>
                            <input asp-for="Base.Assignment.TargetMinutes" type="number" min="0" placeholder="20" />
                        </div>
                        <div>
                            <label asp-for="Base.Assignment.XpReward">XP</label>
                            <input asp-for="Base.Assignment.XpReward" id="assignXp" type="number" min="0" max="50000" placeholder="100" />
                        </div>
                    </div>
                    <button type="submit">Criar missão</button>
                </form>
            </div>

            <div class="student-form-tab" id="tab-repertoire">
                <div class="student-panel-head">
                    <div>
                        <span class="student-section-kicker">Estudo guiado</span>
                        <h2>Adicionar repertório</h2>
                    </div>
                </div>
                <form asp-controller="Teacher" asp-action="AddRepertoire" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="Base.Repertoire.StudentProfileId" type="hidden" value="@studentId" />
                    <div>
                        <label asp-for="Base.Repertoire.Title">Música ou estudo</label>
                        <input asp-for="Base.Repertoire.Title" placeholder="Ex: Clair de Lune" />
                    </div>
                    <div>
                        <label asp-for="Base.Repertoire.ReferenceUrl">Link de referência</label>
                        <input asp-for="Base.Repertoire.ReferenceUrl" type="url" placeholder="https://youtube.com/..." />
                    </div>
                    <div class="form-grid-compact">
                        <div>
                            <label asp-for="Base.Repertoire.ComposerOrArtist">Autor</label>
                            <input asp-for="Base.Repertoire.ComposerOrArtist" placeholder="Debussy" />
                        </div>
                        <div>
                            <label asp-for="Base.Repertoire.Instrument">Instrumento</label>
                            <input asp-for="Base.Repertoire.Instrument" placeholder="Piano" />
                        </div>
                        <div>
                            <label asp-for="Base.Repertoire.Level">Nivel</label>
                            <input asp-for="Base.Repertoire.Level" type="number" min="1" placeholder="1" />
                        </div>
                    </div>
                    <button type="submit">Adicionar repertório</button>
                </form>
            </div>

            <div class="student-form-tab" id="tab-feedback">
                <div class="student-panel-head">
                    <div>
                        <span class="student-section-kicker">Retorno</span>
                        <h2>Feedback para o aluno</h2>
                    </div>
                    <span class="student-soft-pill">@visibleFeedback visíveis</span>
                </div>
                <form asp-controller="Teacher" asp-action="CreateFeedback" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="Base.Feedback.StudentProfileId" type="hidden" value="@studentId" />
                    <div>
                        <label asp-for="Base.Feedback.Message">Mensagem</label>
                        <textarea asp-for="Base.Feedback.Message" placeholder="Escreva um retorno claro e útil para o aluno."></textarea>
                    </div>
                    <label class="auth-check">
                        <input asp-for="Base.Feedback.VisibleToStudent" type="checkbox" />
                        <span>Visível para o aluno</span>
                    </label>
                    <button type="submit">Salvar feedback</button>
                </form>
            </div>

            <div class="student-form-tab" id="tab-lesson">
                <div class="student-panel-head">
                    <div>
                        <span class="student-section-kicker">Registro rápido</span>
                        <h2>Registrar aula</h2>
                    </div>
                </div>
                <form asp-controller="Teacher" asp-action="CreateLesson" asp-route-studentId="@studentId" method="post" class="auth-form compact-form">
                    @Html.AntiForgeryToken()
                    <input asp-for="Base.Lesson.StudentProfileId" type="hidden" value="@studentId" />
                    <div>
                        <label asp-for="Base.Lesson.Title">Titulo da aula</label>
                        <input asp-for="Base.Lesson.Title" placeholder="Ex: Técnica e repertório" />
                    </div>
                    <div>
                        <label asp-for="Base.Lesson.LessonDateUtc">Data e hora</label>
                        <input asp-for="Base.Lesson.LessonDateUtc" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" step="60" />
                    </div>
                    <div>
                        <label asp-for="Base.Lesson.DurationMinutes">Duração</label>
                        <input asp-for="Base.Lesson.DurationMinutes" type="number" min="0" max="600" placeholder="60" />
                    </div>
                    <div>
                        <label asp-for="Base.Lesson.Notes">Descrição da aula</label>
                        <textarea asp-for="Base.Lesson.Notes" placeholder="O que foi trabalhado, observações e combinados?"></textarea>
                    </div>
                    <button type="submit">Registrar aula</button>
                </form>
            </div>

            <div class="student-form-tab" id="tab-skills">
                <div class="student-panel-head">
                    <div>
                        <span class="student-section-kicker">Níveis</span>
                        <h2>Habilidades</h2>
                    </div>
                    <a class="student-inline-link" asp-controller="Teacher" asp-action="Skills">Editar base</a>
                </div>
                <p class="student-help-text">Habilidades até o nível atual contam como dominadas. Marque manualmente apenas antecipações de níveis acima.</p>
                @if (!Model.Skills.Any())
                {
                    <div class="student-empty-inline">Nenhuma habilidade definida ainda. <a asp-controller="Teacher" asp-action="Skills">Criar habilidades</a></div>
                }
                else
                {
                    <div class="student-skill-list">
                        @foreach (var level in Enumerable.Range(1, 5))
                        {
                            var levelSkills = Model.Skills.Where(s => s.RequiredLevel == level).ToList();
                            if (!levelSkills.Any()) continue;
                            <div class="skill-level-group">
                                <strong>Nivel @level</strong>
                                @foreach (var skill in levelSkills)
                                {
                                    <form asp-controller="Teacher" asp-action="ToggleSkillMastery" asp-route-studentId="@studentId" asp-route-skillId="@skill.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" disabled="@skill.InferredFromCurrentLevel" class="skill-toggle @(skill.Mastered ? "mastered" : "")">
                                            <span>@(skill.Mastered ? "OK" : "")</span>
                                            <em>@skill.Name</em>
                                            <small>@(skill.InferredFromCurrentLevel ? "Pelo nivel" : skill.Mastered ? "Dominada" : "Marcar")</small>
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <aside class="student-side-panel">
            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Missões</span><h2>@detail.Assignments.Count total</h2></div>
                </div>
                <div class="student-item-list">
                    @if (detail.Assignments.Any())
                    {
                        @foreach (var item in detail.Assignments.OrderBy(a => a.Status.ToString() == "Completed" ? 1 : 0).Take(5))
                        {
                            var statusLabel = item.Status.ToString() switch
                            {
                                "Pending" => "Pendente",
                                "InProgress" => "Em andamento",
                                "Completed" => "Concluida",
                                "Skipped" => "Ignorada",
                                _ => item.Status.ToString()
                            };
                            <article class="student-list-item">
                                <div><span>@statusLabel</span><strong>@item.Title</strong></div>
                                <em>+@item.XpReward XP</em>
                            </article>
                        }
                    }
                    else { <p class="student-empty-inline">Sem missões ainda.</p> }
                </div>
            </section>

            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Repertório</span><h2>@detail.Repertoire.Count itens</h2></div>
                </div>
                <div class="student-item-list">
                    @if (detail.Repertoire.Any())
                    {
                        @foreach (var item in detail.Repertoire.Take(5))
                        {
                            <article class="student-list-item progress-item">
                                <div>
                                    <span>@(string.IsNullOrWhiteSpace(item.ComposerOrArtist) ? item.Status : item.ComposerOrArtist)</span>
                                    <strong>@item.Title</strong>
                                    <div class="student-mini-bar"><i style="width:@item.ProgressPercent%"></i></div>
                                </div>
                                <em>@item.ProgressPercent%</em>
                            </article>
                        }
                    }
                    else { <p class="student-empty-inline">Sem repertório ainda.</p> }
                </div>
            </section>

            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Feedbacks</span><h2>@detail.Feedback.Count registros</h2></div>
                </div>
                <div class="student-item-list">
                    @if (detail.Feedback.Any())
                    {
                        @foreach (var item in detail.Feedback.OrderByDescending(f => f.CreatedAtUtc).Take(4))
                        {
                            <article class="student-list-item">
                                <div>
                                    <span>@(item.VisibleToStudent ? "Visivel" : "Privado") · @item.CreatedAtUtc.ToLocalTime().ToString("dd/MM")</span>
                                    <strong>@item.Message</strong>
                                </div>
                            </article>
                        }
                    }
                    else { <p class="student-empty-inline">Sem feedback ainda.</p> }
                </div>
            </section>

            @if (detail.Lessons.Any())
            {
                <section>
                    <div class="student-panel-head compact">
                        <div><span class="student-section-kicker">Aulas</span><h2>@detail.Lessons.Count registros</h2></div>
                    </div>
                    <div class="student-item-list">
                        @foreach (var lesson in detail.Lessons.OrderByDescending(l => l.LessonDateUtc).Take(4))
                        {
                            <a class="student-list-item" asp-controller="Teacher" asp-action="LessonDetail" asp-route-studentId="@studentId" asp-route-lessonId="@lesson.Id">
                                <div>
                                    <span>@lesson.LessonDateUtc.ToLocalTime().ToString("dd/MM") · @lesson.DurationMinutes min · @lesson.Status</span>
                                    <strong>@lesson.Title</strong>
                                </div>
                            </a>
                        }
                    </div>
                </section>
            }
        </aside>
    </section>
</section>

<script>
(function () {
    var buttons = document.querySelectorAll('.student-jump-btn');
    var panels = document.querySelectorAll('.student-form-tab');
    buttons.forEach(function (button) {
        button.addEventListener('click', function () {
            buttons.forEach(function (item) { item.classList.remove('active'); });
            panels.forEach(function (item) { item.classList.remove('active'); });
            button.classList.add('active');
            var target = document.getElementById(button.dataset.tab);
            if (target) target.classList.add('active');
        });
    });
}());
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    function copyStudentLink() {
        var input = document.getElementById('student-access-link');
        if (!input) return;
        var btn = document.querySelector('[onclick="copyStudentLink()"]');
        function done() {
            if (!btn) return;
            btn.textContent = 'Copiado';
            setTimeout(function () { btn.textContent = 'Copiar'; }, 1800);
        }
        function fallbackCopy() {
            input.removeAttribute('disabled');
            input.focus();
            input.select();
            input.setSelectionRange(0, input.value.length);
            try { document.execCommand('copy'); done(); }
            catch (_) { window.prompt('Copie o link do aluno:', input.value); }
        }
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(input.value).then(done).catch(fallbackCopy);
        } else {
            fallbackCopy();
        }
    }

    // Auto-fill XP when rarity changes
    (function(){
        var rarSel = document.getElementById('assignRarity');
        var xpIn   = document.getElementById('assignXp');
        var xpMap  = { Comum:100, Rara:400, MuitoRara:1500, Epica:5000, Lendaria:25000 };
        if (rarSel && xpIn) {
            rarSel.addEventListener('change', function(){
                xpIn.value = xpMap[rarSel.value] || 100;
            });
        }
    }());
    </script>
}
