@model YourRhythmStudio.ViewModels.Learning.TeacherStudentDetailWithSkillsViewModel
@using YourRhythmStudio.Domain.Learning.Enums
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = Model.Base.Detail.Student.DisplayName;
    ViewData["Role"] = "teacher";
    ViewData["DashTitle"] = Model.Base.Detail.Student.DisplayName;
    ViewData["HideDashTopbar"] = true;

    var detail = Model.Base.Detail;
    var student = detail.Student;
    var studentId = student.StudentProfileId;
    var progress = Model.Progress;
    var activeAssignments = detail.Assignments.Where(a => a.Status != AssignmentStatus.Completed && a.Status != AssignmentStatus.Skipped).Take(3).ToArray();
    var pendingPromotion = Model.Skills.FirstOrDefault(s => s.SkillType == SkillType.PromotionRequired && s.RequiredLevel == student.CurrentLevel && !s.Mastered);
    var recentLessons = detail.Lessons.OrderBy(l => l.LessonDateUtc).Where(l => l.LessonDateUtc >= DateTime.UtcNow.AddDays(-1)).Take(3).ToArray();
}

<section class="teacher-student-page">
    <div class="student-detail-hero">
        <div class="student-detail-topline">
            <a class="student-back-link" asp-controller="Teacher" asp-action="Students">
                <partial name="_DashIcon" model="@("users")" />
                Meus alunos
            </a>
            <button type="button" class="btn btn-primary btn-sm" data-action-modal>Abrir criar / editar</button>
        </div>

        <div class="student-profile-card">
            <div class="student-avatar-lg">@Initials(student.DisplayName)</div>
            <div class="student-profile-main">
                <span class="student-kicker">Resumo do aluno</span>
                <h1>@student.DisplayName</h1>
                <p>@(string.IsNullOrWhiteSpace(student.Instrument) ? "Instrumento não informado" : student.Instrument) · Nível @student.CurrentLevel</p>
            </div>
            <div class="student-xp-badge">
                <strong>@student.CurrentXp</strong>
                <span>XP</span>
            </div>
        </div>

        <div class="student-quick-stats" aria-label="Resumo do aluno">
            <div><strong>@student.CurrentLevel</strong><span>Nível</span></div>
            <div><strong>@(progress?.CurrentLevelProgressPercent ?? 0)%</strong><span>Progresso XP</span></div>
            <div><strong>@detail.Assignments.Count(a => a.Status == AssignmentStatus.Completed)</strong><span>Missões feitas</span></div>
            <div><strong>@detail.Repertoire.Count</strong><span>Repertório</span></div>
        </div>

        <div class="student-focus-strip">
            <span>Próxima evolução</span>
            <strong>@(pendingPromotion?.Name ?? (progress?.AwaitingPromotion == true ? "Aguardando skill obrigatória" : "Sem bloqueio obrigatório definido"))</strong>
            <div class="student-mini-bar"><i style="width:@(progress?.CurrentLevelProgressPercent ?? 0)%"></i></div>
            <em>@(progress?.CurrentLevelProgressPercent ?? 0)%</em>
        </div>
    </div>

    @if (TempData["Error"] is string error)
    {
        <div class="auth-validation">@error</div>
    }

    @if (TempData["StudentAccessLink"] is string accessLink)
    {
        <section class="student-access-panel">
            <div>
                <span class="student-section-kicker">Acesso do aluno</span>
                <strong>Link pronto para enviar</strong>
            </div>
            <div class="student-access-row">
                <input id="student-access-link" type="text" readonly value="@accessLink" />
                <button type="button" class="btn btn-primary btn-sm" onclick="copyStudentLink()">Copiar</button>
            </div>
        </section>
    }

    <nav class="student-action-bar student-module-nav" aria-label="Módulos do aluno">
        <a class="student-jump-btn active" asp-action="StudentDetail" asp-route-studentId="@studentId">Resumo</a>
        <a class="student-jump-btn" asp-action="StudentAssignments" asp-route-studentId="@studentId">Missões</a>
        <a class="student-jump-btn" asp-action="StudentRepertoire" asp-route-studentId="@studentId">Repertório</a>
        <a class="student-jump-btn" asp-action="StudentFeedback" asp-route-studentId="@studentId">Feedbacks</a>
        <a class="student-jump-btn" asp-action="StudentSkills" asp-route-studentId="@studentId">Skills</a>
        <a class="student-jump-btn" asp-action="StudentLessons" asp-route-studentId="@studentId">Aulas</a>
    </nav>

    <section class="student-workspace">
        <div class="student-form-panel">
            <div class="student-panel-head">
                <div>
                    <span class="student-section-kicker">Atalho inteligente</span>
                    <h2>O que precisa de atenção</h2>
                </div>
            </div>

            <div class="student-item-list">
                <article class="student-list-item">
                    <div>
                        <span>Skill obrigatória</span>
                        <strong>@(pendingPromotion?.Name ?? "Nenhuma skill bloqueando a evolução atual")</strong>
                    </div>
                    <a class="student-inline-link" asp-action="StudentSkills" asp-route-studentId="@studentId">Ver skills</a>
                </article>
                <article class="student-list-item">
                    <div>
                        <span>Missões ativas</span>
                        <strong>@activeAssignments.Length em andamento ou pendentes</strong>
                    </div>
                    <a class="student-inline-link" asp-action="StudentAssignments" asp-route-studentId="@studentId">Gerenciar</a>
                </article>
                <article class="student-list-item">
                    <div>
                        <span>Próximas aulas</span>
                        <strong>@recentLessons.Length agendadas</strong>
                    </div>
                    <a class="student-inline-link" asp-action="StudentLessons" asp-route-studentId="@studentId">Abrir aulas</a>
                </article>
            </div>
        </div>

        <aside class="student-side-panel">
            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Missões ativas</span><h2>@activeAssignments.Length recentes</h2></div>
                </div>
                <div class="student-item-list">
                    @foreach (var item in activeAssignments)
                    {
                        <article class="student-list-item">
                            <div><span>@item.Status</span><strong>@item.Title</strong></div>
                            <em>+@item.XpReward XP</em>
                        </article>
                    }
                    @if (!activeAssignments.Any()) { <p class="student-empty-inline">Sem missões abertas.</p> }
                </div>
            </section>

            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Repertórios recentes</span><h2>@detail.Repertoire.Count itens</h2></div>
                </div>
                <div class="student-item-list">
                    @foreach (var item in detail.Repertoire.Take(4))
                    {
                        <article class="student-list-item progress-item">
                            <div>
                                <span>@(item.HasAudio ? "Áudio" : "Link")</span>
                                <strong>@item.Title</strong>
                                <div class="student-mini-bar"><i style="width:@item.ProgressPercent%"></i></div>
                            </div>
                            <em>@item.ProgressPercent%</em>
                        </article>
                    }
                    @if (!detail.Repertoire.Any()) { <p class="student-empty-inline">Sem repertório ainda.</p> }
                </div>
            </section>

            <section>
                <div class="student-panel-head compact">
                    <div><span class="student-section-kicker">Últimos feedbacks</span><h2>@detail.Feedback.Count registros</h2></div>
                </div>
                <div class="student-item-list">
                    @foreach (var item in detail.Feedback.OrderByDescending(f => f.CreatedAtUtc).Take(3))
                    {
                        <article class="student-list-item">
                            <div>
                                <span>@(item.VisibleToStudent ? "Visível" : "Privado") · @item.CreatedAtUtc.ToLocalTime().ToString("dd/MM")</span>
                                <strong>@item.Message</strong>
                            </div>
                        </article>
                    }
                    @if (!detail.Feedback.Any()) { <p class="student-empty-inline">Sem feedback ainda.</p> }
                </div>
            </section>
        </aside>
    </section>
</section>

<div class="student-action-modal" data-action-modal-panel hidden>
    <div class="student-action-modal-backdrop" data-action-modal-close></div>
    <section class="student-action-modal-card" role="dialog" aria-modal="true" aria-label="Criar ou editar">
        <div class="student-panel-head">
            <div>
                <span class="student-section-kicker">Criar / Editar</span>
                <h2>@student.DisplayName</h2>
            </div>
            <button type="button" class="student-jump-btn" data-action-modal-close>Fechar</button>
        </div>
        <div class="student-modal-grid">
            <a asp-action="StudentAssignments" asp-route-studentId="@studentId">Criar missão<span>XP, prazo opcional e raridade</span></a>
            <a asp-action="StudentAssignments" asp-route-studentId="@studentId">Editar missão<span>Abra a lista de missões</span></a>
            <a asp-action="StudentRepertoire" asp-route-studentId="@studentId">Criar repertório<span>Link e/ou áudio</span></a>
            <a asp-action="StudentRepertoire" asp-route-studentId="@studentId">Editar repertório<span>Materiais enviados</span></a>
            <a asp-action="StudentFeedback" asp-route-studentId="@studentId">Registrar feedback<span>Público ou privado</span></a>
            <a asp-action="StudentSkills" asp-route-studentId="@studentId">Criar ou editar skill<span>Requisitos por nível</span></a>
            <a asp-action="StudentLessons" asp-route-studentId="@studentId">Criar ou editar aula<span>Data, hora e descrição</span></a>
            <a asp-action="CreateStudent">Editar aluno<span>Informações cadastrais</span></a>
        </div>
    </section>
</div>

@section Scripts {
    <script>
    (function(){
        var panel = document.querySelector('[data-action-modal-panel]');
        document.querySelectorAll('[data-action-modal]').forEach(function(btn){
            btn.addEventListener('click', function(){ if(panel) panel.hidden = false; });
        });
        document.querySelectorAll('[data-action-modal-close]').forEach(function(btn){
            btn.addEventListener('click', function(){ if(panel) panel.hidden = true; });
        });
    }());
    function copyStudentLink() {
        var input = document.getElementById('student-access-link');
        if (!input) return;
        navigator.clipboard?.writeText(input.value).catch(function(){ input.select(); document.execCommand('copy'); });
    }
    </script>
}

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        return parts.Length == 0 ? "YR" : string.Concat(parts.Select(part => char.ToUpperInvariant(part[0])));
    }
}
