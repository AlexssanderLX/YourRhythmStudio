@model YourRhythmStudio.ViewModels.Learning.TeacherDashboardViewModel
@using YourRhythmStudio.Domain.Learning.Enums
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Painel do professor";
    ViewData["Role"] = "teacher";
    var first = (User.Identity?.Name ?? "Professor").Split(' ')[0];
    ViewData["DashTitle"] = first;

    var activeStudents = Model.Summary.ActiveStudentCount;
    var pending        = Model.Summary.PendingAssignmentCount;
    var completed      = Model.Summary.RecentCompletedAssignmentCount;
    var lessons        = Model.Summary.RecentLessons;
    var students       = Model.Summary.RecentStudents;

    var now      = DateTime.Now;
    var hour     = now.Hour;
    var greeting = hour < 12 ? "Bom dia" : hour < 18 ? "Boa tarde" : "Boa noite";
    var weekday  = now.DayOfWeek switch {
        DayOfWeek.Sunday    => "domingo",
        DayOfWeek.Monday    => "segunda-feira",
        DayOfWeek.Tuesday   => "terça-feira",
        DayOfWeek.Wednesday => "quarta-feira",
        DayOfWeek.Thursday  => "quinta-feira",
        DayOfWeek.Friday    => "sexta-feira",
        _                   => "sábado"
    };
    var todayLabel = now.ToString("dd 'de' MMMM", new System.Globalization.CultureInfo("pt-BR"));
}

@* ── Greeting ──────────────────────────────────────────────────────────── *@
<div class="cmd-greeting">
    <div>
        <h1 class="cmd-hello">@greeting, <span>@first</span> 👋</h1>
        <p class="cmd-subline">
            Hoje é @weekday, @todayLabel
            @if (pending > 0) {
                <span class="cmd-badge cmd-badge--warn">@pending missão@(pending == 1 ? "" : "ões") pendente@(pending == 1 ? "" : "s")</span>
            } else {
                <span class="cmd-badge cmd-badge--ok">Tudo em dia</span>
            }
        </p>
    </div>
</div>

@* ── KPI Cards ─────────────────────────────────────────────────────────── *@
<div class="cmd-kpi-grid cmd-kpi-grid--4">

    <a class="cmd-kpi" asp-controller="Teacher" asp-action="Students"
       aria-label="@activeStudents alunos ativos">
        <span class="cmd-kpi-icon" aria-hidden="true">👨‍🎓</span>
        <strong class="cmd-kpi-val">@activeStudents</strong>
        <span class="cmd-kpi-label">Alunos ativos</span>
    </a>

    <a class="cmd-kpi @(pending > 0 ? "cmd-kpi--warn" : "")"
       href="/Teacher/Missions?status=pending"
       aria-label="@pending missões pendentes">
        <span class="cmd-kpi-icon" aria-hidden="true">🎯</span>
        <strong class="cmd-kpi-val">@pending</strong>
        <span class="cmd-kpi-label">Missões pendentes</span>
    </a>

    <a class="cmd-kpi cmd-kpi--done"
       href="/Teacher/Missions?status=completed"
       aria-label="@completed missões concluídas nos últimos 14 dias">
        <span class="cmd-kpi-icon" aria-hidden="true">✅</span>
        <strong class="cmd-kpi-val">@completed</strong>
        <span class="cmd-kpi-label">Concluídas (14d)</span>
    </a>

    <div class="cmd-kpi" aria-label="@lessons.Count aulas recentes">
        <span class="cmd-kpi-icon" aria-hidden="true">📖</span>
        <strong class="cmd-kpi-val">@lessons.Count</strong>
        <span class="cmd-kpi-label">Aulas recentes</span>
    </div>

</div>

@* ── Panels ─────────────────────────────────────────────────────────────── *@
<div class="cmd-panels">

    @* Left — Recent Students *@
    <div class="cmd-panel">
        <div class="cmd-panel-head">
            <h2>Turma</h2>
            <a asp-controller="Teacher" asp-action="Students">Ver todos →</a>
        </div>

        @if (students.Any()) {
            <div class="cmd-student-list">
                @foreach (var s in students) {
                    var rep = Math.Clamp(s.RepertoireProgressPercent, 0, 100);
                    <a class="cmd-student"
                       asp-controller="Teacher" asp-action="StudentDetail"
                       asp-route-studentId="@s.StudentProfileId"
                       aria-label="Abrir perfil de @s.DisplayName">
                        <div class="cmd-avatar">
                            @if (!string.IsNullOrWhiteSpace(s.ProfilePhotoUrl)) {
                                <img src="@s.ProfilePhotoUrl" alt="" aria-hidden="true" />
                            } else {
                                <span aria-hidden="true">@Initials(s.DisplayName)</span>
                            }
                        </div>
                        <div class="cmd-student-body">
                            <div class="cmd-student-row">
                                <strong>@s.DisplayName</strong>
                                <span class="cmd-lvl-badge">Nv @s.CurrentLevel</span>
                            </div>
                            <p class="cmd-student-sub">@s.Instrument@(s.CurrentRepertoireTitle != null ? $" · {s.CurrentRepertoireTitle}" : "")</p>
                            <div class="cmd-prog-bar" role="progressbar" aria-valuenow="@rep" aria-valuemin="0" aria-valuemax="100" aria-label="Progresso no repertório @rep por cento">
                                <i style="width:@rep%"></i>
                            </div>
                        </div>
                    </a>
                }
            </div>
        } else {
            <div class="cmd-empty">
                <p>Nenhum aluno cadastrado ainda.</p>
            </div>
        }
    </div>

    @* Right — Recent Lessons *@
    <div class="cmd-panel">
        <div class="cmd-panel-head">
            <h2>Aulas recentes</h2>
        </div>

        @if (lessons.Any()) {
            <div class="cmd-timeline">
                @foreach (var l in lessons) {
                    var local  = l.LessonDateUtc.ToLocalTime();
                    var isDone = l.Status == LessonStatus.Completed;
                    var isCx   = l.Status == LessonStatus.Cancelled;
                    <a class="cmd-lesson @(isDone ? "cmd-lesson--done" : isCx ? "cmd-lesson--cx" : "")"
                       asp-controller="Teacher" asp-action="LessonDetail"
                       asp-route-studentId="@l.StudentProfileId"
                       asp-route-lessonId="@l.Id">
                        <span class="cmd-lesson-dot" aria-hidden="true"></span>
                        <div class="cmd-lesson-body">
                            <strong>@l.Title</strong>
                            <small>@local.ToString("dd/MM · HH:mm") · @(isDone ? "Concluída" : isCx ? "Cancelada" : "Planejada")</small>
                        </div>
                    </a>
                }
            </div>
        } else {
            <div class="cmd-empty">
                <p>Nenhuma aula registrada ainda.</p>
            </div>
        }
    </div>

</div>

@functions {
    private static string Initials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToArray();
        return parts.Length == 0 ? "YR" : string.Concat(parts.Select(p => char.ToUpperInvariant(p[0])));
    }
}
