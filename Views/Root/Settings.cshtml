@model YourRhythmStudio.ViewModels.Root.RootSettingsViewModel
@{
    Layout = "_RootLayout";
    ViewData["Title"] = "Configuracoes";
    ViewData["RootSection"] = "settings";
}

<div class="root-settings-grid">
    <section class="root-card">
        <div class="root-card-title">Credenciais da conta Root</div>
        <p class="root-muted">
            Login atual: <strong>@Model.CurrentEmail</strong>
        </p>
        <p class="root-muted">
            A senha inicial e gerada automaticamente uma unica vez em <code>root-credentials.txt</code> na pasta de saida do app.
        </p>
        <form method="post" action="/Root/Settings/Credentials" class="root-form">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="cred-email">Novo e-mail de login</label>
                <input type="email" id="cred-email" name="NewEmail" value="@Model.CurrentEmail" required maxlength="256" />
            </div>
            <div class="form-group">
                <label for="cred-pwd">Nova senha <span class="root-form-hint">(deixe em branco para manter)</span></label>
                <input type="password" id="cred-pwd" name="NewPassword" minlength="8" autocomplete="new-password" />
            </div>
            <div class="form-group">
                <label for="cred-current">Senha atual <span class="root-required">*</span></label>
                <input type="password" id="cred-current" name="CurrentPassword" required autocomplete="current-password" />
            </div>
            <button type="submit" class="btn-root btn-primary">Salvar credenciais</button>
        </form>
    </section>

    <section class="root-card">
        <div class="root-card-title">Notificacoes e e-mail</div>
        <div class="email-status @(Model.IsNotificationReady ? "ready" : "pending")">
            <strong>@(Model.IsNotificationReady ? "Pronto para enviar" : "Configuracao incompleta")</strong>
            <span>@Model.EmailStatusMessage</span>
        </div>

        <dl class="email-status-list">
            <div>
                <dt>SMTP</dt>
                <dd>@(Model.IsSmtpReady ? "Configurado" : "Pendente")</dd>
            </div>
            <div>
                <dt>Host</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.SmtpHost) ? "Nao configurado" : $"{Model.SmtpHost}:{Model.SmtpPort}")</dd>
            </div>
            <div>
                <dt>Remetente</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.SmtpSenderEmail) ? "Nao configurado" : Model.SmtpSenderEmail)</dd>
            </div>
            <div>
                <dt>Usuario SMTP</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.SmtpUsername) ? "Nao configurado" : Model.SmtpUsername)</dd>
            </div>
            <div>
                <dt>Senha SMTP</dt>
                <dd>@(Model.HasSmtpPassword ? "Configurada" : "Nao configurada")</dd>
            </div>
            <div>
                <dt>Destino</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.NotificationRecipient) ? "Nao configurado" : Model.NotificationRecipient)</dd>
            </div>
            <div>
                <dt>Origem do destino</dt>
                <dd>@Model.NotificationRecipientSource</dd>
            </div>
        </dl>

        <form method="post" action="/Root/Settings/Notification" class="root-form">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="notif-email">E-mail destinatario das notificacoes</label>
                <input type="email" id="notif-email" name="Recipient"
                       value="@Model.NotificationRecipient" required maxlength="256"
                       placeholder="seu@email.com" />
            </div>
            <div class="settings-actions">
                <button type="submit" class="btn-root btn-primary">Salvar destinatario</button>
            </div>
        </form>

        <form method="post" action="/Root/Settings/TestEmail" class="settings-actions">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-root btn-ghost" @(Model.IsNotificationReady ? null : "disabled")>
                Enviar e-mail teste
            </button>
        </form>

        <p class="root-muted">
            SMTP deve ficar em <code>appsettings.Development.json</code>, User Secrets ou variaveis de ambiente.
            Senhas de app e tokens nao devem ser versionados.
        </p>
    </section>
</div>

<style>
    .root-settings-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 20px;
        align-items: start;
    }

    .root-muted {
        font-size: 13px;
        color: var(--muted);
        margin: 0 0 16px;
        line-height: 1.5;
    }

    .root-form-hint {
        font-weight: 400;
        color: var(--muted);
    }

    .root-required {
        color: #ef4444;
    }

    .email-status {
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 14px;
        border: 1px solid var(--border-soft);
        display: grid;
        gap: 4px;
    }

    .email-status.ready {
        background: rgba(34, 197, 94, .1);
        border-color: rgba(34, 197, 94, .28);
        color: #22c55e;
    }

    .email-status.pending {
        background: rgba(245, 158, 11, .1);
        border-color: rgba(245, 158, 11, .28);
        color: #f59e0b;
    }

    .email-status span {
        color: var(--muted);
        font-size: 13px;
    }

    .email-status-list {
        display: grid;
        gap: 8px;
        margin: 0 0 16px;
    }

    .email-status-list div {
        display: grid;
        grid-template-columns: 120px minmax(0, 1fr);
        gap: 12px;
        align-items: start;
        padding: 8px 0;
        border-bottom: 1px solid var(--border-soft);
    }

    .email-status-list dt {
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .email-status-list dd {
        margin: 0;
        color: var(--text);
        overflow-wrap: anywhere;
        font-size: 13px;
    }

    .settings-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 0 0 12px;
    }

    .btn-root:disabled {
        opacity: .5;
        cursor: not-allowed;
    }

    @@media (max-width: 760px) {
        .root-settings-grid {
            grid-template-columns: 1fr;
        }

        .email-status-list div {
            grid-template-columns: 1fr;
            gap: 3px;
        }
    }
</style>
