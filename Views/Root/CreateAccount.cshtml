@model YourRhythmStudio.ViewModels.Root.CreateAccountViewModel
@{ Layout = "_RootLayout"; ViewData["Title"] = "Nova Conta"; }

<div style="margin-bottom:12px">
    <a href="/Root/Accounts" style="color:var(--muted);font-size:13px;text-decoration:none">← Contas</a>
</div>

<div class="root-card" style="max-width:520px">
    <form asp-controller="Root" asp-action="CreateAccount" method="post" class="root-form" style="max-width:100%">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-error" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="form-group">
            <label asp-for="PlanCode">Plano</label>
            <select asp-for="PlanCode">
                <option value="">Selecione…</option>
                <option value="professor">Professor (individual)</option>
                <option value="escola">Escola / Studio</option>
            </select>
            <span asp-validation-for="PlanCode" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="DisplayName">Nome completo</label>
            <input asp-for="DisplayName" placeholder="Ex.: Ana Silva" autocomplete="name" />
            <span asp-validation-for="DisplayName" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Email">E-mail</label>
            <input asp-for="Email" type="email" placeholder="ana@studio.com" />
            <span asp-validation-for="Email" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="SchoolName">Nome da escola / studio</label>
            <input asp-for="SchoolName" placeholder="Ex.: Studio Música Viva" />
            <span asp-validation-for="SchoolName" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Phone">Telefone (opcional)</label>
            <input asp-for="Phone" placeholder="(11) 99999-9999" />
        </div>
        <div class="form-group">
            <label asp-for="Password">Senha temporária</label>
            <input asp-for="Password" type="password" placeholder="Mínimo 8 caracteres" />
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <div style="display:flex;gap:8px;margin-top:4px">
            <button type="submit" class="btn-root btn-primary">Criar conta</button>
            <a href="/Root/Accounts" class="btn-root btn-ghost">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
